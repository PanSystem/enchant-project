                -- [FIX RIFT] ถ้า TimeLeft อยู่ใน window ตอนนี้เลย → เข้าได้ทันที
                local tlNow = getRiftTimeLeft()
                local inWindow = tlNow > 0 and tlNow <= 15

                if not inWindow then
                    -- รอ signal (ปลุกทันทีเมื่อ TimeLeft เปลี่ยน)
                    riftSignalFired = false
                    local waitDl = os.clock() + 1.0  -- poll ทุก 1s เป็น fallback
                    while os.clock() < waitDl and not riftSignalFired and autoRiftRun do
                        task.wait(0.05)
                    end
                    -- เช็คอีกครั้งหลัง signal / timeout
                    tlNow = getRiftTimeLeft()
                    inWindow = tlNow > 0 and tlNow <= 15
                    if not inWindow then continue end
                end

                -- [FIX RIFT] อยู่ใน window แล้ว → เริ่มกระบวนการ
                riftSignalFired = false

