local function findTargetByPrefix(prefixList)
    local targetMon, nearestDist = nil, math.huge
    local char = LP.Character
    local pHRP = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
    
    for _, mon in ipairs(Server:GetChildren()) do
        local isMatch = false
        if type(prefixList) == "table" then
            for _, pref in ipairs(prefixList) do if string.match(mon.Name, "^" .. pref) then isMatch = true; break end end
        else
            if string.match(mon.Name, "^" .. prefixList) then isMatch = true end
        end

        if isMatch then
            local hum = mon:FindFirstChildOfClass("Humanoid")
            local hrp = mon:FindFirstChild("HumanoidRootPart") or mon:FindFirstChild("Torso")
            if hum and hum.Health > 0 and hrp then
                if pHRP then
                    local dist = (pHRP.Position - hrp.Position).Magnitude
                    if dist < nearestDist then nearestDist = dist; targetMon = {Model=mon, HRP=hrp, Humanoid=hum} end
                else
                    targetMon = {Model=mon, HRP=hrp, Humanoid=hum}; break
                end
            end
        end
    end
    return targetMon
end

