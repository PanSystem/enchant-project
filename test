            end)

            while getgenv().autoBoss do
                if not waitUntilAlive(cancelBoss, 20) then break end
                if cancelBoss() then break end
                clearBossConn()

                -- ── Wait if rift is running ──
                if riftInterrupt() then
                    getgenv().bossWaiting = false
                    while getgenv().autoBoss and (State.riftActive or State.riftSettling) do
                        task.wait(0.2)
                    end
                    if cancelBoss() then break end
                end

                if not isBossReady() then
                    bossSignalFired = false
                    getgenv().bossWaiting = false
                    local waitDl = os.clock() + 10
                    while os.clock() < waitDl and not isBossReady() do
                        if not getgenv().autoBoss then break end
                        if bossSignalFired then bossSignalFired = false; break end
                        -- Also break out if rift fires while waiting
                        if riftInterrupt() then break end
                        task.wait(0.5)
                    end
                    if not isBossReady() then task.wait(0.2); continue end
                end

                getgenv().bossWaiting = true

                -- ── If in Raid → wait for raid to finish (but abort if rift comes) ──
                if State.raidActive then
                    local raidWaitDl = os.clock() + 600
                    while State.raidActive and os.clock() < raidWaitDl do
                        if cancelBoss() then break end
                        -- Rift takes priority over waiting for raid
                        if riftInterrupt() then break end
                        task.wait(0.3)
                    end
                    -- If rift fired, yield to it
                    if riftInterrupt() then
                        getgenv().bossWaiting = false
                        while getgenv().autoBoss and (State.riftActive or State.riftSettling) do
                            task.wait(0.2)
                        end
                        if cancelBoss() then break end
                        continue
                    end
                end

                if cancelBoss() then continue end
                if not isBossReady() then getgenv().bossWaiting=false; continue end

                -- ── Begin Boss ──
                summonPaused=true; summonPauseReason="boss"
                getgenv().doBoss=true; State.bossActive=true

                R.Byte:FireServer(teleportBuffers["Demon Forest"]); lastStgUp=0

                local ok = waitCharReady("Demon Forest", cancelBoss, 18, 2)
                if not ok or cancelBoss() or riftInterrupt() then
                    bossFail()
                    if riftInterrupt() then
                        while getgenv().autoBoss and (State.riftActive or State.riftSettling) do task.wait(0.2) end
                    end
                    task.wait(1.0); continue
                end
                if not isBossEventActive() then bossFail(); task.wait(1.0); continue end

                task.wait(0.6)
                if cancelBoss() or riftInterrupt() then
                    bossFail()
                    if riftInterrupt() then
                        while getgenv().autoBoss and (State.riftActive or State.riftSettling) do task.wait(0.2) end
                    end
                    continue
                end

                local MAX_RETRY = 6
                local foundUI   = false

                for attempt = 1, MAX_RETRY do
                    if cancelBoss() or not isBossEventActive() or riftInterrupt() then break end
                    if detectBossFightUI() then foundUI=true; break end

                    local doorPart = waitBossEntering(4.0, function()
                        return cancelBoss() or riftInterrupt()
                    end)
                    if not doorPart then
                        R.Byte:FireServer(teleportBuffers["Demon Forest"]); lastStgUp=0
                        waitCharReady("Demon Forest", cancelBoss, 12, 2)
                        task.wait(0.8); continue
                    end

                    if not stagedTpToBoss(doorPart, function()
                        return cancelBoss() or riftInterrupt()
                    end) then
                        if attempt < MAX_RETRY then
                            R.Byte:FireServer(teleportBuffers["Demon Forest"]); lastStgUp=0
                            waitCharReady("Demon Forest", cancelBoss, 12, 2)
                            task.wait(0.8)
                        end
                        continue
                    end
                    if cancelBoss() or riftInterrupt() then break end

                    if waitBossFightUI(5.0, function()
                        return cancelBoss() or riftInterrupt()
                    end) then foundUI=true; break end

                    if attempt < MAX_RETRY then
                        R.Byte:FireServer(teleportBuffers["Demon Forest"]); lastStgUp=0
                        waitCharReady("Demon Forest", cancelBoss, 12, 2)
                        task.wait(1.0)
                    end
                end

                if not foundUI or cancelBoss() or riftInterrupt() then
                    bossFail()
                    if riftInterrupt() then
                        while getgenv().autoBoss and (State.riftActive or State.riftSettling) do task.wait(0.2) end
                    end
                    task.wait(1.0); continue
                end

                clearBossConn(); task.wait(2.0)
                if cancelBoss() or riftInterrupt() or not detectBossFightUI() then
                    bossFail()
                    if riftInterrupt() then
                        while getgenv().autoBoss and (State.riftActive or State.riftSettling) do task.wait(0.2) end
                    end
                    continue
                end

                local cBoss, cBossPart = nil, nil
                local spawnDl = os.clock() + 12
                local bossSpawnConn = nil; local bossJustSpawned = false
                pcall(function()
                    bossSpawnConn = ServerTargets.ChildAdded:Connect(function(child)
                        if child.Name:sub(1,9)=="BossFight" then bossJustSpawned=true end
                    end)
                end)

                while os.clock() < spawnDl do
                    if cancelBoss() or riftInterrupt() then break end
                    if bossJustSpawned then bossJustSpawned=false end
                    cBoss, cBossPart = getBossMobInStage()
                    if cBoss then break end
                    task.wait(0.08)
                end
                if bossSpawnConn then pcall(function() bossSpawnConn:Disconnect() end) end

                if not cBoss or cancelBoss() or riftInterrupt() then
                    bossFail()
                    if riftInterrupt() then
                        while getgenv().autoBoss and (State.riftActive or State.riftSettling) do task.wait(0.2) end
                    end
                    task.wait(1.0); continue
                end

                if cBossPart then
                    local hrpNow = getHRP()
                    if hrpNow then killVelocity(hrpNow); hrpNow.CFrame = CFrame.new(cBossPart.Position) end
                end
                task.wait(0.3)

                local fighting = true
                clearBossConn()
                Conns.boss = RunService.Heartbeat:Connect(function()
                    if not fighting or not getgenv().autoBoss then return end
                    -- If rift fires mid-boss, stop combat loop (rift connector takes over)
                    if State.riftActive then fighting=false; return end
                    sendAtk()
                    if cBoss and (not cBoss.Parent or not isMobAlive(cBoss)) then
                        cBoss=nil; cBossPart=nil; lastTgtUp=0
                    end
                    if not cBoss then
                        for _,m in next,getSTgts() do
                            if m.Name:sub(1,9)=="BossFight" and isMobAlive(m) then
                                cBoss=m; cBossPart=m.PrimaryPart or m:FindFirstChild("HumanoidRootPart"); break
                            end
                        end
                    end
                    if cBoss and cBossPart then
                        local hrp = getHRP(); if not hrp then return end
                        local mPos = cBossPart.Position
                        local dv   = hrp.Position - mPos
                        if dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z > 16 then
                            killVelocity(hrp); hrp.CFrame = CFrame.new(mPos)
                        end
                        reqAttack(cBoss)
                    end
                end)

                local bossDl = os.clock() + 300
                while fighting and getgenv().autoBoss and os.clock() < bossDl do
                    -- Rift → abort boss combat immediately
                    if State.riftActive then fighting=false; break end
                    lastTgtUp=0
                    local alive = false
                    for _,m in next,getSTgts() do
                        if m.Name:sub(1,9)=="BossFight" and isMobAlive(m) then alive=true; break end
                    end
                    if not alive then
                        task.wait(0.3); lastTgtUp=0
                        local stillAlive = false
                        for _,m in next,getSTgts() do
                            if m.Name:sub(1,9)=="BossFight" and isMobAlive(m) then stillAlive=true; break end
                        end
                        if not stillAlive then
                            getgenv().lastBossKill=os.clock(); fighting=false; break
                        end
                    end
                    task.wait(0.08)
                end

                fighting=false; clearBossConn()
                getgenv().doBoss    = false
                getgenv().bossWaiting = false
                State.bossActive    = false

                -- If rift fired, wait for it to finish before continuing
                if riftInterrupt() then
                    if summonPaused and summonPauseReason=="boss" then
                        summonPaused=false; summonPauseReason=nil
                    end
                    while getgenv().autoBoss and (State.riftActive or State.riftSettling) do task.wait(0.2) end
                    continue
                end

                if getgenv().autoBoss then
                    waitUntilBackAtLobby(cancelBoss)
                end

                if summonPaused and summonPauseReason=="boss" then
                    summonPaused=false; summonPauseReason=nil
                end
            end

            if bossSignalConn then pcall(function() bossSignalConn:Disconnect() end) end
            getgenv().bossWaiting=false
            State.bossActive=false
        end)
    end
})

