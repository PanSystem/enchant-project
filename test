-- ==========================================
-- [FIX] makeFarmConn — directTp parameter
--   directTp=false (Auto Nearest): เช็คระยะ ATK_D_SQ เท่านั้น ไม่ TP
--   directTp=true  (Auto Selected & others): TP ตรงไปที่มอนทันที
-- ==========================================
local function makeFarmConn(getScanFn, flagName, directTp)
    local cT,cP=nil,nil; local lastScan=0
    return RunService.Heartbeat:Connect(function()
        if not getgenv()[flagName] then return end
        sendAtk()

        if dpsActive then return end

        local hrp=getHRP(); if not hrp then return end
        if cT and cP then
            if not cT.Parent or not isMobAlive(cT) then cT=nil; cP=nil
            else
                local d=hrp.Position-cP.Position
                local dsq=d.X*d.X+d.Y*d.Y+d.Z*d.Z
                if directTp then
                    -- TP ตรงไปหามอนเลย
                    if dsq > Const.SNAP_D_SQ then
                        killVelocity(hrp)
                        hrp.CFrame = CFrame.new(cP.Position)
                    end
                    reqAttack(cT)
                else
                    -- Auto Nearest: เช็คระยะเท่านั้น ถ้าไกลเกินให้หามอนใหม่
                    if dsq > Const.ATK_D_SQ then
                        cT=nil; cP=nil; return
                    end
                    reqAttack(cT)
                end
                return
            end
        end
        local now=os.clock()
        if now-lastScan<0.04 then return end
        lastScan=now; cT,cP=getScanFn()
    end)
end

