            inventoryUnitsMap[finalName] = uData.folder
        end
    end
    table.sort(inventoryUnitsList)
end

local function safeGetVal(parent, name)
    if parent and parent:FindFirstChild(name) then return tostring(parent[name].Value) end
    return "N/A"
end

local function safeGetNestedVal(parent, folderName, name)
    local folder = parent and parent:FindFirstChild(folderName)
    if folder and folder:FindFirstChild(name) then return tostring(folder[name].Value) end
    return "N/A"
end

local function getStatLayoutAndTier(statName, valNumStr)
    local valNum = tonumber(valNumStr)
    if not valNum then return 0, "N/A" end
    
    local t = tVL[statName]
    local gData = t and t[math.floor(valNum * 10000 + 0.5)] or nil
    if gData then
        return gData.layout, gData.name
    end
    
    local bestLayout = 0
    local bestTier = "N/A"
    local minDiff = math.huge
    for tier, data in pairs(talent_check) do
        local targetVal = data.Status[statName]
        if targetVal then
            local diff = math.abs(valNum - targetVal)
            if diff < 0.015 and diff < minDiff then
                minDiff = diff
                bestLayout = data.layout
                bestTier = tier
            end
        end
    end
    return bestLayout, bestTier
end

local function getRawStat(unitFolder, statName)
    local val = safeGetNestedVal(unitFolder, "Potentials_Adjustment", statName)
    if val == "N/A" then
        if statName == "Abilities_DMG" then val = safeGetVal(unitFolder, "Ability_Talent")
        elseif statName == "Critical_Damage" then val = safeGetVal(unitFolder, "Critical_Talent")
        else val = safeGetVal(unitFolder, statName .. "_Talent") end
    end
    return val
end

local function waitTalentChange(unitFolder, statName, oldVal, timeout)
    local dl = os.clock() + (timeout or 2.0)
    while os.clock() < dl do
        local newVal = getRawStat(unitFolder, statName)
        if newVal ~= "N/A" and newVal ~= oldVal then
            return true 
        end
        task.wait(0.05)
    end
    return false
end

local function waitTraitChange(unitFolder, slotToRoll, oldVal, timeout)
    local dl = os.clock() + (timeout or 2.0)
    local traitNode = slotToRoll == "Primary" and "Primary" or "Sub"
    local legacyNode = slotToRoll == "Primary" and "Primary_Trait" or "Sub_Trait"
    
    while os.clock() < dl do
        local newVal = safeGetNestedVal(unitFolder, "Traits", traitNode)
        if newVal == "N/A" then newVal = safeGetVal(unitFolder, legacyNode) end
        
        if newVal ~= "N/A" and newVal ~= oldVal then
            return true
        end
        task.wait(0.05)
    end
    return false
end

local function getBaseTraitName(name)
    local b = string.match(name, "^(.-)%s+III$") or string.match(name, "^(.-)%s+II$") or string.match(name, "^(.-)%s+I$")
    return b or name
end

local autoTraitsEnabled = false
local autoTalentsEnabled = false
local customQueue = {} 
local unitStates = {} 

local function getUnitInfoText(unitFolder, isRolling, currentActiveDisp, tDone, talDone)
    if not unitFolder then return "No unit selected." end

    local nickName = safeGetVal(unitFolder, "Nickname")
    if nickName == "N/A" then nickName = unitFolder.Name end
    local level = safeGetVal(unitFolder, "Level")
    
    local traitPrimary = safeGetNestedVal(unitFolder, "Traits", "Primary")
    if traitPrimary == "N/A" then traitPrimary = safeGetVal(unitFolder, "Primary_Trait") end
    local traitSub = safeGetNestedVal(unitFolder, "Traits", "Sub")
    if traitSub == "N/A" then traitSub = safeGetVal(unitFolder, "Sub_Trait") end
    
    local _, talDmg = getStatLayoutAndTier("Damage", getRawStat(unitFolder, "Damage"))
    local _, talAbil = getStatLayoutAndTier("Abilities_DMG", getRawStat(unitFolder, "Abilities_DMG"))
    local _, talCrit = getStatLayoutAndTier("Critical_Damage", getRawStat(unitFolder, "Critical_Damage"))
    local _, talSpd = getStatLayoutAndTier("Speed", getRawStat(unitFolder, "Speed"))

    local tMark = ""
    if autoTraitsEnabled then tMark = tDone and " [✅ Traits]" or " [🔄 Rolling Traits...]" end
    
    local talMark = ""
    if autoTalentsEnabled then talMark = talDone and " [✅ Talents]" or " [🔄 Rolling Talents...]" end

    local info = string.format(
        "Name units : %s%s%s\nLevel Units : %s\n--- Traits ---\nPrimary > %s\nSub > %s\n--- Talents ---\nDamage > %s\nAbility Damage > %s\nCritical > %s\nSpeed > %s",
        nickName, tMark, talMark, level, traitPrimary, traitSub, talDmg, talAbil, talCrit, talSpd
    )
    
    info = info .. "\n\n--- Queue ---"
    
    if #customQueue > 0 then
        for i, uName in ipairs(customQueue) do
            local state = unitStates[uName] or "waiting"
            local emoji = " ⏸️ (Waiting)"
            
            if state == "done" then emoji = " ✅ (Done)"
            elseif state == "rolling" or uName == currentActiveDisp then 
                if isRolling then emoji = " 🔄 (Rolling)" end
            end
            
            info = info .. "\n" .. i .. ". " .. uName .. emoji
        end
    else
        info = info .. "\nNone"
    end
    
    return info
end

