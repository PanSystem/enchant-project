local function teleportToPosition(targetPos, killVelocity)
    local char = LP.Character
    local pHRP = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
    if not pHRP then return false end
    
    if killVelocity then
        pHRP.AssemblyLinearVelocity = Vector3.zero
        pHRP.AssemblyAngularVelocity = Vector3.zero
    end
    pHRP.CFrame = CFrame.new(targetPos)
    return true
end

local function tweenToPosition(targetPos)
    local char = LP.Character
    local pHRP = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
    if not pHRP then return nil end
    
    local dist = (pHRP.Position - targetPos).Magnitude
    local speed = 50 + (math.clamp(tweenSpeed, 0, 1) * 4950) 
    local t = dist / speed
    
    local tween = TS:Create(pHRP, TweenInfo.new(t, Enum.EasingStyle.Linear), {CFrame = CFrame.new(targetPos)})
    tween:Play()
    return tween
end

local function smartTeleport(targetMapName)
    local myData = RS:FindFirstChild("Players_Data") and RS.Players_Data:FindFirstChild(LP.Name)
    if not myData then return false end
    
    local onStage = myData:FindFirstChild("Data") and myData.Data:FindFirstChild("OnStage")
    if onStage and onStage.Value == targetMapName then return true end

    if mapBuffers[targetMapName] then
        for i = 1, 3 do 
            pcall(function() ByteNetReq:FireServer(buffer.fromstring(mapBuffers[targetMapName])) end)
            local success = SmartWait(function() return onStage.Value == targetMapName end, 3.0)
            if success then 
                task.wait(0.2) 
                return true 
            end
        end
    end
    return false
end

local function getMapFromEgg(eggName)
    if not eggName or eggName == "" then return "Lobby" end
    local lowerEgg = string.lower(eggName)
    for mapName, _ in pairs(mapBuffers) do
        local lowerMap = string.lower(mapName)
        if string.find(lowerMap, lowerEgg) or string.find(lowerEgg, lowerMap) then return mapName end
    end
    if string.find(lowerEgg, "namex") then return "Namex Planet" end
    if string.find(lowerEgg, "colosseum") then return "Colosseum Kingdom" end
    if string.find(lowerEgg, "demon") then return "Demon Forest" end
    if string.find(lowerEgg, "dungeon") then return "Dungeons Town" end
    if string.find(lowerEgg, "reaper") then return "Reaper Society" end
    return "Lobby"
end

