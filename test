    if not fn then uInfoPara:SetTitle("Rolling Unit"); uInfoPara:SetDesc("— No unit selected —"); return end
    local f=getUF_fn(fn); local d=getSUD(fn)
    if not d then uInfoPara:SetTitle("Rolling Unit"); uInfoPara:SetDesc("Unit data not found"); return end
    uInfoPara:SetTitle(string.format("[ %s ]  Lv.%d%s", tostring(d.un), tonumber(d.lv) or 0, d.sh and "  ⭐" or ""))
