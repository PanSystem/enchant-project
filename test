    if DS2.aaHB   then pcall(function() DS2.aaHB:Disconnect()   end); DS2.aaHB=nil   end
    doAAOff()
end

-- Pre-built unit debounce check — avoids GC pressure per frame
local _debCache = {}
local _debCacheValid = false
local _lastDebRebuild = 0

local function rebuildDebCache()
    _debCache = {}
    for i = 1, #_unitCache do
        local u = _unitCache[i]
        if u and u.Parent then
            local deb = _FindFirstChild(u, "Debounce")
            _debCache[i] = deb
        end
    end
    _debCacheValid = true
    _lastDebRebuild = os.clock()
end

local function allUnitsHitting()
    if not _unitCacheValid then return false end
    local n = #_unitCache
    if n == 0 then return false end
    -- Rebuild deb cache if needed
    if not _debCacheValid or (os.clock() - _lastDebRebuild) > 0.5 then
        rebuildDebCache()
    end
    for i = 1, n do
        local deb = _debCache[i]
        if not deb or deb.Value ~= true then return false end
    end
    return true
end

local function startMasterHB()
    if DS2.hb then DS2.hb:Disconnect() end

    -- Reused locals to avoid allocation per frame
    local now, mPos, dv, mn, last
    local hrp, hum, plrFolder, numUnits

    DS2.hb = RunService.Heartbeat:Connect(function()
        if not dpsActive then return end
        hrp = getHRP(); if not hrp then return end
        hum = hrp.Parent and hrp.Parent:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return end

        now = os.clock()

        -- Attack & click — always fire at max rate
        if now - _lastAtk >= Const.ATK_RATE then
            _lastAtk = now
            R.Byte:FireServer(unpack(attackArgs))
        end
        if now - _lastClk >= Const.CLK_RATE then
            _lastClk = now
            R.Byte:FireServer(unpack(clickArgs))
        end

        -- Safe boost DPS cap check
        if getgenv().safeBoostActive then
            local dpsObj = lp:FindFirstChild("DPS")
            if dpsObj and dpsObj.Value >= safeDMGLimit then
                safeBoostUntil = now + 5.0
            end
        end

        -- EQ firing — fire only when needed, batch-optimized
        if now >= safeBoostUntil then
            if now - DS2.lastEQ >= dpsInputDelay then
                DS2.lastEQ = now
                plrFolder = unitServerFolder
                if plrFolder and plrFolder.Parent then
                    if not _unitCacheValid then _rebuildUC(plrFolder); rebuildDebCache() end
                    numUnits = #_unitCache
                    if numUnits > 0 then
                        if allUnitsHitting() then
                            -- All units attacking → fire EQ burst
                            R.Byte:FireServer(DPS_EQ)
                            R.Byte:FireServer(DPS_EQ)
                        end
                        -- Even if not all hitting, still fire to keep flow
                        R.Byte:FireServer(DPS_EQ)
                    else
                        -- No units placed → fire continuously
                        R.Byte:FireServer(DPS_EQ)
                        R.Byte:FireServer(DPS_EQ)
                    end
                else
                    -- No folder found → fire continuously
                    R.Byte:FireServer(DPS_EQ)
                    R.Byte:FireServer(DPS_EQ)
                end
            end
        end

        -- Mob targeting & snap
        if not DS2.scanFn then return end

        DS2.chkTick = DS2.chkTick + 1
        if DS2.chkTick % 2 == 0 then
            if DS2.mob and (not DS2.mob.Parent or not isMobAlive(DS2.mob)) then
                DS2.mob=nil; DS2.part=nil
            end
        end

        DS2.scanTick = DS2.scanTick + 1
        if not DS2.mob and DS2.scanTick % 2 == 0 then
            DS2.mob, DS2.part = DS2.scanFn()
        end
        if not DS2.mob or not DS2.part then return end

        mPos = DS2.part.Position
        dv   = hrp.Position - mPos
        -- Tight 8-stud snap for precision
        if dv.X*dv.X + dv.Z*dv.Z > SNAP_SQ then
            killVelocity(hrp)
            hrp.CFrame = CFrame.new(mPos.X, hrp.Position.Y, mPos.Z)
        end

        -- Fire attack request at ultra-low rate
        last = pendingRequests[DS2.mob]
        if not last or (now - last >= DPS_REQ_RATE) then
            mn = mobNameCache[DS2.mob]
            if not mn then mn = getValidMobName(DS2.mob) end
            if type(mn) == "string" and mn ~= "" and mn ~= "nil" then
                R.Req:FireServer(mn, "Mouse")
                R.Req:FireServer(mn, "Mouse")
                pendingRequests[DS2.mob] = now
            end
        end
    end)
end

