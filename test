                if not verified then
                    if Conns.rift then Conns.rift:Disconnect(); Conns.rift = nil end
                    cRiftMob = nil; cRiftPart = nil; riftEngaged = false
                    getgenv().doRift = false
                    resetRiftDetection()
                    if summonPaused and summonPauseReason == "rift" then
                        summonPaused = false; summonPauseReason = nil
                    end
                    tpToLobbyConfirmed()
                    task.wait(2.0); continue
                end

                lastTgtUp = 0
                local hasMobs = riftHasLiveMobs()
                if not hasMobs then
                    task.wait(0.50); lastTgtUp = 0
                    hasMobs = riftHasLiveMobs()
                end

                if hasMobs then
                    riftEngaged = true

                    local hrpNow = getHRP()
                    if hrpNow then
                        local nearMob, nearPart = findNearestRiftMob()
                        if nearPart then
                            local dv = hrpNow.Position - nearPart.Position
                            if dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z > LEASH_SQ then
                                killVelocity(hrpNow)
                                hrpNow.CFrame = CFrame.new(nearPart.Position + Vector3.new(0,2,0))
                            end
                        end
                    end

                    startRiftCombat()

                    -- Combat loop
                    local combatDl = os.clock() + 300
                    while autoRiftRun and os.clock() < combatDl do
                        task.wait(0.06)
                        lastTgtUp = 0
                        if not riftHasLiveMobs() then
                            -- Confirm mob ตายจริง (2 รอบ)
                            task.wait(0.3); lastTgtUp = 0
                            if not riftHasLiveMobs() then break end
                        end

                        if cRiftPart then
                            local hrp2 = getHRP()
                            if hrp2 then
                                local dv = hrp2.Position - cRiftPart.Position
                                if dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z > LEASH_SQ then
                                    killVelocity(hrp2)
                                    hrp2.CFrame = CFrame.new(cRiftPart.Position + Vector3.new(0,2,0))
                                end
                            end
                        end
                    end

                    if Conns.rift then Conns.rift:Disconnect(); Conns.rift = nil end
                    cRiftMob = nil; cRiftPart = nil

                    -- รอ wave ใหม่ 8s
                    local waveFound = false
                    local postDl    = os.clock() + 8
                    while os.clock() < postDl and autoRiftRun do
                        task.wait(0.25); lastTgtUp = 0
                        if riftHasLiveMobs() then waveFound=true; break end
                    end

                    if waveFound then
                        riftEngaged = false
                        task.wait(0.10); continue
                    else
                        if Conns.rift then Conns.rift:Disconnect(); Conns.rift = nil end
                        cRiftMob = nil; cRiftPart = nil

                        local cancelExit = function()
                            return not autoRiftRun or not getgenv().autoRift
                        end
                        exitRiftViaPortal(cancelExit)

                        getgenv().doRift = false
                        resetRiftDetection()
                        riftEngaged = false
                        if summonPaused and summonPauseReason == "rift" then
                            summonPaused = false; summonPauseReason = nil
                        end
                    end

                else
                    local pList = getRiftPromptsWithPos()
                    if #pList > 0 then
                        riftEngaged = true
                        for _, entry in ipairs(pList) do
                            if not autoRiftRun then break end
                            local p, pos = entry.prompt, entry.pos
                            if not p or not p.Parent then continue end

                            if pos then
                                local hrpNow = getHRP()
                                if hrpNow then
                                    local dv = hrpNow.Position - pos
                                    if dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z > LEASH_SQ then
                                        killVelocity(hrpNow)
                                        hrpNow.CFrame = CFrame.new(pos + Vector3.new(0,2,0))
                                        task.wait(0.05)
                                    end
                                end
                            end

                            local fireDl = os.clock() + 2.5
                            while os.clock() < fireDl and autoRiftRun do
                                if not p or not p.Parent or not p.Enabled then break end
                                if pos then
                                    local hrpNow = getHRP()
                                    if hrpNow then
                                        local dv = hrpNow.Position - pos
                                        if dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z > LEASH_SQ then
                                            killVelocity(hrpNow)
                                            hrpNow.CFrame = CFrame.new(pos + Vector3.new(0,2,0))
                                            task.wait(0.04); continue
                                        end
                                    end
                                end
                                firePrompt(p); task.wait(0.07)
                            end
                        end
                    else
                        task.wait(0.30)
                    end
                end

                task.wait(0.15)
            end

            if Conns.rift then Conns.rift:Disconnect(); Conns.rift = nil end
            cRiftMob = nil; cRiftPart = nil
            if getgenv().doRift then
                local cancelFinal = function() return false end
                exitRiftViaPortal(cancelFinal)
                getgenv().doRift = false
            end
            resetRiftDetection()
            if summonPaused and summonPauseReason == "rift" then
                summonPaused = false; summonPauseReason = nil
            end
        end)
    end
})

