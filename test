end
local function cTS_fn(fn,sn,tg)
    local f=getUF_fn(fn); if not f then return true end
    local pa=f:FindFirstChild("Potentials_Adjustment"); if not pa then return true end
    local sv=pa:FindFirstChild(sn); if not sv then return true end
    local td=potD[tg]; if not td then return false end
    local g=lGr(sn,sv.Value)
    return g and g.layout>=td.layout
end
local function cTrS_fn(fn,tt,targetList)
    local tl=normalizeMultiVal(targetList or {}); if not fn or #tl==0 then return #tl==0 end
    local f=getUF_fn(fn); if not f then return false end
    local to=f:FindFirstChild(tt.."_Trait")
    if not to or not to:IsA("StringValue") then return false end
    local cur=to.Value
    for _,sl in ipairs(tl) do local g=trD2G[sl]; if g and cur==g then return true end end
    return false
end

local function getSlotRaw(fn,slot)
    local f=getUF_fn(fn); if not f then return nil end
    local to=f:FindFirstChild(slot.."_Trait")
    return (to and to:IsA("StringValue")) and to.Value or nil
end
local function smartComboDone(fn,comboList)
    local cl=normalizeMultiVal(comboList or {}); if #cl==0 then return true end
    local subRaw=getSlotRaw(fn,"Sub"); local primRaw=getSlotRaw(fn,"Primary")
    if not subRaw or not primRaw then return false end
    local subOk,primOk=false,false
    for _,label in ipairs(cl) do
        local g=trD2G[label]
        if g then if subRaw==g then subOk=true end; if primRaw==g then primOk=true end end
    end
    return subOk and primOk and (subRaw~=primRaw)
end

