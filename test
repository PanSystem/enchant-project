                    local hrp = getHRP(); if not hrp then return end
                    local mPos = cRiftPart.Position
                    local diff = hrp.Position - mPos
                    local dsq  = diff.X*diff.X + diff.Y*diff.Y + diff.Z*diff.Z

                    if dpsActive then
                        hrp.CFrame = CFrame.new(mPos)
                        reqAttack(cRiftMob)
                    else
                        if dsq > LEASH_SQ then
                            killVelocity(hrp)
                            hrp.CFrame = CFrame.new(mPos + Vector3.new(0, 2, 0))
                        end
                        reqAttack(cRiftMob)
                    end
                end)
            end

            -- [FIX] rift confirm counter — ต้อง 5 consecutive positives × 0.3s = 1.5s
            -- ก่อนถือว่า rift เกิดจริงและ TP ไป
            local riftConfirmCount = 0
            local RIFT_NEED_CONFIRM = 5

            while autoRiftRun do
                if not getgenv().autoRift then break end

                -- ── Cooldown guard ──────────────────────────────────────
                if os.clock() < riftCooldownUntil then
                    riftConfirmCount = 0
                    if riftEngaged or getgenv().doRift then
                        -- อยู่ใน rift แต่ cooldown running = rift จบแล้ว endRift
                        if Conns.rift then Conns.rift:Disconnect(); Conns.rift = nil end
                        cRiftMob = nil; cRiftPart = nil; riftEngaged = false
                        getgenv().doRift = false
                        if summonPaused and summonPauseReason == "rift" then
                            summonPaused = false; summonPauseReason = nil
                        end
                    end
                    task.wait(0.5); continue
                end

                -- ── ตรวจ physical evidence (STRICT) ────────────────────
                local strictOk = riftExistsStrict()

                if not strictOk then
                    riftConfirmCount = 0
                    if riftEngaged or getgenv().doRift then endRift() end
                    task.wait(0.25)
