task.spawn(function()
    while task.wait(0.5) do -- หน่วงเวลาเช็คคิวเพื่อลดภาระเครื่อง
        if #selectedInventoryUnits > 0 then
            unitInfoParagraph:SetDesc(getUnitInfoText())
            
            local activeTraitUnit, activeTalentUnit = nil, nil
            
            if autoTraitsEnabled then
                for _, uName in ipairs(selectedInventoryUnits) do
                    local unit = inventoryUnitsMap[uName]
                    if unit and not checkUnitTraitsDone(unit) then activeTraitUnit = unit; break end
                end
            end
            
            if autoTalentsEnabled then
                for _, uName in ipairs(selectedInventoryUnits) do
                    local unit = inventoryUnitsMap[uName]
                    if unit and not checkUnitTalentsDone(unit) then activeTalentUnit = unit; break end
                end
            end

            if not activeTraitUnit and not activeTalentUnit then continue end

            local firedAny = false
            
            -- [ Execute Traits ]
            if activeTraitUnit then
                local currentPri = safeGetNestedVal(activeTraitUnit, "Traits", "Primary"); if currentPri == "N/A" then currentPri = safeGetVal(activeTraitUnit, "Primary_Trait") end
                local currentSub = safeGetNestedVal(activeTraitUnit, "Traits", "Sub"); if currentSub == "N/A" then currentSub = safeGetVal(activeTraitUnit, "Sub_Trait") end
                
                local uiPri = getUiNameFromInternal(currentPri)
                local uiSub = getUiNameFromInternal(currentSub)
                
                local slotToRollTrait = nil
                local targetBuffsClean = {}

                if #targetTraits == 1 then
                    slotToRollTrait = (uiPri ~= targetTraits[1]) and "Primary" or "Sub"
                    table.insert(targetBuffsClean, getBaseTraitName(targetTraits[1]))
                else
                    local matchPri = table.find(targetTraits, uiPri) ~= nil
                    local matchSub = table.find(targetTraits, uiSub) ~= nil
                    
                    if matchPri and not matchSub then
                        slotToRollTrait = "Sub"
                        for _, t in ipairs(targetTraits) do if t ~= uiPri then table.insert(targetBuffsClean, getBaseTraitName(t)) end end
                    elseif matchSub and not matchPri then
                        slotToRollTrait = "Primary"
                        for _, t in ipairs(targetTraits) do if t ~= uiSub then table.insert(targetBuffsClean, getBaseTraitName(t)) end end
                    else
                        slotToRollTrait = "Primary"
                        for _, t in ipairs(targetTraits) do table.insert(targetBuffsClean, getBaseTraitName(t)) end
                    end
                end

                if slotToRollTrait then
                    pcall(function() RS:WaitForChild("Remotes"):WaitForChild("Gamblings"):WaitForChild("Traits"):FireServer(activeTraitUnit.Name, slotToRollTrait, targetBuffsClean, false) end)
                    firedAny = true
                end
            end
            
            -- [ Execute Talents ]
            if activeTalentUnit then
                local targetLayout = talent_check[targetTalentTier] and talent_check[targetTalentTier].layout or 0
                local highestCurrentLayout = 0
                local slotToRollTalent = nil
                
                for _, remStatName in pairs(talentUIToRemote) do
                    local valStr = safeGetNestedVal(activeTalentUnit, "Potentials_Adjustment", remStatName)
                    if valStr == "N/A" then valStr = safeGetVal(activeTalentUnit, remStatName == "Abilities_DMG" and "Ability_Talent" or (remStatName == "Critical_Damage" and "Critical_Talent" or remStatName .. "_Talent")) end
                    local l, _ = getStatLayoutAndTier(remStatName, valStr)
                    if l > highestCurrentLayout then highestCurrentLayout = l end
                end
                
                for _, uiTalent in ipairs(targetTalents) do
                    local remStatName = talentUIToRemote[uiTalent]
                    local tVal = safeGetNestedVal(activeTalentUnit, "Potentials_Adjustment", remStatName)
                    if tVal == "N/A" then tVal = safeGetVal(activeTalentUnit, remStatName == "Abilities_DMG" and "Ability_Talent" or (remStatName == "Critical_Damage" and "Critical_Talent" or remStatName .. "_Talent")) end
                    local l, _ = getStatLayoutAndTier(remStatName, tVal)
                    
                    if l < targetLayout then 
                        slotToRollTalent = remStatName; break
                    end
                end

                if highestCurrentLayout < 16 then 
                    pcall(function() RS:WaitForChild("Remotes"):WaitForChild("Systems"):WaitForChild("Potentials_Rolling"):FireServer(activeTalentUnit.Name, "Reroll", "Once") end)
                    firedAny = true
                elseif slotToRollTalent then
                    pcall(function() RS:WaitForChild("Remotes"):WaitForChild("Systems"):WaitForChild("Potentials_Rolling"):FireServer(activeTalentUnit.Name, "Reroll", slotToRollTalent) end)
                    firedAny = true
                end
            end
            
            if firedAny then task.wait(1.5) end -- พักให้ Server รีเฟรชค่าสเตตัสใหม่ก่อนเช็ครอบถัดไป
        end
    end
end)

