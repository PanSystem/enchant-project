-- 🎯 [ ระบบต่อสู้: วาร์ปประชิดตัว 0 Offset ย้ำๆ ]
-- ==========================================
local function attackMonster(targetMon, enabledCheckFunc)
    local lastReq = 0
    local isDead = false
    local connection
    local playerName = LP.Name
    local activeTween = nil
    local initialTpDone = false 

    connection = RunService.Heartbeat:Connect(function()
        if not targetMon or not targetMon.Model or not targetMon.Model.Parent or not targetMon.Humanoid or targetMon.Humanoid.Health <= 0 then
            isDead = true; if connection then connection:Disconnect() end; return
        end
        if enabledCheckFunc and not enabledCheckFunc() then
            isDead = true; if connection then connection:Disconnect() end; return
        end

        local char = LP.Character
        local pHRP = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
        if not pHRP then return end
        local targetHRP = targetMon.HRP
        if not targetHRP or not targetHRP.Parent then return end

        local hum = char:FindFirstChildOfClass("Humanoid")
        local currentTool = char:FindFirstChildOfClass("Tool")
        if hum and not currentTool then
            local bpTool = LP.Backpack:FindFirstChildOfClass("Tool")
            if bpTool then hum:EquipTool(bpTool) end
        end

        local destPos = targetHRP.Position
        
        if not initialTpDone then
            pHRP.CFrame = CFrame.new(destPos)
            pHRP.AssemblyLinearVelocity = Vector3.zero
            pHRP.AssemblyAngularVelocity = Vector3.zero
            initialTpDone = true
        else
            local distToDest = (pHRP.Position - destPos).Magnitude
            if farmMode == "Tp" then
                if distToDest > 25 then
                    pHRP.CFrame = CFrame.new(destPos)
                    pHRP.AssemblyLinearVelocity = Vector3.zero
                    pHRP.AssemblyAngularVelocity = Vector3.zero
                end
            elseif farmMode == "Tween" then
                if distToDest > 25 then
                    if not activeTween or activeTween.PlaybackState ~= Enum.PlaybackState.Playing then
                        activeTween = tweenToPosition(destPos)
                    end
                else
                    if activeTween then activeTween:Cancel(); activeTween = nil end
                end
            end
            
            if distToDest <= 40 then
                local now = os.clock()
                if now - lastReq > 0.15 then 
                    local inSaviors = false
                    local saviorsFolder = targetMon.Model:FindFirstChild("Saviors")
                    if saviorsFolder then
                        if saviorsFolder:FindFirstChild(playerName) then
                            inSaviors = true
                        else
                            for _, val in ipairs(saviorsFolder:GetChildren()) do
                                if val:IsA("StringValue") and val.Value == playerName then
                                    inSaviors = true; break
                                end
                            end
                        end
                    end

                    if not inSaviors then
                        lastReq = now
                        task.spawn(function() pcall(function() RequestReq:FireServer(targetMon.Model.Name, "Mouse") end) end)
                    end
                end
            end
        end
    end)

    while not isDead do task.wait(0.1) end
    if activeTween then activeTween:Cancel() end
    if connection then connection:Disconnect() end
end

