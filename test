    if DS2.aaHB   then pcall(function() DS2.aaHB:Disconnect()   end); DS2.aaHB=nil   end
    doAAOff()
end

-- [FIX DPS] allUnitsHit: ตรวจสอบแม่นยำ — ทุก unit ต้อง debounce=true
local function allUnitsHit()
    if DS2.unitCount == 0 then return false end
    local count = 0
    for _, deb in next, DS2.debs do
        if deb.Value then
            count = count + 1
        else
            return false  -- unit ยังไม่ hit → รอก่อน
        end
    end
    return count == DS2.unitCount
end

-- [FIX DPS] anyUnitHit: ใช้สำหรับ fallback trigger เมื่อ unit บางตัวช้า
local function anyUnitHit()
    for _, deb in next, DS2.debs do
        if deb.Value then return true end
    end
    return false
end

local DPS_REQ_RATE_HB = 0.012  -- [FIX DPS] เร็วขึ้น 0.015→0.012
local SNAP_SQ = 4               -- [FIX DPS] snap radius ลดเหลือ 2 studs (4=2²)

-- [FIX DPS] startMasterHB — ปรับ state machine ให้ตัดสินใจเร็วขึ้น
local function startMasterHB()
    if DS2.hb then DS2.hb:Disconnect() end

    -- state: 0=รอ allHit, 1=กำลังรอ delay, 2=fire equip
    local _eqFireNext = 0

    DS2.hb = RunService.Heartbeat:Connect(function()
        if not dpsActive then return end
        local now = os.clock()

        -- ยิง atk/clk ทุก frame (rate limited)
        if now - _lastAtk >= Const.ATK_RATE then
            _lastAtk = now; R.Byte:FireServer(unpack(attackArgs))
        end
        if now - _lastClk >= Const.CLK_RATE then
            _lastClk = now; R.Byte:FireServer(unpack(clickArgs))
        end

        local st = DS2.eqState

        -- ── STATE 0: รอสัญญาณ allHit ────────────────────────────────
        if st == 0 then
            if now < safeBoostUntil then return end

            local shouldFire = DS2.allHitFlag

            -- fallback: ถ้าไม่มี unit → fire ตาม delay เอง
            if not shouldFire and DS2.unitCount == 0 then
                shouldFire = now >= DS2.eqNext
            end

            -- fallback: ถ้าทุก unit hit จริง (re-check)
            if not shouldFire and DS2.unitCount > 0 then
                shouldFire = allUnitsHit()
            end

            if shouldFire then
                DS2.allHitFlag = false
                DS2.hitThisCycle = 0

                -- [FIX DPS] Safe boost check
                if getgenv().safeBoostActive then
                    local dpsObj = lp:FindFirstChild("DPS")
                    if dpsObj and dpsObj.Value >= safeDMGLimit then
                        safeBoostUntil = now + 5.0
                        DS2.eqState    = 0
                        DS2.allHitFlag = false
                        return
                    end
                end

                -- เข้า state 1: รอ delay แล้ว fire
                DS2.eqState = 1
                DS2.eqNext  = now + dpsInputDelay
            end

        -- ── STATE 1: delay ครบ → fire ───────────────────────────────
        elseif st == 1 then
            if now >= DS2.eqNext then
                R.Byte:FireServer(DPS_EQ)
                DS2.eqState = 0
                -- [FIX DPS] reset eqNext ให้ fallback timer ทำงานถูก
                DS2.eqNext  = now + dpsInputDelay * 2.0
            end
        end

        -- ── MOB SNAP + REQ ──────────────────────────────────────────
        if not DS2.scanFn then return end

        DS2.chkTick = DS2.chkTick + 1
        -- [FIX DPS] check mob alive ทุก 2 frame (ลดจาก 3)
        if DS2.chkTick % 2 == 0 then
            if DS2.mob and (not DS2.mob.Parent or not isMobAlive(DS2.mob)) then
                DS2.mob=nil; DS2.part=nil
            end
        end

        DS2.scanTick = DS2.scanTick + 1
        -- [FIX DPS] rescan ทุก 3 frame (ลดจาก 4)
        if not DS2.mob and DS2.scanTick % 3 == 0 then
            DS2.mob, DS2.part = DS2.scanFn()
        end
        if not DS2.mob or not DS2.part then return end

        local hrp = getHRP(); if not hrp then return end
        local mPos = DS2.part.Position
        -- [FIX DPS] snap ถ้าห่างเกิน 2 studs (SNAP_SQ=4)
        local dv = hrp.Position - mPos
        if dv.X*dv.X + dv.Z*dv.Z > SNAP_SQ then
            hrp.CFrame = CFrame.new(mPos)
        end

        -- [FIX DPS] ยิง req ทุก frame แต่ rate-limited ที่ 0.012s
        local last = pendingRequests[DS2.mob]
        if not last or (now - last >= DPS_REQ_RATE_HB) then
            local mn = mobNameCache[DS2.mob]
            if not mn then mn = getValidMobName(DS2.mob) end
            if type(mn) == "string" and mn ~= "" and mn ~= "nil" then
                R.Req:FireServer(mn, "Mouse"); pendingRequests[DS2.mob] = now
            end
        end
    end)
end

-- [FIX DPS] autoFire fallback สำหรับกรณีไม่มี unit เลย
local _autoFireHB = nil
local function startAutoFire()
    if _autoFireHB then return end
    _autoFireHB = RunService.Heartbeat:Connect(function()
        if not dpsActive or DS2.unitCount > 0 then return end
        -- ถ้าไม่มี unit ให้ eqNext หมดเร็ว
        if DS2.eqState == 0 and os.clock() > DS2.eqNext then
            DS2.allHitFlag = true
        end
    end)
end
local function stopAutoFire()
    if _autoFireHB then pcall(function() _autoFireHB:Disconnect() end); _autoFireHB = nil end
end

local function findDebounce(unitInst)
    local d = unitInst:FindFirstChild("Debounce")
    if d and d:IsA("BoolValue") then return d end
    for _, child in next, unitInst:GetChildren() do
        local dd = child:FindFirstChild("Debounce")
        if dd and dd:IsA("BoolValue") then return dd end
    end
    return nil
end

-- [FIX DPS] wireUnit — ใช้ signal แม่นยำ + reset hitThisCycle
local function wireUnit(unitInst)
    local uName = unitInst.Name
    if DS2.debs[uName] then return end

    local deb = findDebounce(unitInst)
    if not deb then
        local dc
        dc = unitInst.DescendantAdded:Connect(function(v)
            if v.Name == "Debounce" and v:IsA("BoolValue") then
                pcall(function() dc:Disconnect() end)
                DS2.desc[uName] = nil
                if dpsActive and not DS2.debs[uName] then wireUnit(unitInst) end
            end
        end)
        DS2.desc[uName] = dc
        return
    end

    DS2.debs[uName]  = deb
    DS2.unitCount    = DS2.unitCount + 1

    local prev = deb.Value
    DS2.conns[uName] = deb:GetPropertyChangedSignal("Value"):Connect(function()
        if not dpsActive then return end
        local cur = deb.Value

        -- [FIX DPS] false→true = unit เพิ่งตี
        if cur and not prev then
            DS2.hitThisCycle = DS2.hitThisCycle + 1
            -- ถ้าทุก unit ตีแล้ว → set allHitFlag ทันที
            if DS2.eqState == 0 and allUnitsHit() then
                DS2.allHitFlag = true
            end
        end

        prev = cur
    end)
end

local function unwireUnit(uName)
    local c = DS2.conns[uName]; if c then pcall(function() c:Disconnect() end); DS2.conns[uName]=nil end
    local d = DS2.desc[uName];  if d then pcall(function() d:Disconnect() end); DS2.desc[uName]=nil end
    if DS2.debs[uName] then DS2.debs[uName]=nil; DS2.unitCount=math.max(0,DS2.unitCount-1) end
end

local function dpsCleanup_impl()
    dpsActive = false
    DS2.eqState=0; DS2.eqNext=0; DS2.allHitFlag=false; DS2.hitThisCycle=0
    DS2.mob=nil; DS2.part=nil; DS2.scanFn=nil
    DS2.debs={}; DS2.unitCount=0
    safeBoostUntil = 0

    pcall(function() R.Byte:FireServer(DPS_EQ) end)

    stopAutoFire()
