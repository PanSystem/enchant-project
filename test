local function SmartWait(conditionFunc, timeout)
    local timeoutLimit = tonumber(timeout) or 15.0
    local startTime = os.clock()
    while (os.clock() - startTime) < timeoutLimit do
        local success, result = pcall(conditionFunc)
        if success and result == true then return true end
        task.wait() -- Frame-Perfect Check ไม่มีดีเลย์ค้าง
    end
    return false
end

