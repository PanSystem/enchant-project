local RAY_P = RaycastParams.new()
RAY_P.FilterType = Enum.RaycastFilterType.Exclude
local grOff = { Const.V3Z,
    Vector3.new(1,0,0), Vector3.new(-1,0,0),
    Vector3.new(0,0,1), Vector3.new(0,0,-1),
    Vector3.new(0.7,0,0.7),  Vector3.new(-0.7,0,0.7),
    Vector3.new(0.7,0,-0.7), Vector3.new(-0.7,0,-0.7)
}
local lastTP = 0

local function killVelocity(hrp)
    if not hrp or not hrp.Parent then return end
    hrp.AssemblyLinearVelocity  = Const.V3Z
    hrp.AssemblyAngularVelocity = Const.V3Z
end

local function tpPosition(cf, skipCooldown)
    local now = os.clock()
    if not skipCooldown and (now - lastTP < Const.TP_MIN) then return false end
    lastTP = now
    local hrp = getHRP(); if not hrp then return false end
    local pos = cf.Position
    if pos.Y < Const.ANTI_Y then pos = Vector3.new(pos.X, 0, pos.Z) end
    RAY_P.FilterDescendantsInstances = getParts()
    local best, originY, downVec = nil, pos.Y + 20, Vector3.new(0, -400, 0)
    for _, off in ipairs(grOff) do
        local r = Workspace:Raycast(Vector3.new(pos.X+off.X, originY, pos.Z+off.Z), downVec, RAY_P)
        if r and (not best or r.Position.Y > best) then best = r.Position.Y end
    end
    local finalY  = best and math.max(best+2, pos.Y) or math.max(pos.Y, Const.ANTI_Y+10)
    local _, rotY, _ = cf:ToEulerAnglesYXZ()
    local finalCF = CFrame.new(pos.X, finalY, pos.Z) * CFrame.Angles(0, rotY, 0)
    for i = 1, 4 do
        killVelocity(hrp); hrp.CFrame = finalCF
        if (hrp.CFrame.Position - finalCF.Position).Magnitude <= 2.0 then return true end
        if i < 4 then task.wait(0.03) end
    end
    return false
end

local function tpTarget(target)
    if not target then return false end
    local cf
    if target:IsA("Model") then
        local p = target.PrimaryPart or target:FindFirstChild("HumanoidRootPart")
        cf = p and p.CFrame or target:GetPivot()
    elseif target:IsA("BasePart") then cf = target.CFrame
    else
        local p = target:FindFirstChildWhichIsA("BasePart")
        cf = p and p.CFrame
    end
    return cf and tpPosition(cf) or false
end

local function tpDirect(part, skipCooldown, addOffset)
    if not part or not part.Parent then return false end
    local now = os.clock()
    if not skipCooldown and (now - lastTP < Const.TP_MIN) then return false end
    local hrp = getHRP(); if not hrp then return false end
    local mPos = part.Position
    local dv = hrp.Position - mPos
    if dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z <= 100 then return true end
    lastTP = now
    if mPos.Y < Const.ANTI_Y then mPos = Vector3.new(mPos.X, 0, mPos.Z) end
    local offX, offZ = 0, 0
    if addOffset then
        local angle = math.random() * math.pi * 2
        offX = math.cos(angle) * Const.MOB_OFF
        offZ = math.sin(angle) * Const.MOB_OFF
    end
    local finalCF = CFrame.new(mPos.X+offX, mPos.Y, mPos.Z+offZ)
    for i = 1, 4 do
        killVelocity(hrp); hrp.CFrame = finalCF
        if (hrp.CFrame.Position - finalCF.Position).Magnitude <= 2.0 then break end
        if i < 4 then task.wait(0.03) end
    end
    return true
end

local function tpInstant(cf)
    local hrp = getHRP()
    if hrp then killVelocity(hrp); hrp.CFrame = cf end
end

local function tpForceSnap(part, yOffset)
    if not part or not part.Parent then return false end
    local hrp = getHRP(); if not hrp then return false end
    yOffset = yOffset or 2
    local targetCF = CFrame.new(part.Position + Vector3.new(0, yOffset, 0))
    for i = 1, 5 do
        killVelocity(hrp)
        hrp.CFrame = targetCF
        task.wait(0.04)
        local diff = (hrp.CFrame.Position - targetCF.Position).Magnitude
        if diff <= 3.0 then return true end
    end
    return (hrp.CFrame.Position - targetCF.Position).Magnitude <= 5.0
end

local function stagedTpToBoss(targetPart, cancelFn)
    if not targetPart or not targetPart.Parent then return false end
    local tPos = targetPart.Position
    local hrp  = getHRP(); if not hrp then return false end
    local rawDir = hrp.Position - tPos
    local dir    = rawDir.Magnitude > 1 and rawDir.Unit or Vector3.new(0,0,1)
    local stages = {14, 8, 3, 0}
    for _, dist in ipairs(stages) do
        if cancelFn and cancelFn() then return false end
        hrp = getHRP(); if not hrp then return false end
        killVelocity(hrp)
        if dist > 0 then
            hrp.CFrame = CFrame.new(tPos + dir * dist + Vector3.new(0, 2, 0))
        else
            hrp.CFrame = CFrame.new(tPos + Vector3.new(0, 2, 0))
        end
        task.wait(0.10)
    end
    task.wait(0.15)
    return true
end

local function isMobAlive(mob)
    if not mob or not mob.Parent then return false end
    local h = mobHumCache[mob]
    if h == nil then h = mob:FindFirstChildOfClass("Humanoid"); mobHumCache[mob] = h or false end
    if not h then return false end
    return h.Health > 0
end

local function isLocked(mob)
    if not mob or not mob.Parent then return true end
    local saviors = mob:FindFirstChild("Saviors"); if not saviors then return false end
    for _, v in next, saviors:GetChildren() do
        if v:IsA("StringValue") and v.Value:find(myName, 1, true) then return true end
    end
    return false
end

local function getValidMobName(mob)
    if not mob or not mob.Parent then return nil end
    if mobNameCache[mob] then return mobNameCache[mob] end
    local n = mob.Name; local result
    if n:sub(1,5)=="Raids" or n:sub(1,5)=="Rifts" or n:sub(1,9)=="BossFight"
       or ClientTargets:FindFirstChild(n) then
        result = n
    else
        local display = mob:FindFirstChild("Units_Displays")
        local names   = display and display:FindFirstChild("Names")
        if names then
            local dn = names:IsA("TextLabel") and names.Text or names.Value
            if dn and dn ~= "" then
                for _, v in next, getSTgts() do
                    if v ~= mob then
                        local d2  = v:FindFirstChild("Units_Displays")
                        local n2  = d2 and d2:FindFirstChild("Names")
                        local dn2 = n2 and (n2:IsA("TextLabel") and n2.Text or n2.Value)
                        if dn2 == dn then result = v.Name; break end
                    end
                end
            end
        end
        result = result or n
    end
    mobNameCache[mob] = result
    return result
end

local function getMobDisplayName(mob)
    if mobDisplayCache[mob] then return mobDisplayCache[mob] end
    local dp = mob:FindFirstChild("Units_Displays")
    local no = dp and dp:FindFirstChild("Names")
    local mn = no and (no:IsA("TextLabel") and no.Text or no.Value) or nil
    mobDisplayCache[mob] = mn or false
    return mn
end

local pendingRequests = {}

local function reqAttack(mob)
    if not mob or not mob.Parent then return end
    local h = mobHumCache[mob]
    if h == nil then
        h = mob:FindFirstChildOfClass("Humanoid")
        mobHumCache[mob] = h or false
    end
    if not h or h.Health <= 0 then
        mobHumCache[mob]     = false
        mobNameCache[mob]    = nil
        mobDisplayCache[mob] = nil
        pendingRequests[mob] = nil
        return
    end
    if isLocked(mob) then pendingRequests[mob] = nil; return end

    local mobName = mobNameCache[mob]
    if not mobName then mobName = getValidMobName(mob) end
    if type(mobName) ~= "string" or mobName == "" or mobName == "nil" then
        mobNameCache[mob] = nil; return
    end

    if dpsActive then
        local now = os.clock()
        local last = pendingRequests[mob]
        if last and (now - last < 0.03) then return end
        pendingRequests[mob] = now
        R.Req:FireServer(mobName, "Mouse")
        return
    end

    local now  = os.clock()
    local last = pendingRequests[mob]
    if last and (now - last < Const.REQ_RATE) then return end
    R.Req:FireServer(mobName, "Mouse")
    pendingRequests[mob] = now
end

