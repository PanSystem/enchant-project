local function getBossMobInStage()
    lastTgtUp = 0
    for _,m in next,getSTgts() do
        if m.Name:sub(1,9)=="BossFight" and isMobAlive(m) then
            return m, m.PrimaryPart or m:FindFirstChild("HumanoidRootPart")
        end
    end
