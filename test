    Title="Auto Abandon Village", Flag="AutoAbandon", Value=false,
    Callback=function(state)
        getgenv().autoBoss = state
        if not state then
            bossFail()
            clearBossConn()
            return
        end

        task.spawn(function()
            local function cancelBoss()
                return not getgenv().autoBoss or getgenv().doRift
            end

            local function sendDemonTP()
                R.Byte:FireServer(teleportBuffers["Demon Forest"])
                lastStgUp = 0
            end

            while getgenv().autoBoss do

                -- [FIX] ล้าง conn เก่าทุกต้น loop ป้องกัน attack โดยไม่มี UI
                clearBossConn()

                local bossReady = isBossEventActive()
                               and (os.clock() - (getgenv().lastBossKill or 0) >= 25)
                getgenv().bossWaiting = bossReady

                if not bossReady or getgenv().doRift then
                    task.wait(0.8); continue
                end

                -- [PRIORITY FIX] Abandon รอ Raid เฉพาะเมื่อกำลังอยู่ใน session จริงๆ
                -- (raidInP=true AND มี session folder จริง)
                -- ถ้าไม่ได้ลง Raid → ไปทำ Abandon ก่อนทันที
                if getgenv().raidInP and getRaidSession() ~= nil then
                    local rDl = os.clock() + 600
                    while getgenv().raidInP and getRaidSession() ~= nil and os.clock() < rDl do
                        if cancelBoss() then break end
                        task.wait(0.5)
                    end
                end
                if cancelBoss() then continue end
                if not isBossEventActive() then
                    getgenv().bossWaiting = false; continue
                end

                summonPaused      = true
                summonPauseReason = "boss"
                getgenv().doBoss  = true

                sendDemonTP()

                local ok = waitCharReady("Demon Forest", cancelBoss, 22, 3)
                if not ok or cancelBoss() then bossFail(); task.wait(1.0); continue end
                if not isBossEventActive() then bossFail(); task.wait(1.0); continue end

                task.wait(0.8)
                if cancelBoss() then bossFail(); continue end

                local MAX_RETRY = 8
                local foundUI   = false

                for attempt = 1, MAX_RETRY do
                    if cancelBoss() then break end
                    if not isBossEventActive() then break end

                    if detectBossFightUI() then
                        foundUI = true; break
                    end

                    local entering = Workspace:FindFirstChild("BossFight_Entering")
                    local doorPart = entering and entering:FindFirstChild("Demon Forest")

                    if doorPart then
                        tpTarget(doorPart)
                        task.wait(0.5)
                        if cancelBoss() then break end

                        if waitBossFightUI(5.0, cancelBoss) then
                            foundUI = true; break
                        end

                        if attempt < MAX_RETRY then
                            sendDemonTP()
                            local reloaded = waitCharReady("Demon Forest", cancelBoss, 18, 3)
                            if not reloaded or cancelBoss() then break end
                            task.wait(1.2)
                        end
                    else
                        local waitDl = os.clock() + 5.0
                        while os.clock() < waitDl and not cancelBoss() do
                            entering = Workspace:FindFirstChild("BossFight_Entering")
                            if entering and entering:FindFirstChild("Demon Forest") then break end
                            task.wait(0.15)
                        end
                        if cancelBoss() then break end
                        if not (entering and entering:FindFirstChild("Demon Forest")) then
                            sendDemonTP()
                            local reloaded = waitCharReady("Demon Forest", cancelBoss, 18, 3)
                            if not reloaded or cancelBoss() then break end
                            task.wait(1.0)
                        end
                    end
                end

                if not foundUI or cancelBoss() then
                    bossFail(); task.wait(1.0); continue
                end

                -- [FIX] รอให้ Boss Fight scene โหลดสมบูรณ์ก่อนเริ่ม combat
                -- ป้องกัน "เข้า UI แล้วแต่ยังไม่ spawn mob" และ "วาปไว"
                clearBossConn()
                task.wait(2.5)
                if cancelBoss() then bossFail(); continue end

                -- ต้องยังอยู่ใน BossFight UI
                if not detectBossFightUI() then
                    bossFail(); task.wait(1.0); continue
                end

                local cBoss, cBossPart = nil, nil
                local spawnDl = os.clock() + 15
                while os.clock() < spawnDl do
                    if cancelBoss() then break end
                    cBoss, cBossPart = getBossMobInStage()
                    if cBoss then break end
                    task.wait(0.10)
                end

                if not cBoss or cancelBoss() then
                    bossFail(); task.wait(1.0); continue
                end

                if cBossPart then tpDirect(cBossPart, true, true) end
                task.wait(0.4)

                local fighting = true
                clearBossConn()
                Conns.boss = RunService.Heartbeat:Connect(function()
                    if not fighting or not getgenv().autoBoss or getgenv().doRift then return end
                    sendAtk()
                    if cBoss and (not cBoss.Parent or not isMobAlive(cBoss)) then
                        cBoss = nil; cBossPart = nil
                    end
                    if not cBoss then
                        lastTgtUp = 0
                        for _,m in next,getSTgts() do
                            if m.Name:sub(1,9)=="BossFight" and isMobAlive(m) then
                                cBoss=m
                                cBossPart=m.PrimaryPart or m:FindFirstChild("HumanoidRootPart")
                                break
                            end
                        end
                    end
                    if cBoss and cBossPart then
                        local hrp = getHRP(); if not hrp then return end
                        local mPos = cBossPart.Position
                        local d    = hrp.Position - mPos
                        if dpsActive then
                            hrp.CFrame = CFrame.new(mPos); reqAttack(cBoss)
                        else
                            if d.X*d.X + d.Y*d.Y + d.Z*d.Z > Const.ATK_D_SQ then
                                tpInstant(CFrame.new(mPos + d.Unit * (-3)))
                            else
                                reqAttack(cBoss)
                            end
                        end
                    end
                end)

                local bossDl = os.clock() + 300
                while fighting and getgenv().autoBoss and os.clock() < bossDl do
                    if getgenv().doRift then fighting = false; break end
                    lastTgtUp = 0
                    local alive = false
                    for _,m in next,getSTgts() do
                        if m.Name:sub(1,9)=="BossFight" and isMobAlive(m) then
                            alive = true; break
                        end
                    end
                    if not alive then
                        getgenv().lastBossKill = os.clock()
                        fighting = false; break
                    end
                    task.wait(0.10)
                end

                fighting = false
                clearBossConn()
                getgenv().doBoss      = false
                getgenv().bossWaiting = false
                if summonPaused and summonPauseReason == "boss" then
                    summonPaused = false; summonPauseReason = nil
                end

                -- [FIX] รอให้ reward drop ก่อนกลับ Lobby
                -- ป้องกันวาปออกก่อนได้ของ
                if getgenv().autoBoss and not getgenv().doRift then
                    task.wait(4.5)
                    waitReady("Lobby", 10, teleportBuffers["Lobby"], 2, riftCancel)
                end
            end

            getgenv().bossWaiting = false
        end)
    end
})

