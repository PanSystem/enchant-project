        end
        task.spawn(function()
            local cRiftMob  = nil
            local cRiftPart = nil
            local inRift    = false
            local lastRiftEnd = 0  -- [FIX RIFT] cooldown หลังจบ

            -- ── combat connection ────────────────────────────────────
            local function startRiftCombat()
                if Conns.rift then return end
                Conns.rift = RunService.Heartbeat:Connect(function()
                    if not autoRiftRun or not getgenv().autoRift then return end
                    sendAtk(); sendClk()

                    if cRiftMob and (not cRiftMob.Parent or not isMobAlive(cRiftMob)) then
