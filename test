                local pt=primT()
                if #pt>0 then
                    getgenv().rollingPhase="PRIMARY"
                    rollSlotUntilDone(fn, "Primary", pt, run)
                end

                getgenv().rollingPhase=""; getgenv().traitsDoneSet[fn]=true
                if getgenv().autoTalRun then
                    local wdl=os.clock()+600
                    while run() and getgenv().autoTalRun and not getgenv().talentsDoneSet[fn] and os.clock()<wdl do
                        task.wait(0.05)
