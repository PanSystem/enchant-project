-- [ Smart Collect Boxes: การันตี 100% ]
-- ==========================================
local function collectBoxes(othersFolder)
    if not othersFolder then return end
    
    local rewardsFolder = nil
    -- รอให้โฟลเดอร์ Rewards โผล่ออกมาก่อน (เซิร์ฟเสกช้า)
    SmartWait(function()
        rewardsFolder = othersFolder:FindFirstChild("Rewards", true)
        return rewardsFolder ~= nil and #rewardsFolder:GetChildren() > 0
    end, 15.0)

    if not rewardsFolder then return end
    
    -- รอให้กล่องขึ้น Prompt ให้เก็บได้ชัวร์ๆ
    SmartWait(function()
        for _, box in ipairs(rewardsFolder:GetChildren()) do
            local prm = box:FindFirstChildOfClass("ProximityPrompt", true)
            if prm and prm.Enabled then return true end
        end
        return false
    end, 10.0)

    local collectDl = os.clock() + 15.0
    while os.clock() < collectDl do
        local boxes = rewardsFolder:GetChildren()
        if #boxes == 0 then break end

        local anyActive = false
        for _, box in ipairs(boxes) do
            local prm = box:FindFirstChildOfClass("ProximityPrompt", true)
            if not prm or not prm.Enabled then continue end
            anyActive = true
            
            local part = box.PrimaryPart or box:FindFirstChildWhichIsA("BasePart")
            if not part and prm.Parent and prm.Parent:IsA("BasePart") then part = prm.Parent end
            if not part then continue end

            local destPos = part.Position + Vector3.new(0, 1.5, 0)
            local pHRP = LP.Character and (LP.Character:FindFirstChild("HumanoidRootPart") or LP.Character:FindFirstChild("Torso"))
            if pHRP then
                pHRP.CFrame = CFrame.new(destPos)
                pHRP.AssemblyLinearVelocity = Vector3.zero
            end

            pcall(function() fireproximityprompt(prm, 1, true) end)
            task.wait(0.1)
        end
        if not anyActive then break end
        task.wait(0.1)
    end
end

