end

local function bossFail()
    clearBossConn()
    getgenv().doBoss      = false
    getgenv().bossWaiting = false
    State.bossActive      = false
    if summonPaused and summonPauseReason == "boss" then
        summonPaused = false; summonPauseReason = nil
    end
end

local function isBossReady()
    return isBossEventActive()
        and not State.riftActive
        and not State.riftSettling
        and (os.clock() - (getgenv().lastBossKill or 0) >= 25)
end

local function waitUntilBackAtLobby(cancelFn)
    local buf  = teleportBuffers["Lobby"]
    local dl   = os.clock() + 45
    local last = -99
    while os.clock() < dl do
        if cancelFn and cancelFn() then return false end
        -- If rift appears, abort immediately
        if State.riftActive then return false end

        lastStgUp = 0
        if getStg() == "Lobby" then
            local char = lp.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hum.Health > 0 and hrp.Position.Y > -50 then
                task.wait(0.3); lastStgUp = 0
                if getStg() == "Lobby" then
                    char = lp.Character
                    hrp  = char and char:FindFirstChild("HumanoidRootPart")
                    hum  = char and char:FindFirstChildOfClass("Humanoid")
                    if hrp and hum and hum.Health > 0 then return true end
                end
            end
        end

        local now = os.clock()
        if now - last >= 1.5 then
            if buf then R.Byte:FireServer(buf) end
            lastStgUp = 0; last = now
        end
        task.wait(0.08)
    end
    return false
end

