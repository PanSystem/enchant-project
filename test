local function normalizeMultiVal(v)
    if type(v) ~= "table" then return {} end
    if v[1] ~= nil or next(v) == nil then return v end
    local arr = {}
    for label, val in next, v do
        if type(label) == "string" and val then arr[#arr+1] = label end
    end
    table.sort(arr)
    return arr
end

