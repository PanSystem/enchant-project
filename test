    _unitCacheValid = true
end
local function _invalidUC() _unitCacheValid = false end

-- DPS request rate — ultra-low for maximum speed
local DPS_REQ_RATE = 0.003
local SNAP_SQ      = 64   -- 8 studs squared, tighter snap

local DS2 = {
    hb=nil, aaConn=nil, aaHB=nil, lastAA=0,
    lastNoFire=0, lastEQ=0,
    scanFn=nil, mob=nil, part=nil,
    scanTick=0, chkTick=0,
