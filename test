-- riftHasPortal: เช็คว่ามี ProximityPrompt จริงๆ ใน SpawnedRifts
-- (portal ที่ยังไม่ได้เข้า หรือ portal ออก)
local function riftHasPortal()
    local function scanForPrompt(folder)
        if not folder or not folder.Parent then return false end
        for _, child in ipairs(folder:GetChildren()) do
            for _, v in ipairs(child:GetDescendants()) do
                if v:IsA("ProximityPrompt") and v.Enabled then return true end
            end
            -- ตรวจ child เองด้วย
            for _, v in ipairs(child:GetChildren()) do
                if v:IsA("ProximityPrompt") and v.Enabled then return true end
            end
        end
        return false
    end
    local maps = Workspace:FindFirstChild("Maps")
    local rs   = maps and maps:FindFirstChild("Reaper Society")
    if rs then
        local sr = rs:FindFirstChild("SpawnedRifts")
        if sr and scanForPrompt(sr) then return true end
    end
    local d = Workspace:FindFirstChild("SpawnedRifts")
    if d and scanForPrompt(d) then return true end
    return false
end

-- riftContainerExists: ใช้แค่ backup หลัง TP เท่านั้น (ไม่ใช้ trigger)
local function riftContainerExists()
    local maps = Workspace:FindFirstChild("Maps")
    local rs   = maps and maps:FindFirstChild("Reaper Society")
    if rs then
        local sr = rs:FindFirstChild("SpawnedRifts")
        if sr and #sr:GetChildren()>0 then return true end
    end
    local d = Workspace:FindFirstChild("SpawnedRifts")
    if d and #d:GetChildren()>0 then return true end
    return false
end

-- riftExistsStrict: trigger TP เฉพาะเมื่อมี mob หรือ portal จริงๆ
-- ไม่นับ container เปล่า / text notification
local function riftExistsStrict()
    if os.clock() < riftCooldownUntil then return false end  -- cooldown หลัง rift จบ
    if riftHasLiveMobs() then return true end
    if riftHasPortal()   then return true end
    return false
end

-- riftExists: ใช้ post-TP verify เท่านั้น (กว้างกว่า strict)
local function riftExists()
    if os.clock() < riftCooldownUntil then return false end
    if riftHasLiveMobs()     then return true end
    if riftHasPortal()       then return true end
    if riftContainerExists() then return true end
    return false
end

local function findRiftPortalEntry()
    if not RaidsVisual then return nil, nil end
    for _, f in next, RaidsVisual:GetChildren() do
        if f.Name:sub(1, 20) == "Reaper Society_Rift_" then
            local cfg = f:FindFirstChild("Configs")
            local oth = cfg and cfg:FindFirstChild("Others")
            local por = oth and oth:FindFirstChild("Portal")
            local trv = por and por:FindFirstChild("Travel")
            if trv then
                local prm = trv:FindFirstChildWhichIsA("ProximityPrompt")
                if not prm then
                    for _, v in next, trv:GetDescendants() do
                        if v:IsA("ProximityPrompt") then prm = v; break end
                    end
                end
                local part = nil
                if trv:IsA("BasePart") then
                    part = trv
                elseif trv:IsA("Model") then
                    part = trv.PrimaryPart or trv:FindFirstChildWhichIsA("BasePart")
                else
                    part = trv:FindFirstChildWhichIsA("BasePart")
                end
                if not part and prm then
                    local pp = prm.Parent
                    if pp and pp:IsA("BasePart") then part = pp
                    elseif pp then part = pp:FindFirstChildWhichIsA("BasePart") end
                end
                if prm then return prm, part end
            end
        end
    end
    return nil, nil
end

local function exitRiftViaPortal(cancelFn)
    local LEASH_SQ  = 5 * 5
    local deadline  = os.clock() + 35
    local lastCheck = 0

    while os.clock() < deadline do
        if cancelFn and cancelFn() then return false end

        local now = os.clock()
        if now - lastCheck >= 0.12 then
            lastCheck = now; lastStgUp = 0
            if getStg() == "Lobby" then
                task.wait(0.12); lastStgUp = 0
                if getStg() == "Lobby" then return true end
            end
        end

        local prm, part = findRiftPortalEntry()
        if prm and prm.Parent and prm.Enabled then
            if part and part.Parent then
                local hrp = getHRP()
                if hrp then
                    local dv = hrp.Position - part.Position
                    if dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z > LEASH_SQ then
                        killVelocity(hrp)
                        hrp.CFrame = CFrame.new(part.Position + Vector3.new(0, 2, 0))
                        task.wait(0.05)
                    end
                end
            end
            firePrompt(prm)
            task.wait(0.06)
        else
            task.wait(0.15)
        end
    end

    return tpToLobbyConfirmed()
end

local function getRiftPromptsWithPos()
    local list,seen={},{}
    local function scanFolder(folder)
        if not folder then return end
        for _,m in next,folder:GetChildren() do
            for _,d in next,m:GetDescendants() do
                if d:IsA("ProximityPrompt") and d.Enabled and not seen[d] then
                    seen[d]=true
                    local posPart = d.Parent and (
                        (d.Parent:IsA("BasePart") and d.Parent) or
                        (d.Parent:IsA("Model") and (d.Parent.PrimaryPart or d.Parent:FindFirstChildWhichIsA("BasePart")))
                    ) or nil
                    local pos = posPart and posPart.Position or nil
                    if not pos and d.Parent and d.Parent.Parent then
                        local gp = d.Parent.Parent
                        local pp = gp:IsA("Model") and (gp.PrimaryPart or gp:FindFirstChildWhichIsA("BasePart"))
                        pos = pp and pp.Position or nil
                    end
                    list[#list+1] = {prompt=d, pos=pos}
                end
            end
        end
    end
    local maps = Workspace:FindFirstChild("Maps")
    local rs   = maps and maps:FindFirstChild("Reaper Society")
    if rs and rs:FindFirstChild("SpawnedRifts") then scanFolder(rs.SpawnedRifts) end
    if Workspace:FindFirstChild("SpawnedRifts") then scanFolder(Workspace.SpawnedRifts) end
    return list
end

local function tpToRiftStage(cancelFn)
    R.Byte:FireServer(teleportBuffers["Reaper Society"])
    lastStgUp = 0

    local deadline  = os.clock() + 28
    local lastSend  = os.clock()
    local RETRY_IV  = 0.9
    local confirms  = 0
    local NEED_CONF = 3

    while os.clock() < deadline do
        if cancelFn and cancelFn() then return false end
        task.wait(0.07)
        lastStgUp = 0

        if getStg() == "Reaper Society" then
            local char = lp.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hrp.Position.Y > -50 and hum.Health > 0 then
                confirms = confirms + 1
                if confirms >= NEED_CONF then return true end
                task.wait(0.15); continue
            end
        end
        confirms = 0

        local now = os.clock()
        if now - lastSend >= RETRY_IV then
            R.Byte:FireServer(teleportBuffers["Reaper Society"])
            lastSend = now
        end
    end
    return false
end

local function tpToLobbyConfirmed()
    lastStgUp = 0
    if getStg() == "Lobby" then
        task.wait(0.12); lastStgUp = 0
        if getStg() == "Lobby" then return true end
    end
    local deadline = os.clock() + 18; local lastSend = -99
    while os.clock() < deadline do
        local now = os.clock()
        if now - lastSend >= 1.5 then
            R.Byte:FireServer(teleportBuffers["Lobby"]); lastSend = now
        end
        task.wait(0.10); lastStgUp = 0
        if getStg() == "Lobby" then
            task.wait(0.12); lastStgUp = 0
            if getStg() == "Lobby" then return true end
        end
    end
    return false
end

Tabs.Gen:Toggle({
    Title="Auto Rift", Flag="AutoRift", Value=false,
    Callback=function(state)
        getgenv().autoRift=state; autoRiftRun=state
        if not state then
            getgenv().doRift=false; resetRiftDetection()
            if Conns.rift then Conns.rift:Disconnect(); Conns.rift=nil end
            if summonPaused and summonPauseReason=="rift" then summonPaused=false; summonPauseReason=nil end
