                            task.wait(0.4); lastTgtUp = 0
                            if not riftHasLiveMobs() then break end
                        end
                    end
                    stopRiftCombat()
                end

                -- ── EXIT PHASE ───────────────────────────────────────
                doExitRift()

                -- [FIX RIFT] หน่วงก่อน loop ใหม่ (cooldown set ใน doExitRift แล้ว)
                -- ไม่ต้องหน่วงเพิ่ม เพราะ lastRiftEnd = os.clock() ใน doExitRift
            end

            -- cleanup เมื่อปิด Auto Rift
            if riftSignalConn then pcall(function() riftSignalConn:Disconnect() end) end
            stopRiftCombat()
            if inRift then doExitRift() end
            getgenv().doRift = false
            if summonPaused and summonPauseReason=="rift" then
                summonPaused=false; summonPauseReason=nil
            end
        end)
