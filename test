    end
})

local DS2 = {
    hb=nil, aaConn=nil, aaHB=nil, lastAA=0,
    conns={}, desc={}, folder={},
    debs={}, unitCount=0,
    eqState=0, eqNext=0,
    -- [FIX DPS] แยก hitCount เพื่อ track ว่า unit ใดตีแล้วบ้าง
    hitThisCycle = 0,
    allHitFlag=false,
    scanFn=nil, mob=nil, part=nil,
