                -- ── หลัง TP: verify ว่า rift ยังอยู่จริง (max 6s) ────────
                -- ถ้าไม่เจอ evidence → false alarm, กลับ Lobby
                local verifyDl = os.clock() + 6.0
                local verified = false
                while os.clock() < verifyDl and autoRiftRun do
                    task.wait(0.3); lastTgtUp = 0
                    if riftHasLiveMobs() then verified = true; break end
                    if riftHasPortal()   then verified = true; break end
