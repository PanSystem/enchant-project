                    local d=hrp.Position-cP.Position
                    local dsq=d.X*d.X+d.Y*d.Y+d.Z*d.Z
                    if dsq > Const.ATK_D_SQ then cT=nil; cP=nil; return end
                    reqAttack(cT)
                end
                return
            end
        end
        local now=os.clock()
        if now-lastScan<0.03 then return end
        lastScan=now; cT,cP=getScanFn()
    end)
end

