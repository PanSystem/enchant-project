            -- trigger เมื่อ tl > 0 AND tl <= 15
            -- ========================================================
            local riftSignalFired = false
            local riftSignalConn  = nil

            -- เชื่อมต่อ signal ก่อน loop
            pcall(function()
                riftSignalConn = RiftTimeLeft:GetPropertyChangedSignal("Value"):Connect(function()
                    if not autoRiftRun or not getgenv().autoRift then return end
                    if inRift then return end  -- กำลังทำ Rift อยู่แล้ว ข้ามไป
