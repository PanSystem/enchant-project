        if not state then return end
        task.spawn(function()
            local queue={}
            for _,e in ipairs(getgenv().unitQueue) do queue[#queue+1]=e end
            if #queue==0 then getgenv().autoSTRun=false; return end
            local pool=normalizeMultiVal(getgenv().selComboT)
            if #pool<2 then getgenv().autoSTRun=false; return end
            for _,e in ipairs(queue) do getgenv().stDoneSet[e.fn]=nil end
            local function run() return getgenv().autoSTRun end

            local function buildSet()
                local p2=normalizeMultiVal(getgenv().selComboT); local cSet,cArr={},{}
                for _,lbl in ipairs(p2) do
                    local g=trD2G[lbl]; if g and not cSet[g] then cSet[g]=true; cArr[#cArr+1]=g end
                end
                return cSet,cArr
            end
            local function getRaw(fn2,slot)
                local ff=getUF_fn(fn2); local to=ff and ff:FindFirstChild(slot.."_Trait")
                return (to and to:IsA("StringValue")) and to.Value or nil
            end

            for _,entry in ipairs(queue) do
                if not run() then break end
                local fn=entry.fn; getgenv().rollingFn=fn
                local f=getUF_fn(fn)
                if not f or f.Name~=fn then
                    getgenv().stDoneSet[fn]=true; getgenv().traitsDoneSet[fn]=true; continue
                end
                local cSet,cArr=buildSet()
                local distinct=0; for _ in next,cSet do distinct=distinct+1 end
                if distinct<2 then
                    getgenv().stDoneSet[fn]=true; getgenv().traitsDoneSet[fn]=true; continue
                end

                local function isDone()
                    return smartComboDone(fn, normalizeMultiVal(getgenv().selComboT))
                end

                while run() and not isDone() do
                    cSet,cArr=buildSet(); distinct=0; for _ in next,cSet do distinct=distinct+1 end
                    if distinct<2 then break end

                    getgenv().rollingPhase="SUB"
                    while run() do
                        local sub=getRaw(fn,"Sub")
                        if sub and cSet[sub] then break end
                        f=getUF_fn(fn); if not f or f.Name~=fn then break end
                        local to=f:FindFirstChild("Sub_Trait")
                        if not to or not to:IsA("StringValue") then break end
                        local old=to.Value
                        R.Traits:FireServer(fn,"Sub",cArr,false)
                        waitTraitChange(fn,"Sub",old,run,1.5)
                    end
                    if not run() then break end

                    local lockedSub=getRaw(fn,"Sub")
                    if not lockedSub or not cSet[lockedSub] then RunService.Heartbeat:Wait(); continue end

                    local exArr={}
                    for g in next,cSet do if g~=lockedSub then exArr[#exArr+1]=g end end
                    if #exArr==0 then break end

