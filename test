local function sTN(r)
    if not r or r=="None" or r=="" then return "—" end
    local b,n=r:match("^(.-)_(%d+)$")
    if b and n then local rm={"I","II","III","IV","V"}; return b.." "..(rm[tonumber(n)] or n) end
    return r
end

function uUI()
