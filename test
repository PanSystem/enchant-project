-- REQUEST / ATTACK SYSTEM (RATE-LIMITED)
-- ==========================================
local pendingRequests = {}

local function reqAttack(mob)
    if not mob or not mob.Parent then return end
    local h = mobHumCache[mob]
    if h == nil then
        h = mob:FindFirstChildOfClass("Humanoid")
        mobHumCache[mob] = h or false
    end
    if not h or h.Health <= 0 then
        mobHumCache[mob]     = false
        mobNameCache[mob]    = nil
        mobDisplayCache[mob] = nil
        pendingRequests[mob] = nil
        return
    end
    if isLocked(mob) then pendingRequests[mob] = nil; return end

    local mobName = mobNameCache[mob]
    if not mobName then mobName = getValidMobName(mob) end
    if type(mobName) ~= "string" or mobName == "" or mobName == "nil" then
        mobNameCache[mob] = nil; return
    end

    if dpsActive then
        local now = os.clock()
        local last = pendingRequests[mob]
        if last and (now - last < 0.04) then return end
        pendingRequests[mob] = now
        R.Req:FireServer(mobName, "Mouse")
        return
    end

    local now  = os.clock()
    local last = pendingRequests[mob]
    if last and (now - last < Const.REQ_RATE) then return end
    R.Req:FireServer(mobName, "Mouse")
    pendingRequests[mob] = now
end

local _pendingCleanKeys = {}
local _pendingCleanIdx  = 0
RunService.Heartbeat:Connect(function()
    _pendingCleanIdx = _pendingCleanIdx + 1
    if _pendingCleanIdx % 150 == 0 then
        _pendingCleanKeys = {}
        for mob in next, pendingRequests do _pendingCleanKeys[#_pendingCleanKeys+1] = mob end
    end
    if #_pendingCleanKeys == 0 then return end
    local idx = (_pendingCleanIdx % #_pendingCleanKeys) + 1
    local mob = _pendingCleanKeys[idx]
    if mob then
        local h = mobHumCache[mob]
        if not mob.Parent or (h and h.Health <= 0) or not isMobAlive(mob) then
            mobHumCache[mob]     = nil
            mobNameCache[mob]    = nil
            mobDisplayCache[mob] = nil
            pendingRequests[mob] = nil
        end
    end
end)

