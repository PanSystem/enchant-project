                end

                -- [FIX RIFT] รอมอน spawn — ใช้ signal ChildAdded + poll fallback
                local mobSpawnSignal = false
                local mobSpawnConn   = nil
                pcall(function()
                    mobSpawnConn = ServerTargets.ChildAdded:Connect(function(child)
                        if child.Name:sub(1,5) == "Rifts" then mobSpawnSignal = true end
                    end)
                end)

                local mobWaitDl = os.clock() + 25  -- รอสูงสุด 25s
                while os.clock() < mobWaitDl and autoRiftRun do
                    lastTgtUp = 0
                    if riftHasLiveMobs() or mobSpawnSignal then break end
                    task.wait(0.15)
                end
                if mobSpawnConn then pcall(function() mobSpawnConn:Disconnect() end) end
                mobSpawnSignal = false

                -- double-confirm มอนมีจริง
                lastTgtUp = 0; task.wait(0.1)

                -- ── COMBAT PHASE ─────────────────────────────────────
                if riftHasLiveMobs() then
                    -- snap ไปหามอนก่อนเลย
                    local _, np = findNearestRiftMob()
                    if np then
                        local hrpNow = getHRP()
                        if hrpNow then
                            killVelocity(hrpNow)
                            hrpNow.CFrame = CFrame.new(np.Position)
                        end
