Tabs.Sum:Toggle({
    Title="Auto Summon Egg", Flag="AutoSummon", Value=false,
    Callback=function(state)
        getgenv().autoSummon = state
        anyEggRef = nil; anyEggInitialized = false
        if not state then pcall(sendHatchStop); return end
        task.spawn(function()
            local function cancelCheck() return not getgenv().autoSummon end
            local function isBlocked()   return isBusy() or summonPaused end

            local function tpToEggMap(targetMap)
                lastStgUp = 0
                if getStg() == targetMap then
                    local char = lp.Character
                    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                    local hum  = char and char:FindFirstChildOfClass("Humanoid")
                    if hrp and hum and hrp.Position.Y > -50 and hum.Health > 0 then return true end
                end
                local buf = teleportBuffers[targetMap]; if not buf then return false end
                local deadline = os.clock() + 30
                local lastSend = -99; local interval = 0.8; local confirms = 0
                while os.clock() < deadline do
                    if cancelCheck() then return false end
                    if isBlocked() then task.wait(0.4); continue end
                    local now = os.clock()
                    if now - lastSend >= interval then
                        R.Byte:FireServer(buf); lastSend = now; interval = math.min(interval * 1.4, 4.0)
                    end
                    task.wait(0.08); lastStgUp = 0
                    if getStg() == targetMap then
                        local char = lp.Character
                        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                        local hum  = char and char:FindFirstChildOfClass("Humanoid")
                        if hrp and hum and hrp.Position.Y > -50 and hum.Health > 0 then
                            confirms = confirms + 1
                            if confirms >= 2 then return true end
                            task.wait(0.10); continue
                        end
                    end
                    confirms = 0
                end
                return false
            end

            local function goToNearestEgg(targetMap)
                if not SummonersFolder or not SummonersFolder.Parent then
                    SummonersFolder = Workspace:FindFirstChild("Summoners")
                    if not SummonersFolder then return false end
                end
                local eggModel = findNearestEggModel(targetMap)
                if not eggModel then return false end
                return snapToEggModel(eggModel)
            end

            while getgenv().autoSummon do
                if cancelCheck() then break end
                if not waitUntilAlive(cancelCheck, 20) then break end
                if cancelCheck() then break end
                if isBlocked() then
                    pcall(sendHatchStop)
                    while getgenv().autoSummon and isBlocked() do task.wait(0.3) end
                    if cancelCheck() then break end
                end
                local targetMap = getgenv().selSumm or "Namex Planet"
                lastStgUp = 0
                if getStg() ~= targetMap then
                    pcall(sendHatchStop)
                    local ok = tpToEggMap(targetMap)
                    if cancelCheck() then break end
                    if not ok then task.wait(2.0); continue end
                    task.wait(0.3)
                end
                if cancelCheck() then break end
                if isBlocked() then pcall(sendHatchStop); continue end
                local eggFound = goToNearestEgg(targetMap)
                if not eggFound then task.wait(0.5); continue end
                if cancelCheck() then break end
                sendHatchStart()
                local _hatchKeepLast = os.clock()
                local _distCheckLast = os.clock()
                local cachedEgg      = findNearestEggModel(targetMap)
                while getgenv().autoSummon do
                    task.wait(0.12)
                    if cancelCheck() then break end
                    if isBlocked() then pcall(sendHatchStop); break end
                    lastStgUp = 0
                    if getStg() ~= targetMap then pcall(sendHatchStop); break end
                    local now = os.clock()
                    if now - _hatchKeepLast >= 3.0 then
                        _hatchKeepLast = now; sendHatchStart()
                    end
                    if now - _distCheckLast >= 0.5 then
                        _distCheckLast = now
                        if not cachedEgg or not cachedEgg.Parent then
                            cachedEgg = findNearestEggModel(targetMap)
                        end
                        if cachedEgg and isfarFromEgg(cachedEgg) then snapToEggModel(cachedEgg) end
                    end
                end
            end
            pcall(sendHatchStop)
        end)
    end
})

