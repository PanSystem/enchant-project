        if not state then dpsCleanup(); return end

        dpsActive = true
        DS2.hitCounter=0; DS2.burstPending=0; DS2.lastBurst=0; DS2.lastNoFire=0
        DS2.debs={}; DS2.unitCount=0
        safeBoostUntil = 0

        -- Pre-burst seeding: 6×2 = 12 packets
        for _ = 1, 6 do
            pcall(function() R.Byte:FireServer(DPS_EQ) end)
            pcall(function() R.Byte:FireServer(DPS_EQ) end)
        end
        startAAKeepalive()
        startMasterHB()

        task.spawn(function()
            if not dpsActive then return end

            local unitsRoot = WorldsFolder:FindFirstChild("Units")
                           or WorldsFolder:WaitForChild("Units", 10)
            if not unitsRoot or not dpsActive then dpsCleanup(); return end

            local srvRoot = unitsRoot:FindFirstChild("Server")
                         or unitsRoot:WaitForChild("Server", 10)
            if not srvRoot or not dpsActive then dpsCleanup(); return end

            local plrFolder = srvRoot:FindFirstChild(myName)
                           or srvRoot:WaitForChild(myName, 15)
            if not plrFolder or not dpsActive then dpsCleanup(); return end

            unitServerFolder = plrFolder

            for _, u in next, plrFolder:GetChildren() do
                if not dpsActive then return end
                wireUnit(u)
            end
            if not dpsActive then return end

            -- Re-burst หลัง wire: 2 bursts
            task.wait(0.02)
            if dpsActive then triggerBurst() end
            task.wait(0.01)
            if dpsActive then triggerBurst() end

            local connAdded = plrFolder.ChildAdded:Connect(function(u)
                if dpsActive then wireUnit(u) end
            end)
            local connRemoved = plrFolder.ChildRemoved:Connect(function(u)
                unwireUnit(u.Name)
            end)
            if not dpsActive then
                pcall(function() connAdded:Disconnect() end)
                pcall(function() connRemoved:Disconnect() end)
                return
            end
            table.insert(DS2.folder, connAdded)
            table.insert(DS2.folder, connRemoved)

            if getgenv().autoNearest then
                DS2.scanFn = function() return getNearestMobUniversal(math.huge) end
            elseif getgenv().autoSel then
                DS2.scanFn = function() return findSelectedMob() end
            end
        end)
    end
})

