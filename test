local function getAABool() return MyData:FindFirstChild("Auto_Attacks") end
local function isAAOn()    local v=getAABool(); return v~=nil and v.Value==true end
local function doAAOn()    R.Byte:FireServer(AA_ON); DS.lastAA=os.clock() end
local function doAAOff()   R.Byte:FireServer(AA_OFF) end

local function wireAA(av)
    if DS.aaConn then pcall(function() DS.aaConn:Disconnect() end) end
    DS.aaConn = av:GetPropertyChangedSignal("Value"):Connect(function()
        if not dpsActive or av.Value then return end
        if dpsActive and not isAAOn() then doAAOn() end
    end)
end

local function startAAKeepalive()
    doAAOn()
    local av = getAABool()
    if av then wireAA(av)
    else
        task.spawn(function()
            local dl = os.clock() + 30
            while os.clock() < dl and dpsActive do
                av = getAABool()
                if av then wireAA(av); break end
                task.wait(0.3)
            end
        end)
    end
    DS.aaHB = RunService.Heartbeat:Connect(function()
        if not dpsActive then return end
        local now = os.clock()
        if now - DS.lastAA < 0.5 then return end
        if not isAAOn() then doAAOn() else DS.lastAA = now end
    end)
end

local function stopAAKeepalive()
    if DS.aaConn then pcall(function() DS.aaConn:Disconnect() end); DS.aaConn=nil end
    if DS.aaHB   then pcall(function() DS.aaHB:Disconnect()   end); DS.aaHB=nil   end
    doAAOff()
end

local function allUnitsHit()
    if DS.unitCount == 0 then return false end
    for _, deb in next, DS.debs do
        if not deb.Value then return false end
    end
    return true
end

local DPS_REQ_RATE_HB = 0.015
local SNAP_SQ         = Const.SNAP_D_SQ

local function startMasterHB()
    if DS.hb then DS.hb:Disconnect() end
    DS.hb = RunService.Heartbeat:Connect(function()
        if not dpsActive then return end
        local now = os.clock()

        if now - _lastAtk >= Const.ATK_RATE then
            _lastAtk = now; R.Byte:FireServer(unpack(attackArgs))
        end
        if now - _lastClk >= Const.CLK_RATE then
            _lastClk = now; R.Byte:FireServer(unpack(clickArgs))
        end

        local st = DS.eqState

        if st == 0 then
            if now < safeBoostUntil then return end

            local hit = DS.allHitFlag
                     or (DS.unitCount > 0 and allUnitsHit())
                     or (DS.unitCount == 0 and now >= DS.eqNext)

            if hit then
                DS.allHitFlag = false

                if getgenv().safeBoostActive then
                    local dpsObj = lp:FindFirstChild("DPS")
                    if dpsObj and dpsObj.Value >= safeDMGLimit then
                        safeBoostUntil = now + 5.0
                        DS.eqState     = 0
                        DS.allHitFlag  = false
                        return
                    end
                end

                DS.eqState = 1
                DS.eqNext  = now + dpsInputDelay
            end

        elseif st == 1 then
            if now >= DS.eqNext then
                R.Byte:FireServer(DPS_EQ)
                DS.eqState = 0
                DS.eqNext  = now
            end
        end

        if not DS.scanFn then return end

        DS.chkTick = DS.chkTick + 1
        if DS.chkTick % 3 == 0 then
            if DS.mob and (not DS.mob.Parent or not isMobAlive(DS.mob)) then
                DS.mob=nil; DS.part=nil
            end
        end
        DS.scanTick = DS.scanTick + 1
        if not DS.mob and DS.scanTick % 4 == 0 then
            DS.mob, DS.part = DS.scanFn()
        end
        if not DS.mob or not DS.part then return end

        local hrp = getHRP(); if not hrp then return end
        local mPos = DS.part.Position
        local dv   = hrp.Position - mPos
        if dv.X*dv.X + dv.Z*dv.Z > SNAP_SQ then
            hrp.CFrame = CFrame.new(mPos)
        end

        local last = pendingRequests[DS.mob]
        if not last or (now - last >= DPS_REQ_RATE_HB) then
            local mn = mobNameCache[DS.mob]
            if not mn then mn = getValidMobName(DS.mob) end
            if type(mn) == "string" and mn ~= "" and mn ~= "nil" then
                R.Req:FireServer(mn, "Mouse"); pendingRequests[DS.mob] = now
            end
        end
    end)
end

local _autoFireHB = nil
local function startAutoFire()
    if _autoFireHB then return end
