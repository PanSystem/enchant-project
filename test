local function anyTraitsRunning() return getgenv().autoTRun or getgenv().autoSTRun end

local function waitTraitChange(fn, slotKey, oldVal, runFlagFn, timeout)
    local dl = os.clock() + (timeout or 1.5)
    local changed = false; local conn
    local ff = getUF_fn(fn)
    local to = ff and ff:FindFirstChild(slotKey.."_Trait")
    if to and to:IsA("StringValue") then
        pcall(function()
            conn = to:GetPropertyChangedSignal("Value"):Connect(function()
                if to.Value ~= oldVal then changed = true end
            end)
        end)
    end
    while not changed and os.clock() < dl do
        if not runFlagFn() then break end
        local f2 = getUF_fn(fn)
        local t2 = f2 and f2:FindFirstChild(slotKey.."_Trait")
        if t2 and t2:IsA("StringValue") and t2.Value ~= oldVal then changed = true; break end
        task.wait(0.004)
    end
    if conn then pcall(function() conn:Disconnect() end) end
    return changed
end

local function waitTalentChange(fn, stat, oldVal, runFlagFn, timeout)
    local dl = os.clock() + (timeout or 1.5)
    local changed = false; local conn
    local ff = getUF_fn(fn)
    local pa = ff and ff:FindFirstChild("Potentials_Adjustment")
    local sv = pa and pa:FindFirstChild(stat)
    if sv then
        pcall(function()
            conn = sv:GetPropertyChangedSignal("Value"):Connect(function()
                if sv.Value ~= oldVal then changed = true end
            end)
        end)
    end
    while not changed and os.clock() < dl do
        if not runFlagFn() then break end
        local f2  = getUF_fn(fn)
        local pa2 = f2 and f2:FindFirstChild("Potentials_Adjustment")
        local sv2 = pa2 and pa2:FindFirstChild(stat)
        if sv2 and sv2.Value ~= oldVal then changed = true; break end
        task.wait(0.004)
    end
    if conn then pcall(function() conn:Disconnect() end) end
    return changed
end

local function rollSlotUntilDone(fn, slotKey, targetList, runFlagFn)
    local ra = {}
    for _,d in ipairs(targetList) do ra[#ra+1] = trD2G[d] or d end
    while runFlagFn() do
        local f = getUF_fn(fn)
        if not f or f.Name ~= fn then return end
        local to = f:FindFirstChild(slotKey.."_Trait")
        if not to or not to:IsA("StringValue") then return end
        if cTrS_fn(fn, slotKey, targetList) then return end
        local old = to.Value
        R.Traits:FireServer(fn, slotKey, ra, false)
        waitTraitChange(fn, slotKey, old, runFlagFn, 1.5)
    end
end

