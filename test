local RAY_P = RaycastParams.new()
RAY_P.FilterType = Enum.RaycastFilterType.Exclude
local grOff = { Const.V3Z,
    Vector3.new(1,0,0), Vector3.new(-1,0,0),
    Vector3.new(0,0,1), Vector3.new(0,0,-1),
    Vector3.new(0.7,0,0.7),  Vector3.new(-0.7,0,0.7),
    Vector3.new(0.7,0,-0.7), Vector3.new(-0.7,0,-0.7)
}
local lastTP = 0

local function killVelocity(hrp)
    if not hrp or not hrp.Parent then return end
    hrp.AssemblyLinearVelocity  = Const.V3Z
    hrp.AssemblyAngularVelocity = Const.V3Z
end

local function tpPosition(cf, skipCooldown)
    local now = os.clock()
    if not skipCooldown and (now - lastTP < Const.TP_MIN) then return false end
    lastTP = now
    local hrp = getHRP(); if not hrp then return false end
    local pos = cf.Position
    if pos.Y < Const.ANTI_Y then pos = Vector3.new(pos.X, 0, pos.Z) end
    RAY_P.FilterDescendantsInstances = getParts()
    local best, originY, downVec = nil, pos.Y + 20, Vector3.new(0, -400, 0)
    for _, off in ipairs(grOff) do
        local r = Workspace:Raycast(Vector3.new(pos.X+off.X, originY, pos.Z+off.Z), downVec, RAY_P)
        if r and (not best or r.Position.Y > best) then best = r.Position.Y end
    end
    local finalY  = best and math.max(best+2, pos.Y) or math.max(pos.Y, Const.ANTI_Y+10)
    local _, rotY, _ = cf:ToEulerAnglesYXZ()
    local finalCF = CFrame.new(pos.X, finalY, pos.Z) * CFrame.Angles(0, rotY, 0)
    for i = 1, 4 do
        killVelocity(hrp); hrp.CFrame = finalCF
        if (hrp.CFrame.Position - finalCF.Position).Magnitude <= 2.0 then return true end
        if i < 4 then task.wait(0.03) end
    end
    return false
end

local function tpTarget(target)
    if not target then return false end
    local cf
    if target:IsA("Model") then
        local p = target.PrimaryPart or target:FindFirstChild("HumanoidRootPart")
        cf = p and p.CFrame or target:GetPivot()
    elseif target:IsA("BasePart") then cf = target.CFrame
    else
        local p = target:FindFirstChildWhichIsA("BasePart")
        cf = p and p.CFrame
    end
    return cf and tpPosition(cf) or false
end

local function tpDirect(part, skipCooldown, addOffset)
    if not part or not part.Parent then return false end
    local now = os.clock()
    if not skipCooldown and (now - lastTP < Const.TP_MIN) then return false end
    local hrp = getHRP(); if not hrp then return false end
    local mPos = part.Position
    local dv = hrp.Position - mPos
    if dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z <= 100 then return true end
    lastTP = now
    if mPos.Y < Const.ANTI_Y then mPos = Vector3.new(mPos.X, 0, mPos.Z) end
    local offX, offZ = 0, 0
    if addOffset then
        local angle = math.random() * math.pi * 2
        offX = math.cos(angle) * Const.MOB_OFF
        offZ = math.sin(angle) * Const.MOB_OFF
    end
    local finalCF = CFrame.new(mPos.X+offX, mPos.Y, mPos.Z+offZ)
    for i = 1, 4 do
        killVelocity(hrp); hrp.CFrame = finalCF
        if (hrp.CFrame.Position - finalCF.Position).Magnitude <= 2.0 then break end
        if i < 4 then task.wait(0.03) end
    end
    return true
end

local function tpInstant(cf)
    local hrp = getHRP()
    if hrp then killVelocity(hrp); hrp.CFrame = cf end
end

-- ── TP แบบแม่นยำ force snap ────────────────────────────────────────────
local function tpForceSnap(part, yOffset)
    if not part or not part.Parent then return false end
    local hrp = getHRP(); if not hrp then return false end
    yOffset = yOffset or 2
    local targetCF = CFrame.new(part.Position + Vector3.new(0, yOffset, 0))
    for i = 1, 5 do
        killVelocity(hrp)
        hrp.CFrame = targetCF
        task.wait(0.04)
        local diff = (hrp.CFrame.Position - targetCF.Position).Magnitude
        if diff <= 3.0 then return true end
    end
    return (hrp.CFrame.Position - targetCF.Position).Magnitude <= 5.0
end

