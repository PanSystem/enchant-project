local ConfigFileName = "EnchantHub_AdvancedConfig.json"
local AutoLoadFileName = "EnchantHub_AutoLoadState.txt"
local isAutoLoadConfig = false

Tabs.Config:Section({Title = "Configuration Master", Opened = true})

local function GetConfigData()
    return {
        AutoFarm = autoFarmEnabled,
        AutoClick = autoClickEnabled,
        FastReroll = fastRerollEnabled,
        DmgBoost = dmgBoostEnabled,
        SafeBoost = safeDmgBoostEnabled,
        AutoRift = autoRiftEnabled,
        AutoAbandon = autoAbandonVillageEnabled,
        AutoRaid = autoRaidEnabled,
        HideReroll = hideRerollEnabled,
        HideReward = hideRewardEnabled,
        AutoSummon = autoSummonEnabled,
        AutoTraits = autoTraitsEnabled,
        AutoTalents = autoTalentsEnabled,
        FarmMode = farmMode,
        SpeedTween = tostring(tweenSpeed),
        CategoryMode = selectedMonsters,
        DmgBoostCd = tostring(dmgBoostCooldown),
        DmgBoostLim = tostring(safeDpsLimit),
        SelectRaid = selectedRaidMap,
        SelectDiff = selectedRaidDifficulty,
        CollectChest = collectPurpleChest,
        SelectEgg = selectedEgg,
        TargetTraits = targetTraits,
        TargetTalents = targetTalents,
        TargetTalentTier = targetTalentTier
    }
end

local function SaveConfig()
    local data = GetConfigData()
    local json = HttpService:JSONEncode(data)
    writefile(ConfigFileName, json)
    Window:Notify({Title = "Success", Content = "Configuration Saved!", Duration = 3})
end

local function LoadConfig()
    if isfile(ConfigFileName) then
        local success, decoded = pcall(function() return HttpService:JSONDecode(readfile(ConfigFileName)) end)
        if success and type(decoded) == "table" then
            if decoded.AutoFarm ~= nil then UIElements.Toggles.AutoFarm:SetValue(decoded.AutoFarm) end
            if decoded.AutoClick ~= nil then UIElements.Toggles.AutoClick:SetValue(decoded.AutoClick) end
            if decoded.FastReroll ~= nil then UIElements.Toggles.FastReroll:SetValue(decoded.FastReroll) end
            if decoded.DmgBoost ~= nil then UIElements.Toggles.DamageBoost:SetValue(decoded.DmgBoost) end
            if decoded.SafeBoost ~= nil then UIElements.Toggles.SafeBoost:SetValue(decoded.SafeBoost) end
            if decoded.AutoRift ~= nil then UIElements.Toggles.AutoRift:SetValue(decoded.AutoRift) end
            if decoded.AutoAbandon ~= nil then UIElements.Toggles.AutoAbandonVillage:SetValue(decoded.AutoAbandon) end
            if decoded.AutoRaid ~= nil then UIElements.Toggles.AutoRaid:SetValue(decoded.AutoRaid) end
            if decoded.HideReroll ~= nil then UIElements.Toggles.HideReroll:SetValue(decoded.HideReroll) end
            if decoded.HideReward ~= nil then UIElements.Toggles.HideReward:SetValue(decoded.HideReward) end
            if decoded.AutoSummon ~= nil then UIElements.Toggles.AutoSummon:SetValue(decoded.AutoSummon) end
            if decoded.AutoTraits ~= nil then UIElements.Toggles.AutoTraits:SetValue(decoded.AutoTraits) end
            if decoded.AutoTalents ~= nil then UIElements.Toggles.AutoTalents:SetValue(decoded.AutoTalents) end

            if decoded.FarmMode then UIElements.Dropdowns.SecModeFarm:SetValue(decoded.FarmMode) end
            if decoded.SpeedTween then UIElements.Inputs.SpeedTween:SetValue(decoded.SpeedTween) end
            if decoded.CategoryMode then UIElements.Dropdowns.CategoryMode:SetValue(decoded.CategoryMode) end
            if decoded.DmgBoostCd then UIElements.Inputs.DmgBoostCooldown:SetValue(decoded.DmgBoostCd) end
            if decoded.DmgBoostLim then UIElements.Inputs.DmgBoostLimit:SetValue(decoded.DmgBoostLim) end
            if decoded.SelectRaid then UIElements.Dropdowns.SelectRaid:SetValue(decoded.SelectRaid) end
            if decoded.SelectDiff then UIElements.Dropdowns.SelectDifficulty:SetValue(decoded.SelectDiff) end
            if decoded.CollectChest then UIElements.Dropdowns.CollectChest:SetValue(decoded.CollectChest) end
            if decoded.SelectEgg then UIElements.Dropdowns.SelectEgg:SetValue(decoded.SelectEgg) end
            if decoded.TargetTraits then UIElements.Dropdowns.SelectTraits:SetValue(decoded.TargetTraits) end
            if decoded.TargetTalents then UIElements.Dropdowns.SelectTalents:SetValue(decoded.TargetTalents) end
            if decoded.TargetTalentTier then UIElements.Dropdowns.SelectStats:SetValue(decoded.TargetTalentTier) end
            Window:Notify({Title = "Success", Content = "Configuration Loaded!", Duration = 3})
        end
    end
end

Tabs.Config:Button({Title = "Save Config", Callback = function() SaveConfig() end})
Tabs.Config:Button({Title = "Load Config", Callback = function() LoadConfig() end})

if isfile(AutoLoadFileName) then
    local content = readfile(AutoLoadFileName)
    if content == "true" then isAutoLoadConfig = true end
end

Tabs.Config:Toggle({
    Title = "Auto Load Config",
    Value = isAutoLoadConfig,
    Callback = function(s)
        isAutoLoadConfig = s
        writefile(AutoLoadFileName, tostring(s))
    end
})

if isAutoLoadConfig then
    task.spawn(function()
        task.wait(1.5)
        LoadConfig()
    end)
end
