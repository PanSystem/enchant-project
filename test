local function checkAndAttackAllMonsters()
    if not dmgBoostEnabled then return end
    local t = tick()
    if t - lastAttackTime < (dmgBoostCooldown or 0.05) then return end
    
    local myFolder = UnitsServer:FindFirstChild(LP.Name)
    if not myFolder then return end
    
    local hasDebounceTrue = false
    for _, unit in ipairs(myFolder:GetChildren()) do
        local debounce = unit:FindFirstChild("Debounce")
        if debounce and debounce.Value == true then
            hasDebounceTrue = true
            break
        end
    end
    
    if hasDebounceTrue then
        lastAttackTime = t
        pcall(function() ByteNetReq:FireServer(attackBuffer) end)
    end
end

local function setupDamageBoostForUnit(unit)
    if dmgBoostConnections[unit] then return end
    
    local debounce = unit:WaitForChild("Debounce", 1)
    if debounce then
        local conn = debounce:GetPropertyChangedSignal("Value"):Connect(function()
            if dmgBoostEnabled and debounce.Value == true then
                checkAndAttackAllMonsters()
            end
        end)
        dmgBoostConnections[unit] = conn
    end
end

