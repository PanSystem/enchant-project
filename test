        if not dpsActive or DS.unitCount > 0 then return end
        if DS.eqState == 0 then
            local interval = dpsInputDelay * 2.0 + 0.016
            if os.clock() - DS.eqNext > interval then DS.eqNext = 0 end
        end
    end)
end
local function stopAutoFire()
