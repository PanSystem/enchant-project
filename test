    DS.eqState=0; DS.eqNext=0; DS.allHitFlag=false
    DS.mob=nil; DS.part=nil; DS.scanFn=nil
    DS.debs={}; DS.unitCount=0
    safeBoostUntil = 0

    pcall(function() R.Byte:FireServer(DPS_EQ) end)

    stopAutoFire()
    if DS.hb then pcall(function() DS.hb:Disconnect() end); DS.hb=nil end
    stopAAKeepalive()
    for _,c in next, DS.conns  do pcall(function() c:Disconnect() end) end
    for _,c in next, DS.desc   do pcall(function() c:Disconnect() end) end
    for _,c in next, DS.folder do pcall(function() c:Disconnect() end) end
    DS.conns={}; DS.desc={}; DS.folder={}
    stopDPSPrecision()
end
