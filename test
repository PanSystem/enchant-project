                    local exArr={}
                    for g in next,cSet do if g~=lockedSub then exArr[#exArr+1]=g end end
                    if #exArr==0 then break end
                    getgenv().rollingPhase="PRIMARY"
                    while run() do
                        if getRaw(fn,"Sub")~=lockedSub then break end
                        local prim=getRaw(fn,"Primary")
                        if prim and cSet[prim] and prim~=lockedSub then break end
                        f=getUF_fn(fn); if not f or f.Name~=fn then break end
