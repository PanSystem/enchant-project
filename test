-- ── DS2 State ─────────────────────────────────────────────────────────
local DS2 = {
    hb=nil, aaConn=nil, aaHB=nil, lastAA=0,
    conns={}, desc={}, folder={},
    debs={}, unitCount=0,
    hitCounter   = 0,
    burstPending = 0,
