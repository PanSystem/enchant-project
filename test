                end

                -- ── Accumulate consecutive confirms ─────────────────────
                riftConfirmCount = riftConfirmCount + 1
                if riftConfirmCount < RIFT_NEED_CONFIRM then
                    task.wait(0.3)   -- รอแล้ว re-check ในรอบหน้า
                    continue
                end
                -- ผ่าน 5 confirms แล้ว → rift เกิดจริงๆ
                riftConfirmCount = 0

