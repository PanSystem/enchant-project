    local folder = getUnitServerFolder(); if not folder then return 0 end
    local count = 0
    for _, unit in next, folder:GetChildren() do
        local deb = unit:FindFirstChild("Debounce")
        if not deb then
            for _, v in next, unit:GetDescendants() do
                if v.Name=="Debounce" and v:IsA("BoolValue") then deb=v; break end
            end
        end
        if deb and deb:IsA("BoolValue") and deb.Value then count=count+1 end
    end
