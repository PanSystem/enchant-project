-- PRIORITY MANAGER
-- Priority: RIFT (highest) > BOSS > RAID > SUMMON/FARM (lowest)
-- ============================================================
local Priority = {
    NONE  = 0,
    SUMMON= 1,
    FARM  = 2,
    RAID  = 3,
    BOSS  = 4,
    RIFT  = 5,
}

-- Shared state — single source of truth
local State = {
    currentPriority = Priority.NONE,
    riftActive      = false,   -- Rift is being done right now
    riftDetected    = false,   -- Rift model just spawned (signal)
    bossActive      = false,   -- Boss fight in progress
    bossReady       = false,   -- Boss event active and cooldown passed
    raidActive      = false,   -- Inside a raid session
    raidFinishing   = false,   -- Raid in POST_FIGHT / WAIT_EXIT phase
    riftSettling    = false,   -- Short cooldown after rift exits
}

local function setPriority(p) State.currentPriority = p end
local function hasPriority(p) return State.currentPriority <= p end -- true if caller's priority >= current
local function priorityAtLeast(p) return State.currentPriority >= p end

