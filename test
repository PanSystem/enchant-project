local function findNearestRiftMob()
    local hrp=getHRP(); if not hrp then return nil,nil end
    local hPos=hrp.Position; local bestMob,bestPart,bestDistSq=nil,nil,math.huge
    lastTgtUp = 0
    for _,m in next,getSTgts() do
        if m.Name:sub(1,5)=="Rifts" and isMobAlive(m) then
            local pt=m.PrimaryPart or m:FindFirstChild("HumanoidRootPart")
            if pt then
                local d=hPos-pt.Position; local dsq=d.X*d.X+d.Y*d.Y+d.Z*d.Z
                if dsq<bestDistSq then bestDistSq=dsq; bestMob=m; bestPart=pt end
            end
        end
    end
    return bestMob,bestPart
end

local function riftHasLiveMobs()
    lastTgtUp = 0
    for _, m in ipairs(getSTgts()) do
        if m.Name:sub(1,5)=="Rifts" and m.Parent then
            local h = mobHumCache[m]
            if h==nil then h=m:FindFirstChildOfClass("Humanoid"); mobHumCache[m]=h or false end
            if not h or not h.Parent or h.Health<=0 then continue end
            local pp = m.PrimaryPart or m:FindFirstChild("HumanoidRootPart")
            if not pp or not pp.Parent then continue end
            local p = pp.Position
            if p.Y < -200 or (p.X==0 and p.Z==0 and p.Y==0) then continue end
            return true
        end
    end
    return false
end

