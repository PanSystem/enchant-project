local orgNm={dn=nil,un=nil,ti=nil}; local nSEnb=false
local function getLocalOverheads()
    local char=lp.Character; if not char then return nil,nil,nil end
    local head=char:FindFirstChild("Head")
    local oh=(head and head:FindFirstChild("Overheads")) or char:FindFirstChild("Overheads",true)
    if not oh then return nil,nil,nil end
    return oh:FindFirstChild("DisplayNames"),oh:FindFirstChild("Names"),oh:FindFirstChild("Title")
end
local function updateNameSpoof()
    local dn,un,ti=getLocalOverheads()
    if nSEnb then
        if dn and not orgNm.dn then orgNm.dn=dn.Text end
        if un and not orgNm.un then orgNm.un=un.Text end
        if ti and not orgNm.ti then orgNm.ti=ti.Text end
        if dn then dn.Text="Enchant Hub" end; if un then un.Text="Enchant Hub" end
        if ti then ti.Text="Enchant Hub" end
    else
        if dn and orgNm.dn then dn.Text=orgNm.dn end; if un and orgNm.un then un.Text=orgNm.un end
        if ti and orgNm.ti then ti.Text=orgNm.ti end
        orgNm.dn=nil; orgNm.un=nil; orgNm.ti=nil
    end
end
lp.CharacterAdded:Connect(function()
    task.wait(1)
    if nSEnb then orgNm.dn=nil; orgNm.un=nil; orgNm.ti=nil; updateNameSpoof() end
    lastHRPUp=0; lastPartUp=0; lastStgUp=0; lastTgtUp=0
    unitServerFolder=nil; lastUnitFolderCheck=0
end)
Tabs.Misc:Button({Title="Toggle Name Spoofer", Callback=function() nSEnb=not nSEnb; updateNameSpoof() end})

