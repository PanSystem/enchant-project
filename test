            local function primT() return normalizeMultiVal(getgenv().selPrimT or {}) end
            local function run()   return getgenv().autoTRun end
            if #subT()==0 and #primT()==0 then getgenv().autoTRun=false; return end

            for _,entry in ipairs(queue) do
                if not run() then break end
                local fn=entry.fn; getgenv().rollingFn=fn
                local f=getUF_fn(fn)
