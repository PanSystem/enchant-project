end

local function findDebounce(unitInst)
    local d = unitInst:FindFirstChild("Debounce")
    if d and d:IsA("BoolValue") then return d end
    for _, child in next, unitInst:GetChildren() do
        local dd = child:FindFirstChild("Debounce")
        if dd and dd:IsA("BoolValue") then return dd end
    end
    return nil
end

local function wireUnit(unitInst)
    local uName = unitInst.Name
    if DS.debs[uName] then return end

    local deb = findDebounce(unitInst)
    if not deb then
        local dc
        dc = unitInst.DescendantAdded:Connect(function(v)
            if v.Name == "Debounce" and v:IsA("BoolValue") then
                pcall(function() dc:Disconnect() end)
                DS.desc[uName] = nil
                if dpsActive and not DS.debs[uName] then wireUnit(unitInst) end
            end
        end)
        DS.desc[uName] = dc
        return
    end

    DS.debs[uName]  = deb
    DS.unitCount    = DS.unitCount + 1

    local prev = deb.Value
    DS.conns[uName] = deb:GetPropertyChangedSignal("Value"):Connect(function()
        if not dpsActive then return end
        local cur = deb.Value

        if cur and not prev then
            if DS.eqState == 0 and allUnitsHit() then
                DS.allHitFlag = true
            end
        end

        prev = cur
    end)
end

local function unwireUnit(uName)
    local c = DS.conns[uName]; if c then pcall(function() c:Disconnect() end); DS.conns[uName]=nil end
    local d = DS.desc[uName];  if d then pcall(function() d:Disconnect() end); DS.desc[uName]=nil end
    if DS.debs[uName] then DS.debs[uName]=nil; DS.unitCount=math.max(0,DS.unitCount-1) end
end

local function dpsCleanup_impl()
