local function isMobAlive(mob)
    if not mob or not mob.Parent then return false end
    local h = mobHumCache[mob]
    if h == nil then h = mob:FindFirstChildOfClass("Humanoid"); mobHumCache[mob] = h or false end
    if not h then return false end
    return h.Health > 0
end

local function isLocked(mob)
    if not mob or not mob.Parent then return true end
    local saviors = mob:FindFirstChild("Saviors"); if not saviors then return false end
    for _, v in next, saviors:GetChildren() do
        if v:IsA("StringValue") and v.Value:find(myName, 1, true) then return true end
    end
    return false
end

local function getValidMobName(mob)
    if not mob or not mob.Parent then return nil end
    if mobNameCache[mob] then return mobNameCache[mob] end
    local n = mob.Name; local result
    if n:sub(1,5)=="Raids" or n:sub(1,5)=="Rifts" or n:sub(1,9)=="BossFight"
       or ClientTargets:FindFirstChild(n) then
        result = n
    else
        local display = mob:FindFirstChild("Units_Displays")
        local names   = display and display:FindFirstChild("Names")
        if names then
            local dn = names:IsA("TextLabel") and names.Text or names.Value
            if dn and dn ~= "" then
                for _, v in next, getSTgts() do
                    if v ~= mob then
                        local d2  = v:FindFirstChild("Units_Displays")
                        local n2  = d2 and d2:FindFirstChild("Names")
                        local dn2 = n2 and (n2:IsA("TextLabel") and n2.Text or n2.Value)
                        if dn2 == dn then result = v.Name; break end
                    end
                end
            end
        end
        result = result or n
    end
    mobNameCache[mob] = result
    return result
end

local function getMobDisplayName(mob)
    if mobDisplayCache[mob] then return mobDisplayCache[mob] end
    local dp = mob:FindFirstChild("Units_Displays")
    local no = dp and dp:FindFirstChild("Names")
    local mn = no and (no:IsA("TextLabel") and no.Text or no.Value) or nil
    mobDisplayCache[mob] = mn or false
    return mn
end

-- ==========================================
-- REQUEST / ATTACK SYSTEM (RATE-LIMITED)
-- ==========================================
local pendingRequests = {}

local function reqAttack(mob)
    if not mob or not mob.Parent then return end
    local h = mobHumCache[mob]
    if h == nil then
        h = mob:FindFirstChildOfClass("Humanoid")
        mobHumCache[mob] = h or false
    end
    if not h or h.Health <= 0 then
        mobHumCache[mob]     = false
        mobNameCache[mob]    = nil
        mobDisplayCache[mob] = nil
        pendingRequests[mob] = nil
        return
    end
    if isLocked(mob) then pendingRequests[mob] = nil; return end

    local mobName = mobNameCache[mob]
    if not mobName then mobName = getValidMobName(mob) end
    if type(mobName) ~= "string" or mobName == "" or mobName == "nil" then
        mobNameCache[mob] = nil; return
    end

    if dpsActive then
        local now = os.clock()
        local last = pendingRequests[mob]
        if last and (now - last < 0.06) then return end
        pendingRequests[mob] = now
        R.Req:FireServer(mobName, "Mouse")
        return
    end

    local now  = os.clock()
    local last = pendingRequests[mob]
    if last and (now - last < Const.REQ_RATE) then return end
    R.Req:FireServer(mobName, "Mouse")
    pendingRequests[mob] = now
end

local _pendingCleanKeys = {}
local _pendingCleanIdx  = 0
RunService.Heartbeat:Connect(function()
    _pendingCleanIdx = _pendingCleanIdx + 1
    if _pendingCleanIdx % 150 == 0 then
        _pendingCleanKeys = {}
        for mob in next, pendingRequests do _pendingCleanKeys[#_pendingCleanKeys+1] = mob end
    end
    if #_pendingCleanKeys == 0 then return end
    local idx = (_pendingCleanIdx % #_pendingCleanKeys) + 1
    local mob = _pendingCleanKeys[idx]
    if mob then
        local h = mobHumCache[mob]
        if not mob.Parent or (h and h.Health <= 0) or not isMobAlive(mob) then
            mobHumCache[mob]     = nil
            mobNameCache[mob]    = nil
            mobDisplayCache[mob] = nil
            pendingRequests[mob] = nil
        end
    end
end)

