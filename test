-- ████████████████████████████████████████████████████████████████████
-- DPS BOOST ENGINE v12 — Per-Unit Burst Fire, Zero-State, Max Throughput
-- ████████████████████████████████████████████████████████████████████
--[[
    v12 Design Philosophy (ไม่ลด delay, หาวิธีที่ดีกว่า):
    ─────────────────────────────────────────────────────
    • ยกเลิก State Machine (eqState 0/1) → fire ทันทีไม่รอ
    • Per-unit trigger: debounce false→true ของ unit ใดก็ตาม
      → เพิ่ม hitCounter → ถ้า hitCounter >= threshold → burst fire ทันที
    • Burst Fire: ยิง DPS_EQ 3 ครั้งใน 3 frame ติดกัน (ไม่มี delay)
      → ป้องกัน packet loss / server drop
    • Threshold: ceil(unitCount * 0.45) → trigger เร็วขึ้น ไม่ต้องรอทุก unit
    • hitCounter reset ทันทีหลัง burst เพื่อรอ cycle ใหม่
    • Anti-spam: burstCooldown 6ms ระหว่าง burst series
    • Stuck watchdog: 90 frame ไม่มีใคร hit → force burst
    • autoFire (no unit): fire ทุก dpsInputDelay โดยไม่รอ signal
]]
Tabs.Pre:Section({Title="DPS Boost"})

local dpsCleanup
do

local DPS_EQ        = buffer.fromstring("\026\000")
local dpsInputDelay = 0.02
local safeDMGLimit  = 2000000
local safeBoostUntil = 0
getgenv().safeBoostActive = false

