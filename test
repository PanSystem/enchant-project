end

local function detectBossFightUI()
    local pg = lp:FindFirstChild("PlayerGui"); if not pg then return false end
    local gm = pg:FindFirstChild("Gamemodes"); if not gm then return false end
    local bf = gm:FindFirstChild("BossFight")
    return bf ~= nil and bf.Visible == true
end

local function waitCharReady(stageName, cancelFn, timeout, confirmNeeded)
    confirmNeeded = confirmNeeded or 2
    local dl = os.clock() + (timeout or 18)
    local confirmed = 0
    while os.clock() < dl do
        if cancelFn and cancelFn() then return false end
        lastStgUp = 0
        if getStg() == stageName then
            local char = lp.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hum.Health > 0 and hrp.Position.Y > -50 then
                confirmed = confirmed + 1
                if confirmed >= confirmNeeded then return true end
                task.wait(0.10); continue
            end
        end
        confirmed = 0; task.wait(0.07)
    end
    return false
end

local function waitBossFightUI(timeout, cancelFn)
    if detectBossFightUI() then return true end
    local found = false; local conns = {}
    pcall(function()
        local pg = lp:FindFirstChild("PlayerGui")
        local gm = pg and pg:FindFirstChild("Gamemodes")
        if gm then
            table.insert(conns, gm.ChildAdded:Connect(function(child)
                if child.Name == "BossFight" then
                    task.wait(0.05)
                    if child.Visible then found = true end
                    table.insert(conns, child:GetPropertyChangedSignal("Visible"):Connect(function()
                        if child.Visible then found = true end
                    end))
                end
            end))
            local bf = gm:FindFirstChild("BossFight")
            if bf then
                if bf.Visible then found = true end
                table.insert(conns, bf:GetPropertyChangedSignal("Visible"):Connect(function()
                    if bf.Visible then found = true end
                end))
            end
        end
    end)
    local dl = os.clock() + timeout
    while not found and os.clock() < dl do
        if cancelFn and cancelFn() then break end
        if detectBossFightUI() then found = true; break end
        task.wait(0.025)
    end
    for _,c in ipairs(conns) do pcall(function() c:Disconnect() end) end
    return found
end

local function waitBossEntering(timeout, cancelFn)
    local entering = Workspace:FindFirstChild("BossFight_Entering")
    if entering and entering:FindFirstChild("Demon Forest") then
        return entering:FindFirstChild("Demon Forest")
    end
    local found = nil; local conn1, conn2 = nil, nil
    pcall(function()
        if entering then
            conn1 = entering.ChildAdded:Connect(function(child)
                if child.Name == "Demon Forest" then found = child end
            end)
        else
            conn2 = Workspace.ChildAdded:Connect(function(child)
                if child.Name == "BossFight_Entering" then
                    entering = child
                    local df = child:FindFirstChild("Demon Forest")
                    if df then found = df; return end
                    conn1 = child.ChildAdded:Connect(function(c)
                        if c.Name == "Demon Forest" then found = c end
                    end)
                end
            end)
        end
    end)
    local dl = os.clock() + timeout
    while not found and os.clock() < dl do
        if cancelFn and cancelFn() then break end
        local e2 = Workspace:FindFirstChild("BossFight_Entering")
        if e2 then
            local df = e2:FindFirstChild("Demon Forest")
            if df then found = df; break end
        end
        task.wait(0.05)
    end
    if conn1 then pcall(function() conn1:Disconnect() end) end
    if conn2 then pcall(function() conn2:Disconnect() end) end
