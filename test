local function makeFarmConn(getScanFn, flagName, directTp)
    local cT,cP=nil,nil; local lastScan=0
    return RunService.Heartbeat:Connect(function()
        if not getgenv()[flagName] then return end
        local hrp=getHRP(); if not hrp then cT=nil; cP=nil; return end
        local hum=hrp.Parent and hrp.Parent:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then cT=nil; cP=nil; return end
        sendAtk()
        if dpsActive then return end
        if cT and cP then
            if not cT.Parent or not isMobAlive(cT) then cT=nil; cP=nil
            else
                if directTp then
                    local dv = hrp.Position - cP.Position
                    if dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z > 16 then
                        killVelocity(hrp); hrp.CFrame = CFrame.new(cP.Position)
                    end
                    reqAttack(cT)
