-- ── DS2 State ────────────────────────────────────────────────────────────
local DS2 = {
    hb=nil, aaConn=nil, aaHB=nil, lastAA=0,
    conns={}, desc={}, folder={},
    debs={}, unitCount=0,
    -- [v12] burst system
    hitCounter    = 0,       -- units hit this cycle
    burstPending  = 0,       -- frames left to burst-fire
    lastBurst     = 0,       -- os.clock() of last burst start
    lastNoFire    = 0,       -- os.clock() timer for no-unit fallback
    -- mob snap
    scanFn=nil, mob=nil, part=nil,
