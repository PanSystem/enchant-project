task.spawn(function()
    task.wait(2)
    pcall(function()
        if isfile(configFolder.."/Default.json") then
            local data=HttpService:JSONDecode(readfile(configFolder.."/Default.json"))
            if data.AutoLoadConfig then
                for k,v in pairs(data) do if Window.Flags[k] then Window.Flags[k]:Set(v) end end
            end
        end
    end)
end)
