local function getRiftEnemiesValue()
    local sf = findRiftVisualSession(); if not sf then return nil end
    local configs  = sf:FindFirstChild("Configs")
    local others   = configs and configs:FindFirstChild("Others")
    local enemies  = others  and others:FindFirstChild("Enemies")
    if enemies then return enemies.Value end
    return nil
end

local function getRiftTravelData()
    local sf = findRiftVisualSession(); if not sf then return nil, nil, nil end
    local configs = sf:FindFirstChild("Configs")
    local others  = configs and configs:FindFirstChild("Others")
    local portal  = others  and others:FindFirstChild("Portal")
    local travel  = portal  and portal:FindFirstChild("Travel")
    if not travel then return nil, nil, sf end

    local pp = travel:FindFirstChildOfClass("ProximityPrompt")
    if not pp then
        for _, v in next, travel:GetDescendants() do
            if v:IsA("ProximityPrompt") then pp = v; break end
        end
    end

    local part = nil
    if travel:IsA("BasePart") then
        part = travel
    elseif travel:IsA("Model") then
        part = travel.PrimaryPart or travel:FindFirstChildWhichIsA("BasePart", true)
    else
        part = travel:FindFirstChildWhichIsA("BasePart", true)
    end

    return pp, part, sf
end

local function isRiftAllClear()
    local ec = getRiftEnemiesValue()
    if ec ~= nil and ec <= 0 then return true end
    local pp = getRiftTravelData()
    if pp and pp.Enabled == true then return true end
    return false
end

local function getSpawnedRifts()
    if SpawnedRiftsFolder and SpawnedRiftsFolder.Parent then return SpawnedRiftsFolder end
    SpawnedRiftsFolder = Workspace:FindFirstChild("SpawnedRifts")
    return SpawnedRiftsFolder
end

local function findRiftModelNow()
    local sr = getSpawnedRifts(); if not sr then return nil end
    local m = sr:FindFirstChild("RiftModel")
    return (m and m.Parent) and m or nil
end

local function getRiftModelPart(model)
    if not model or not model.Parent then return nil end
    if model:IsA("BasePart") then return model end
    if model.PrimaryPart and model.PrimaryPart.Parent then return model.PrimaryPart end
    local hrp = model:FindFirstChild("HumanoidRootPart")
    if hrp and hrp.Parent then return hrp end
    return model:FindFirstChildWhichIsA("BasePart", true)
end

local function findRiftProxPrompt(model)
    if not model or not model.Parent then return nil end
    local pp = model:FindFirstChildOfClass("ProximityPrompt")
    if pp then return pp end
    local sub = model:FindFirstChild("Model")
    if sub then
        pp = sub:FindFirstChildOfClass("ProximityPrompt")
        if pp then return pp end
        for _, v in next, sub:GetDescendants() do
            if v:IsA("ProximityPrompt") then return v end
        end
    end
    for _, v in next, model:GetDescendants() do
        if v:IsA("ProximityPrompt") then return v end
    end
    return nil
end

local function waitRiftModelGone(model, timeout, cancelFn)
    if not model or not model.Parent then return true end
    local gone = false; local conn = nil
    pcall(function()
        conn = model.AncestryChanged:Connect(function(_, newParent)
            if not newParent then gone = true end
        end)
    end)
    local dl = os.clock() + (timeout or 120)
    while not gone and os.clock() < dl do
        if cancelFn and cancelFn() then break end
        if not model.Parent then gone = true; break end
        task.wait(0.04)
    end
    if conn then pcall(function() conn:Disconnect() end) end
    return gone or not model.Parent
end

local function isRiftMobValid(mob)
    return mob and mob.Parent and isMobAlive(mob) and mob.Name:sub(1,5) == "Rifts"
end

local function getRiftMobPart(m)
    if not m or not m.Parent then return nil end
    local pp = m.PrimaryPart
    if pp and pp.Parent then return pp end
    local hrp = m:FindFirstChild("HumanoidRootPart")
    if hrp and hrp.Parent then return hrp end
    for _, v in next, m:GetDescendants() do
        if v:IsA("BasePart") and v.Parent then return v end
    end
    return nil
end

local function findNearestRiftMob()
    lastTgtUp = 0
    local all = ServerTargets:GetChildren()
    cachedTargets = all
    local hrp = getHRP(); if not hrp then return nil, nil end
    local hPos = hrp.Position
    local best, bestPt, bestSq = nil, nil, math.huge
    for _, m in next, all do
        if isRiftMobValid(m) then
            local pt = getRiftMobPart(m)
            if pt then
                local d = hPos - pt.Position
                local dsq = d.X*d.X + d.Y*d.Y + d.Z*d.Z
                if dsq < bestSq then bestSq = dsq; best = m; bestPt = pt end
            end
        end
    end
    return best, bestPt
end

local function riftHasLiveMobs()
    local ec = getRiftEnemiesValue()
    if ec ~= nil then return ec > 0 end
    lastTgtUp = 0
    for _, m in next, ServerTargets:GetChildren() do
        if isRiftMobValid(m) then return true end
    end
    return false
end

local function flushAllCaches()
    lastTgtUp = 0; lastHRPUp = 0; lastPartUp = 0
    for k in next, mobHumCache     do mobHumCache[k]    = nil end
    for k in next, mobNameCache    do mobNameCache[k]   = nil end
    for k in next, mobDisplayCache do mobDisplayCache[k]= nil end
end

local REAPER_STAGE  = "Reaper Society"
local REAPER_BUF    = teleportBuffers["Reaper Society"]
local RIFT_SNAP_SQ  = 100

local function tpToReaper(cancelFn)
    if getStg() == REAPER_STAGE then
        local char = lp.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if hrp and hum and hum.Health > 0 and hrp.Position.Y > -50 then return true end
    end
    local dl = os.clock() + 15
    local lastSend = -99
    while os.clock() < dl do
        if cancelFn and cancelFn() then return false end
        local now = os.clock()
        if now - lastSend >= 0.5 then
            R.Byte:FireServer(REAPER_BUF); lastStgUp = 0; lastSend = now
        end
        task.wait(0.05)
        if getStg() == REAPER_STAGE then
            local char = lp.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hum.Health > 0 and hrp.Position.Y > -50 then return true end
        end
    end
    return getStg() == REAPER_STAGE
end

local function exitRiftViaTravel(cancelFn)
    local exitDl = os.clock() + 45
    while os.clock() < exitDl do
        if cancelFn and cancelFn() then break end
        local pp, tPart, sf = getRiftTravelData()
        if not sf or not sf.Parent then break end
        if not pp or not tPart then task.wait(0.1); continue end
        local hrp = getHRP()
        if hrp and tPart and tPart.Parent then
            local dv = hrp.Position - tPart.Position
            if dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z > 16 then
                killVelocity(hrp)
                hrp.CFrame = CFrame.new(tPart.Position + Vector3.new(0, 1, 0))
                task.wait(0.04)
            end
        end
        if pp and pp.Parent and pp.Enabled then
            pcall(function() fireproximityprompt(pp) end)
            pcall(function() fireproximityprompt(pp) end)
        end
        task.wait(0.04)
    end
    local waitDl = os.clock() + 15
    while os.clock() < waitDl do
        if cancelFn and cancelFn() then break end
        if not findRiftVisualSession() then break end
        task.wait(0.1)
    end
end

-- Signal: rift detected → wake up all systems
local riftDetectedSignal = false
local riftDetectedModel  = nil

Tabs.Gen:Toggle({
    Title="Auto Rift", Flag="AutoRift", Value=false,
    Callback=function(state)
        getgenv().autoRift = state; autoRiftRun = state
        if not state then
            getgenv().doRift = false
            State.riftActive   = false
            State.riftDetected = false
            State.riftSettling = false
            riftDetectedSignal = false
            riftDetectedModel  = nil
            if Conns.rift then pcall(function() Conns.rift:Disconnect() end); Conns.rift = nil end
            if summonPaused and summonPauseReason == "rift" then
                summonPaused = false; summonPauseReason = nil
            end
            return
        end

        task.spawn(function()
            local function cancelFn()
                return not autoRiftRun or not getgenv().autoRift
            end

            local function riftCleanup()
                if Conns.rift then pcall(function() Conns.rift:Disconnect() end); Conns.rift = nil end
                getgenv().doRift       = false
                getgenv().riftSettling = false
                State.riftActive       = false
                State.riftSettling     = false
                riftDetectedSignal     = false
                riftDetectedModel      = nil
                if summonPaused and summonPauseReason == "rift" then
                    summonPaused = false; summonPauseReason = nil
                end
            end

            local detectedModel = nil
            local watchConns    = {}

            local function disconnectWatchers()
                for _, c in ipairs(watchConns) do pcall(function() c:Disconnect() end) end
                watchConns = {}; detectedModel = nil
            end

            local function hookSpawnedRifts(srFolder)
                if not srFolder then return end
                local ex = srFolder:FindFirstChild("RiftModel")
                if ex and ex.Parent then detectedModel = ex; return end
                local c = srFolder.ChildAdded:Connect(function(child)
                    if child.Name == "RiftModel" and child.Parent then
                        detectedModel = child
                        riftDetectedSignal = true
                        riftDetectedModel  = child
                    end
                end)
                table.insert(watchConns, c)
                local ex2 = srFolder:FindFirstChild("RiftModel")
                if ex2 and ex2.Parent then
                    detectedModel = ex2
                    riftDetectedSignal = true
                    riftDetectedModel  = ex2
                end
            end

            local function setupWatchers()
                disconnectWatchers()
                local sr = getSpawnedRifts()
                if sr then
                    hookSpawnedRifts(sr)
                else
                    local wc = Workspace.ChildAdded:Connect(function(child)
                        if child.Name == "SpawnedRifts" then
                            SpawnedRiftsFolder = child
                            for i, cc in ipairs(watchConns) do
                                if cc == wc then
                                    pcall(function() cc:Disconnect() end)
                                    table.remove(watchConns, i); break
                                end
                            end
                            hookSpawnedRifts(child)
                        end
                    end)
                    table.insert(watchConns, wc)
                end
            end

            local function pollForRiftModel()
                if detectedModel and detectedModel.Parent then return detectedModel end
                local m = findRiftModelNow()
                if m then detectedModel = m; riftDetectedModel = m; return m end
                local sr = getSpawnedRifts()
                if sr and #watchConns == 0 then
                    hookSpawnedRifts(sr)
                    m = sr:FindFirstChild("RiftModel")
                    if m and m.Parent then detectedModel = m; riftDetectedModel = m; return m end
                end
                return nil
            end

            setupWatchers()

            while autoRiftRun do
                if cancelFn() then break end
                if not waitUntilAlive(cancelFn, 20) then break end
                if cancelFn() then break end

                local riftModel = pollForRiftModel()
                if not riftModel then
                    task.wait(0.05)
                    continue
                end

                detectedModel      = nil
                riftDetectedSignal = false
                riftDetectedModel  = nil

                -- ── Rift starts: take full priority ──
                getgenv().doRift   = true
                State.riftActive   = true
                State.riftDetected = true
                summonPaused       = true
                summonPauseReason  = "rift"

                -- Interrupt Raid immediately
                if getgenv().raidInP or getRaidSession() then
                    pcall(function() R.RaidsL:FireServer("Leave") end)
                    task.wait(0.08)
                    pcall(function() R.RaidsL:FireServer("Leave") end)
                    local rWait = os.clock() + 2.5
                    while getgenv().raidInP and os.clock() < rWait do task.wait(0.06) end
                    getgenv().raidInP = false
                end

                tpToReaper(cancelFn)
                if cancelFn() then riftCleanup(); setupWatchers(); continue end
                if not riftModel.Parent then riftCleanup(); setupWatchers(); continue end

                local promptActive = true
                local promptConn   = nil
                promptConn = RunService.Heartbeat:Connect(function()
                    if not promptActive then return end
                    if not riftModel or not riftModel.Parent then
                        promptActive = false; return
                    end
                    local rPart  = getRiftModelPart(riftModel)
                    local prompt = findRiftProxPrompt(riftModel)
                    local hrp    = getHRP()
                    if hrp and rPart and rPart.Parent then
                        local dv = hrp.Position - rPart.Position
                        if dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z > RIFT_SNAP_SQ then
                            killVelocity(hrp); hrp.CFrame = CFrame.new(rPart.Position)
                        end
                    end
                    if prompt and prompt.Parent then
                        pcall(function() fireproximityprompt(prompt) end)
                    end
                end)

                waitRiftModelGone(riftModel, 120, cancelFn)
                promptActive = false
                if promptConn then pcall(function() promptConn:Disconnect() end); promptConn = nil end

                if cancelFn() then riftCleanup(); setupWatchers(); continue end

                flushAllCaches()
                task.wait(0.1)

                local mobWaitDl = os.clock() + 25
                while os.clock() < mobWaitDl and autoRiftRun do
                    if cancelFn() then break end
                    flushAllCaches()
                    if riftHasLiveMobs() then break end
                    task.wait(0.04)
                end

                if cancelFn() then riftCleanup(); setupWatchers(); continue end
                if not riftHasLiveMobs() and not findRiftVisualSession() then
                    riftCleanup(); setupWatchers()
                    task.wait(0.5); continue
                end

                local initMob, initPart = findNearestRiftMob()
                if initPart then
                    local hrpNow = getHRP()
                    if hrpNow then
                        killVelocity(hrpNow)
                        hrpNow.CFrame = CFrame.new(initPart.Position)
                        task.wait(0.03)
                    end
                end
                sendAtk(); sendClk()
                if initMob then pcall(function() R.Req:FireServer(initMob.Name, "Mouse") end) end

                local cRiftMob  = initMob
                local cRiftPart = initPart
                local _reqLast  = 0
                local _scanTick = 0
                local _reEqLast = 0
                local _stuckCnt = 0

                if Conns.rift then pcall(function() Conns.rift:Disconnect() end) end
                Conns.rift = RunService.Heartbeat:Connect(function()
                    if not autoRiftRun or not getgenv().autoRift then return end
                    local now = os.clock()

                    local hrp = getHRP(); if not hrp then return end
                    local hum = hrp.Parent and hrp.Parent:FindFirstChildOfClass("Humanoid")
                    if not hum or hum.Health <= 0 then cRiftMob=nil; cRiftPart=nil; return end

                    sendAtk(); sendClk()

                    if cRiftMob then
                        if not cRiftMob.Parent or not isRiftMobValid(cRiftMob) then
                            cRiftMob = nil; cRiftPart = nil
                        else
                            local newPt = getRiftMobPart(cRiftMob)
                            if newPt and newPt.Parent then cRiftPart = newPt end
                        end
                    end

                    _scanTick = _scanTick + 1
                    if not cRiftMob and _scanTick % 2 == 0 then
                        cRiftMob, cRiftPart = findNearestRiftMob()
                    end

                    if not cRiftMob then
                        _stuckCnt = _stuckCnt + 1
                        if _stuckCnt >= 60 then
                            _stuckCnt = 0; flushAllCaches()
                            cRiftMob, cRiftPart = findNearestRiftMob()
                        end
                        return
                    end
                    _stuckCnt = 0

                    if not cRiftPart then
                        cRiftPart = getRiftMobPart(cRiftMob)
                        if not cRiftPart then cRiftMob = nil; return end
                    end

                    local dv = hrp.Position - cRiftPart.Position
                    if dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z > 16 then
                        killVelocity(hrp); hrp.CFrame = CFrame.new(cRiftPart.Position)
                    end

                    if now - _reqLast >= 0.025 then
                        _reqLast = now
                        R.Req:FireServer(cRiftMob.Name, "Mouse")
                        pendingRequests[cRiftMob] = now
                    end

                    if dpsActive and now - _reEqLast >= 2.0 then
                        _reEqLast = now
                        pcall(function() R.Byte:FireServer(buffer.fromstring("\026\000")) end)
                    end
                end)

                local CLEAR_CONFIRM = 10
                local noMobTick     = 0
                local _lastFlush    = 0
                local safetyDl      = os.clock() + 1800

                while autoRiftRun and os.clock() < safetyDl do
                    task.wait(0.1)
                    local now2 = os.clock()
                    if now2 - _lastFlush >= 2.0 then
                        _lastFlush = now2; flushAllCaches()
                    end

                    local clear = isRiftAllClear()
                    if not clear then
                        local hasRiftsMob = false
                        lastTgtUp = 0
                        for _, m in next, ServerTargets:GetChildren() do
                            if m.Name:sub(1,5) == "Rifts" and m.Parent and isMobAlive(m) then
                                hasRiftsMob = true; break
                            end
                        end
                        if hasRiftsMob then
                            noMobTick = 0
                        else
                            noMobTick = noMobTick + 1
                            if noMobTick >= CLEAR_CONFIRM then break end
                        end
                    else
                        noMobTick = noMobTick + 1
                        if noMobTick >= CLEAR_CONFIRM then break end
                    end
                end

                if Conns.rift then pcall(function() Conns.rift:Disconnect() end); Conns.rift = nil end
                cRiftMob = nil; cRiftPart = nil

                if cancelFn() then riftCleanup(); getgenv().riftSettling=false; setupWatchers(); continue end

                exitRiftViaTravel(cancelFn)

                if cancelFn() then riftCleanup(); getgenv().riftSettling=false; setupWatchers(); continue end

                -- Settling phase — let other systems know rift is done but settling
                getgenv().riftSettling = true
                State.riftSettling     = true
                State.riftActive       = false -- rift done, just settling

                if autoRiftRun and not cancelFn() then
                    lastStgUp = 0
                    if getStg() ~= "Lobby" then
                        waitReady("Lobby", 18, teleportBuffers["Lobby"], 1.0, cancelFn)
                    end
                    task.wait(0.5); lastStgUp = 0
                    if isCharReady("Lobby") then
                        task.wait(0.3); lastStgUp = 0
                        if isCharReady("Lobby") then task.wait(0.2) end
                    end
                end

                if Conns.rift then pcall(function() Conns.rift:Disconnect() end); Conns.rift = nil end
                getgenv().doRift   = false
                State.riftActive   = false
                State.riftDetected = false
                if summonPaused and summonPauseReason == "rift" then
                    summonPaused = false; summonPauseReason = nil
                end
                disconnectWatchers()

                task.wait(0.3)
                lastStgUp = 0; lastHRPUp = 0
                task.wait(0.2); lastStgUp = 0

                getgenv().riftSettling = false
                State.riftSettling     = false

                if autoRiftRun then setupWatchers() end
            end

            disconnectWatchers()
            if Conns.rift then pcall(function() Conns.rift:Disconnect() end); Conns.rift = nil end
            getgenv().doRift       = false
            getgenv().riftSettling = false
            State.riftActive       = false
            State.riftSettling     = false
            if summonPaused and summonPauseReason == "rift" then
                summonPaused = false; summonPauseReason = nil
            end
        end)
    end
})

