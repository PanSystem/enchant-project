        end
        riftCooldownUntil = 0  -- clear cooldown เมื่อ enable ใหม่
        task.spawn(function()
            local LEASH_SQ    = 5 * 5
            local cRiftMob    = nil
            local cRiftPart   = nil
            local riftEngaged = false

            local function endRift()
                if Conns.rift then Conns.rift:Disconnect(); Conns.rift = nil end
                cRiftMob = nil; cRiftPart = nil
                riftEngaged = false

                if getgenv().doRift then
