-- ==========================================
-- [Logic Loop: Auto Queue (Traits & Talents) Ultimate]
-- ==========================================
task.spawn(function()
    while task.wait(0.1) do
        if #customQueue > 0 then
            
            local activeUnitDisp = nil
            for _, uName in ipairs(customQueue) do
                if unitStates[uName] ~= "done" then
                    activeUnitDisp = uName
                    break
                end
            end
            
            if not activeUnitDisp then
                local lastUnitDisp = customQueue[#customQueue]
                local lastUnit = inventoryUnitsMap[lastUnitDisp]
                unitInfoParagraph:SetDesc(getUnitInfoText(lastUnit, false, nil, true, true))
                continue
            end
            
            local activeUnit = inventoryUnitsMap[activeUnitDisp]
            if not activeUnit or not activeUnit.Parent then
                unitStates[activeUnitDisp] = "done"
                continue
            end
            
            local isSystemRolling = (autoTraitsEnabled or autoTalentsEnabled)
            if not isSystemRolling then
                unitStates[activeUnitDisp] = "waiting"
                unitInfoParagraph:SetDesc(getUnitInfoText(activeUnit, false, activeUnitDisp, false, false))
                continue
            else
                unitStates[activeUnitDisp] = "rolling"
            end
            
            local traitsDone = not autoTraitsEnabled
            local talentsDone = not autoTalentsEnabled
            local targetBuffsClean = {}
            local isDataLoading = false
            
            -- ===================================
            -- [1] เช็คเงื่อนไข Traits
            -- ===================================
            local priIsGood = false
            local subIsGood = false
            local slotToRoll = "Primary"
            
            if autoTraitsEnabled and #targetTraits > 0 then
                local currentPri = safeGetNestedVal(activeUnit, "Traits", "Primary")
                if currentPri == "N/A" then currentPri = safeGetVal(activeUnit, "Primary_Trait") end
                
                local currentSub = safeGetNestedVal(activeUnit, "Traits", "Sub")
                if currentSub == "N/A" then currentSub = safeGetVal(activeUnit, "Sub_Trait") end
                
                if currentPri == "N/A" or currentSub == "N/A" then isDataLoading = true end
                
                local internalTargets = {}
                for _, uiTraitName in ipairs(targetTraits) do
                    local internal = trait_check[uiTraitName]
                    if internal then internalTargets[internal] = true end
                end
                
                if internalTargets[currentPri] then priIsGood = true end
                if internalTargets[currentSub] then subIsGood = true end
                
                if #targetTraits == 1 then
                    if priIsGood and subIsGood and currentPri == currentSub then
                        traitsDone = true
                    else
                        traitsDone = false
                    end
                else
                    if priIsGood and subIsGood then
                        if currentPri == currentSub then
                            subIsGood = false 
                            traitsDone = false
                        else
                            traitsDone = true
                        end
                    else
                        traitsDone = false
                    end
                end
                
                if not traitsDone and not isDataLoading then
                    if priIsGood then slotToRoll = "Sub" end
                    
                    local uiNameOfGoodSlot = nil
                    if slotToRoll == "Sub" and priIsGood then
                        uiNameOfGoodSlot = getUiNameFromInternal(currentPri)
                    elseif slotToRoll == "Primary" and subIsGood then
                        uiNameOfGoodSlot = getUiNameFromInternal(currentSub)
                    end

                    for _, uiTraitName in ipairs(targetTraits) do
                        if #targetTraits == 1 then
                            if not table.find(targetBuffsClean, uiTraitName) then table.insert(targetBuffsClean, uiTraitName) end
                        else
                            if uiNameOfGoodSlot ~= uiTraitName then
                                if not table.find(targetBuffsClean, uiTraitName) then table.insert(targetBuffsClean, uiTraitName) end
                            end
                        end
                    end
                end
            elseif autoTraitsEnabled and #targetTraits == 0 then
                traitsDone = true
            end
            
            -- ===================================
            -- [2] เช็คเงื่อนไข Talents
            -- ===================================
            local targetLayout = talent_check[targetTalentTier] and talent_check[targetTalentTier].layout or 0
            local highestCurrentLayout = 0
            local statsLayouts = {}
            local slotToRollTalent = nil
            local oldValForRoll = nil
            
            if autoTalentsEnabled and #targetTalents > 0 then
                for _, rStat in ipairs(allTalentKeys) do
                    local valStr = getRawStat(activeUnit, rStat)
                    if valStr == "N/A" then isDataLoading = true end
                    local l, _ = getStatLayoutAndTier(rStat, valStr)
                    if l > highestCurrentLayout then highestCurrentLayout = l end
                end

                local allTalentsGood = true
                for _, uiTalent in ipairs(targetTalents) do
                    local remStatName = talentUIToRemote[uiTalent]
                    local valStrTarget = getRawStat(activeUnit, remStatName)
                    local lTarget, _ = getStatLayoutAndTier(remStatName, valStrTarget)
                    if lTarget < targetLayout then
                        allTalentsGood = false
                        if not slotToRollTalent then 
                            slotToRollTalent = remStatName
                            oldValForRoll = valStrTarget
                        end
                    end
                end
                talentsDone = allTalentsGood
            elseif autoTalentsEnabled and #targetTalents == 0 then
                talentsDone = true
            end
            
            if isDataLoading then
                unitInfoParagraph:SetDesc("Loading Unit Data... Please Wait.")
                continue
            end
            
            unitInfoParagraph:SetDesc(getUnitInfoText(activeUnit, true, activeUnitDisp, traitsDone, talentsDone))
            
            -- ===================================
            -- [3] ทำงานส่ง Remote สลับคิว
            -- ===================================
            if traitsDone and talentsDone then
                unitStates[activeUnitDisp] = "done"
                unitInfoParagraph:SetDesc(getUnitInfoText(activeUnit, false, activeUnitDisp, true, true))
                task.wait(1) 
                for i, v in ipairs(customQueue) do
                    if v == activeUnitDisp then table.remove(customQueue, i); break end
                end
            else
                if not traitsDone then
                    local oldTraitVal = slotToRoll == "Primary" and safeGetNestedVal(activeUnit, "Traits", "Primary") or safeGetNestedVal(activeUnit, "Traits", "Sub")
                    if oldTraitVal == "N/A" then 
                        oldTraitVal = slotToRoll == "Primary" and safeGetVal(activeUnit, "Primary_Trait") or safeGetVal(activeUnit, "Sub_Trait")
                    end
                    pcall(function() RS:WaitForChild("Remotes"):WaitForChild("Gamblings"):WaitForChild("Traits"):FireServer(activeUnit.Name, slotToRoll, targetBuffsClean, false) end)
                    waitTraitChange(activeUnit, slotToRoll, oldTraitVal, 3.0)
                    
                elseif not talentsDone then
                    if highestCurrentLayout < 16 then
                        pcall(function() RS:WaitForChild("Remotes"):WaitForChild("Systems"):WaitForChild("Potentials_Rolling"):FireServer(activeUnit.Name, "Reroll", "Once") end)
                        task.wait(0.5)
                    elseif slotToRollTalent then
                        pcall(function() RS:WaitForChild("Remotes"):WaitForChild("Systems"):WaitForChild("Potentials_Rolling"):FireServer(activeUnit.Name, "Reroll", slotToRollTalent) end)
                        waitTalentChange(activeUnit, slotToRollTalent, oldValForRoll, 3.0)
                    end
                end
            end
        end
    end
end)


