local NOTIFY_CONTAINERS = {
    "Objectives","Objectives2","Announcement","Announcements",
    "SystemMessage","Notification","Notifications","Alert",
    "Event","EventUI","Overlay","HUD",
}
local function _scanRiftTextFn()
    local pg=lp:FindFirstChild("PlayerGui"); if not pg then return false end
    for _,sg in ipairs(pg:GetChildren()) do
        if not sg:IsA("ScreenGui") then continue end
        if isSkippedGui(sg) then continue end
        local foundContainer=false
        for _,cname in ipairs(NOTIFY_CONTAINERS) do
            local container=sg:FindFirstChild(cname,true)
            if container then
                foundContainer=true
                for _,v in ipairs(container:GetDescendants()) do
                    if v:IsA("TextLabel") and v.Visible and v.Text:lower():find("rift",1,true) then return true end
                end
            end
        end
        if not foundContainer then
            for _,child in ipairs(sg:GetChildren()) do
                for _,v in ipairs(child:GetDescendants()) do
                    if v:IsA("TextLabel") and v.Visible and v.Text:lower():find("rift",1,true) then return true end
                end
            end
        end
    end
    return false
end

local function checkRiftPhysical()
    local maps=Workspace:FindFirstChild("Maps")
    local rs=maps and maps:FindFirstChild("Reaper Society")
    if rs then
        local sr=rs:FindFirstChild("SpawnedRifts")
        if sr and #sr:GetChildren()>0 then return true end
        for _,c in ipairs(rs:GetChildren()) do
            if c.Name:lower():find("rift",1,true) and #c:GetChildren()>0 then return true end
        end
    end
    local d=Workspace:FindFirstChild("SpawnedRifts")
    if d and #d:GetChildren()>0 then return true end
    for _,m in next,getSTgts() do
        if m.Name:sub(1,5)=="Rifts" and isMobAlive(m) then return true end
    end
    return false
end

