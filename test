-- ── AA keepalive ──────────────────────────────────────────────────────────
local function getAABool() return MyData:FindFirstChild("Auto_Attacks") end
local function isAAOn()    local v=getAABool(); return v~=nil and v.Value==true end
local function doAAOn()    R.Byte:FireServer(AA_ON); DS2.lastAA=os.clock() end
local function doAAOff()   R.Byte:FireServer(AA_OFF) end

local function wireAA(av)
