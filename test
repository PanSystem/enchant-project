do
local function getLobbyPads()
    local pads={}
    if RaidsEntering then
        for _,v in next,RaidsEntering:GetChildren() do if v.Name~="Specify" then pads[#pads+1]=v end end
    end
    table.sort(pads,function(a,b) return a.Name<b.Name end)
    return pads
end
local function isPadAvailable(pad)
    local sv=pad and pad:FindFirstChildWhichIsA("StringValue",true)
    return sv and (sv.Value==myName or sv.Value=="" or sv.Value==" ") or true
end
local function getDoubleDungeonPad()
    local sp=RaidsEntering and RaidsEntering:FindFirstChild("Specify")
    return (sp and isPadAvailable(sp)) and sp or nil
end

-- ==========================================
-- [FIX] countRaidMobs — force session refresh ก่อนนับทุกครั้งที่ forceRefresh=true
-- แก้ปัญหา isRaidMob คืน false เพราะ getRaidSession() cache หมดอายุ
-- ==========================================
local raidMobCountCache, raidMobCountAt = 0, -1
local function countRaidMobs(forceRefresh)
    local now=os.clock()
    if not forceRefresh and (now-raidMobCountAt)<0.03 then return raidMobCountCache end
    -- [FIX] force refresh session ก่อนนับมอบเสมอ
    if forceRefresh then forceSessionRefresh() end
    lastTgtUp=0
    local count=0
    for _,v in next,getSTgts() do
        if isRaidMob(v) and v.Name:sub(1,5)=="Raids" then count=count+1 end
    end
    raidMobCountCache=count; raidMobCountAt=now
    return count
end

local function raidYieldCheck() return getgenv().doRift end

local function collectBoxes()
    if raidYieldCheck() then return end

    local sessionFolder = nil
    if RaidsVisual then
        for _, f in next, RaidsVisual:GetChildren() do
            if f.Name:find(myName, 1, true) then
                sessionFolder = f; break
            end
        end
    end
    if not sessionFolder then return end

    local rewardsFolder = sessionFolder:FindFirstChild("Configs")
    rewardsFolder = rewardsFolder and rewardsFolder:FindFirstChild("Others")
    rewardsFolder = rewardsFolder and rewardsFolder:FindFirstChild("Rewards")
    if not rewardsFolder then return end

    local waitDl = os.clock() + 3.0
    while os.clock() < waitDl and getgenv().autoRaid do
        if raidYieldCheck() then return end
        if #rewardsFolder:GetChildren() > 0 then break end
        task.wait(0.05)
    end

    local function getBoxModels()
        local models = {}
        for _, child in next, rewardsFolder:GetChildren() do
            if child:IsA("Model") then
                if child.Name == "Purple" and not getgenv().colPurp then continue end
                models[#models + 1] = child
            end
        end
        return models
    end

    local function getActivePrompt(model)
        if not model or not model.Parent then return nil end
        for _, v in next, model:GetDescendants() do
            if v:IsA("ProximityPrompt") and v.Enabled then return v end
        end
        return nil
    end
    local function getModelPart(model)
        return model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
    end

    local collectDl = os.clock() + 15.0
    while os.clock() < collectDl and getgenv().autoRaid do
        if raidYieldCheck() then return end
        local models = getBoxModels()
        if #models == 0 then break end
        local anyActive = false
        for _, box in ipairs(models) do
            if not box or not box.Parent then continue end
            if raidYieldCheck() then return end
            local prm = getActivePrompt(box)
            if not prm then continue end
            anyActive = true
            local part = getModelPart(box)
            local hrp  = getHRP()
            if hrp and part then
                killVelocity(hrp)
                hrp.CFrame = CFrame.new(part.Position + Vector3.new(0, 1.5, 0))
                task.wait(0.05)
            end
            local fireDl = os.clock() + 4.0
            while os.clock() < fireDl and getgenv().autoRaid do
                if raidYieldCheck() then return end
                if not prm or not prm.Parent or not prm.Enabled then break end
                hrp = getHRP()
                if hrp and part and part.Parent then
                    local dv = hrp.Position - part.Position
                    if dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z > 4*4 then
                        killVelocity(hrp)
                        hrp.CFrame = CFrame.new(part.Position + Vector3.new(0, 1.5, 0))
                        task.wait(0.04); continue
                    end
                end
                firePrompt(prm)
                task.wait(0.05)
            end
        end
        if not anyActive then break end
        task.wait(0.1)
    end
end

local function exitRaid()
    if getgenv().raidExitMode=="Stealth" then sendTeleport("Lobby"); task.wait(1.0); return end
    local dl=os.clock()+12; local lastFireTime=0
    while os.clock()<dl and getgenv().autoRaid do
        if raidYieldCheck() then return end
        if not getRaidSession() then break end
        local prm,portalPart=nil,nil
        if RaidsVisual then
            for _,f in next,RaidsVisual:GetChildren() do
                if f.Name:find(myName,1,true) then
                    local portalObj=f:FindFirstChild("Portal",true)
                    if portalObj then
                        prm=portalObj:FindFirstChildWhichIsA("ProximityPrompt",true) or portalObj:FindFirstChildOfClass("ProximityPrompt")
                        if portalObj:IsA("BasePart") then portalPart=portalObj
                        elseif portalObj:IsA("Model") then portalPart=portalObj.PrimaryPart or portalObj:FindFirstChildWhichIsA("BasePart") end
                        if not portalPart and prm then portalPart=prm.Parent and prm.Parent:IsA("BasePart") and prm.Parent or nil end
                    end; break
                end
            end
        end
        if prm and prm.Enabled then
            local hrp=getHRP()
            if hrp and portalPart then
                killVelocity(hrp); hrp.CFrame=CFrame.new(portalPart.Position+Vector3.new(0,1.5,0)); task.wait(0.05)
            end
            local now=os.clock()
            if now-lastFireTime>=0.18 then
                for _=1,6 do firePrompt(prm); task.wait(0.04) end; lastFireTime=os.clock()
            end; task.wait(0.10)
        else
            if os.clock()>dl-8 then sendTeleport("Lobby"); task.wait(1.0); break end
            task.wait(0.15)
        end
    end
end

Tabs.Gen:Toggle({
    Title="Auto Raid", Flag="AutoRaid", Value=false,
    Callback=function(state)
        getgenv().autoRaid=state
        if not state then
            if Conns.raid then Conns.raid:Disconnect(); Conns.raid=nil end
            getgenv().raidInP=false; getgenv().raidSt="IDLE"
            raidMobCountAt=-1
            if summonPaused and summonPauseReason=="raid" then summonPaused=false; summonPauseReason=nil end
            return
        end
        task.spawn(function()
            local st="IDLE"
            local pads,pIdx,cAtt={},1,0
            local inCombat=false
            local stateEnterTime=os.clock()
            local lastCreateTime=0
            local cTgt,cPart=nil,nil

            local function setRaidSt(s) st=s; getgenv().raidSt=s; stateEnterTime=os.clock() end
            local function stateAge()   return os.clock()-stateEnterTime end
            local function sg()         return getgenv().isDD and "Dungeons Town" or "Lobby" end

            local function cleanupCombat()
                inCombat=false
                if Conns.raid then Conns.raid:Disconnect(); Conns.raid=nil end
                cTgt=nil; cPart=nil; raidMobCountAt=-1
            end
            local function abortRaid()
                cleanupCombat()
                pcall(function() R.RaidsL:FireServer("Leave") end)
                task.wait(0.12); getgenv().raidInP=false
                if summonPaused and summonPauseReason=="raid" then summonPaused=false; summonPauseReason=nil end
                setRaidSt("IDLE")
            end

            local function startRaidCombat()
                if Conns.raid then Conns.raid:Disconnect() end
                inCombat=true; cTgt=nil; cPart=nil; raidMobCountAt=-1
                Conns.raid=RunService.Heartbeat:Connect(function()
                    if not inCombat or not getgenv().autoRaid then
                        if Conns.raid then Conns.raid:Disconnect(); Conns.raid=nil end; return
                    end
                    if getgenv().doRift then inCombat=false; return end
                    sendAtk()

                    if cTgt and cPart then
                        if not cTgt.Parent or not isMobAlive(cTgt) or not isRaidMob(cTgt) then
                            cTgt=nil; cPart=nil
                        end
                    end
                    if not cTgt then
                        local hrp=getHRP()
                        if hrp then
                            local hPos=hrp.Position; local bestSq=math.huge
                            local tgts=getSTgts()
                            for i=1,#tgts do
                                local v=tgts[i]
                                if isRaidMob(v) and v.Name:sub(1,5)=="Raids" then
                                    local pt=v.PrimaryPart or v:FindFirstChild("HumanoidRootPart")
                                    if pt then
                                        local dx=hPos.X-pt.Position.X; local dz=hPos.Z-pt.Position.Z
                                        local dsq=dx*dx+dz*dz
                                        if dsq<bestSq then bestSq=dsq; cTgt=v; cPart=pt end
                                    end
                                end
                            end
                        end
                    end
                    if cTgt and cPart then
                        local hrp=getHRP()
                        if hrp then
                            local mPos=cPart.Position
                            -- [FIX] TP ตรงไปที่มอนเลย เหมือน Auto Selected ไม่เช็คระยะ
                            killVelocity(hrp)
                            hrp.CFrame=CFrame.new(mPos)
                            reqAttack(cTgt)
                        end
                    end
                end)
            end

            local function tpToStage(target)
                lastStgUp=0
                if getStg()==target then
                    local char=lp.Character
                    local hrp=char and char:FindFirstChild("HumanoidRootPart")
                    local hum=char and char:FindFirstChildOfClass("Humanoid")
                    if hrp and hum and hrp.Position.Y>-50 and hum.Health>0 then
                        task.wait(0.12); lastStgUp=0
                        if getStg()==target then return true end
                    end
                end
                if raidYieldCheck() then return false end
                local deadline=os.clock()+22; local lastSend=-99
                local interval=1.5
                while os.clock()<deadline do
                    if raidYieldCheck() then return false end
                    local now=os.clock()
                    if now-lastSend>=interval then
                        R.Byte:FireServer(teleportBuffers[target]); lastSend=now
                        interval=math.min(interval*1.3, 4.0)
                    end
                    task.wait(0.08); lastStgUp=0
                    if getStg()==target then
                        local char=lp.Character
                        local hrp=char and char:FindFirstChild("HumanoidRootPart")
                        local hum=char and char:FindFirstChildOfClass("Humanoid")
                        if hrp and hum and hrp.Position.Y>-50 and hum.Health>0 then
                            task.wait(0.15); lastStgUp=0
                            if getStg()==target then
                                task.wait(0.10); lastStgUp=0
                                if getStg()==target then return true end
                            end
                        end
                    end
                end
                return false
            end

            local sessionSignalConn=nil; local sessionJustCreated=false
            local function startSessionWatch()
                if sessionSignalConn or not RaidsVisual then return end
                sessionSignalConn=RaidsVisual.ChildAdded:Connect(function(child)
                    if child.Name:find(myName,1,true) then sessionJustCreated=true end
                end)
            end
            local function stopSessionWatch()
                if sessionSignalConn then sessionSignalConn:Disconnect(); sessionSignalConn=nil end
                sessionJustCreated=false
            end

            local mobSignalConn=nil; local mobJustAppeared=false
            local function startMobWatch()
                if mobSignalConn then return end
                mobSignalConn=ServerTargets.ChildAdded:Connect(function(child)
                    if child.Name:sub(1,5)=="Raids" then mobJustAppeared=true end
                end)
            end
            local function stopMobWatch()
                if mobSignalConn then mobSignalConn:Disconnect(); mobSignalConn=nil end
                mobJustAppeared=false
            end
            startSessionWatch(); startMobWatch()

            while getgenv().autoRaid do
                getgenv().raidSt=st

                if getgenv().doRift then
                    abortRaid(); stopSessionWatch(); stopMobWatch()
                    while getgenv().autoRaid and getgenv().doRift do task.wait(0.12) end
                    if getgenv().autoRaid then
                        lastStgUp=0
                        if getStg()==sg() then
                            if not getgenv().isDD then pads=getLobbyPads(); pIdx=1 end
                            cAtt=0; setRaidSt("FIND_PAD")
                        else setRaidSt("TELEPORT") end
                        startSessionWatch(); startMobWatch()
                    end
                    continue
                end

                if st=="IDLE" then
                    inCombat=false; getgenv().raidInP=false; raidMobCountAt=-1
                    forceSessionRefresh(); task.wait(0.04)
                    if getRaidSession() then
                        getgenv().raidInP=true; summonPaused=true; summonPauseReason="raid"
                        setRaidSt(countRaidMobs(true)>0 and "FIGHTING" or "POST_FIGHT")
                    else
                        pads={}; pIdx=1; cAtt=0; lastStgUp=0
                        if getStg()==sg() then
                            if not getgenv().isDD then pads=getLobbyPads() end
                            setRaidSt("FIND_PAD")
                        else setRaidSt("TELEPORT") end
                    end

                elseif st=="TELEPORT" then
                    if stateAge()>90 then setRaidSt("IDLE"); continue end
                    getgenv().raidInP=false
                    local ok=tpToStage(sg())
                    if raidYieldCheck() then continue end
                    if ok then
                        if not getgenv().isDD then pads=getLobbyPads(); pIdx=1 end
                        cAtt=0; setRaidSt("FIND_PAD")
                    else task.wait(0.4); continue end

                elseif st=="FIND_PAD" then
                    getgenv().raidInP=false
                    -- [PRIORITY] หาก Boss พร้อมแล้ว pause raid เพื่อให้ boss ไปก่อน
                    if getgenv().autoBoss and isBossEventActive()
                       and (os.clock()-(getgenv().lastBossKill or 0)>=25) then
                        task.wait(1.0); continue
                    end
                    if stateAge()>25 then
                        lastStgUp=0
                        if getStg()~=sg() then setRaidSt("TELEPORT")
                        else pads=getLobbyPads(); pIdx=1; stateEnterTime=os.clock() end
                        continue
                    end
                    lastStgUp=0
                    if getStg()~=sg() then setRaidSt("TELEPORT"); continue end
                    local pad=nil
                    if getgenv().isDD then
                        pad=getDoubleDungeonPad()
                        if not pad then task.wait(0.25); continue end
                    else
                        if #pads==0 then pads=getLobbyPads(); pIdx=1 end
                        if #pads==0 then task.wait(0.25); continue end
                        for i=1,#pads do
                            local idx=((pIdx-1+i-1)%#pads)+1
                            local p=pads[idx]
                            if p and p.Parent and isPadAvailable(p) then pad=p; pIdx=idx; break end
                        end
                        if not pad then
                            pads=getLobbyPads(); pIdx=(pIdx%math.max(#pads,1))+1
                            task.wait(0.25); continue
                        end
                    end
                    local ct=pad:FindFirstChild("Centers") or pad:FindFirstChildWhichIsA("BasePart")
                    if ct then tpDirect(ct,true,false) else tpTarget(pad) end
                    task.wait(0.10)
                    if not getgenv().autoRaid or raidYieldCheck() then continue end
                    cAtt=0; sessionJustCreated=false; setRaidSt("CREATE")

                elseif st=="CREATE" then
                    -- [PRIORITY] หาก Boss พร้อมแล้ว ไม่สร้าง Raid ใหม่
                    if getgenv().autoBoss and isBossEventActive()
                       and (os.clock()-(getgenv().lastBossKill or 0)>=25) then
                        setRaidSt("FIND_PAD"); continue
                    end
                    if stateAge()>20 then
                        cAtt=0
                        if not getgenv().isDD and #pads>0 then pIdx=(pIdx%#pads)+1 end
                        setRaidSt("FIND_PAD"); continue
                    end
                    forceSessionRefresh()
                    if getRaidSession() or sessionJustCreated then
                        sessionJustCreated=false; setRaidSt("WAIT_ENTER"); continue
                    end
                    if cAtt==0 then
                        lastStgUp=0; if getStg()~=sg() then setRaidSt("TELEPORT"); continue end
                    end
                    if os.clock()-lastCreateTime>=0.15 then
                        lastCreateTime=os.clock()
                        R.Raids:FireServer(
                            getgenv().isDD and "Double Dungeons" or getgenv().selRaidMap,
                            getgenv().selRaidDiff)
                        cAtt=cAtt+1
                    end
                    local cDl=os.clock()+2.0
                    while os.clock()<cDl do
                        if raidYieldCheck() then break end
                        if sessionJustCreated then sessionJustCreated=false; setRaidSt("WAIT_ENTER"); break end
                        forceSessionRefresh()
                        if getRaidSession() then setRaidSt("WAIT_ENTER"); break end
                        task.wait(0.02)
                    end
                    if st~="WAIT_ENTER" then
                        if cAtt>=5 then
                            cAtt=0
                            if not getgenv().isDD and #pads>0 then pIdx=(pIdx%#pads)+1 end
                            setRaidSt("FIND_PAD")
                        else task.wait(0.08) end
                    end

                elseif st=="WAIT_ENTER" then
                    if stateAge()>35 then
                        forceSessionRefresh()
                        if getRaidSession() then
                            pcall(function() R.RaidsL:FireServer("Leave") end); task.wait(0.25)
                        end
                        setRaidSt("IDLE"); continue
                    end
                    getgenv().raidInP=true; summonPaused=true; summonPauseReason="raid"
                    lastTgtUp=0; mobJustAppeared=false
                    if mobJustAppeared or countRaidMobs(true)>0 then
                        mobJustAppeared=false; setRaidSt("FIGHTING")
                    else task.wait(0.01) end

                elseif st=="FIGHTING" then
                    if stateAge()>300 then
                        cleanupCombat()
                        pcall(function() R.RaidsL:FireServer("Leave") end)
                        task.wait(0.12); getgenv().raidInP=false
                        if summonPaused and summonPauseReason=="raid" then summonPaused=false; summonPauseReason=nil end
                        setRaidSt("IDLE"); continue
                    end
                    getgenv().raidInP=true; summonPaused=true; summonPauseReason="raid"
                    if not inCombat then startRaidCombat() end

                    -- ==========================================
                    -- [FIX] FIGHTING inner loop — triple confirm 0.3s x2
                    -- ป้องกันออกก่อนมอนตายหมด เพราะ countRaidMobs
                    -- อาจคืน 0 ชั่วคราวจาก session cache miss
                    -- ==========================================
                    local fDl=os.clock()+300
                    while os.clock()<fDl and getgenv().autoRaid do
                        if getgenv().doRift then
                            cleanupCombat()
                            pcall(function() R.RaidsL:FireServer("Leave") end)
                            task.wait(0.12); getgenv().raidInP=false
                            if summonPaused and summonPauseReason=="raid" then summonPaused=false; summonPauseReason=nil end
                            setRaidSt("IDLE"); break
                        end
                        -- [FIX] force session refresh ก่อนนับ
                        forceSessionRefresh()
                        raidMobCountAt = -1
                        if countRaidMobs(true)==0 then
                            -- confirm รอบที่ 1 (0.3s)
                            task.wait(0.3)
                            forceSessionRefresh(); raidMobCountAt = -1
                            if countRaidMobs(true)==0 then
                                -- confirm รอบที่ 2 (0.3s) — ถ้ายังเป็น 0 จริงๆ ค่อยออก
                                task.wait(0.3)
                                forceSessionRefresh(); raidMobCountAt = -1
                                if countRaidMobs(true)==0 then break end
                            end
                        end
                        task.wait(0.015)
                    end

                    if st=="FIGHTING" then
                        cleanupCombat(); task.wait(0.03); forceSessionRefresh()
                        setRaidSt("POST_FIGHT")
                    end

                elseif st=="POST_FIGHT" then
                    if stateAge()>25 then abortRaid(); continue end
                    if raidYieldCheck() then abortRaid(); continue end
                    -- ตรวจก่อนว่า mob กลับมาไหม
                    forceSessionRefresh(); raidMobCountAt = -1
                    if countRaidMobs(true)>0 then setRaidSt("FIGHTING"); continue end
                    inCombat=false; getgenv().raidInP=true
                    collectBoxes()
                    if not getgenv().autoRaid then break end
                    if raidYieldCheck() then abortRaid(); continue end
                    forceSessionRefresh(); raidMobCountAt = -1
                    if countRaidMobs(true)>0 then setRaidSt("FIGHTING"); continue end
                    exitRaid()
                    if raidYieldCheck() then abortRaid(); continue end
                    forceSessionRefresh()
                    if getRaidSession() then
                        pcall(function() R.RaidsL:FireServer("Leave") end)
                        task.wait(0.25); forceSessionRefresh()
                    end
                    setRaidSt("WAIT_EXIT")

                elseif st=="WAIT_EXIT" then
                    if stateAge()>45 then
                        getgenv().raidInP=false
                        if summonPaused and summonPauseReason=="raid" then summonPaused=false; summonPauseReason=nil end
                        setRaidSt("IDLE"); continue
                    end
                    inCombat=false
                    local target=sg(); lastStgUp=0
                    if getStg()==target then
                        getgenv().raidInP=false
                        if summonPaused and summonPauseReason=="raid" then summonPaused=false; summonPauseReason=nil end
                        forceSessionRefresh(); task.wait(0.04); setRaidSt("IDLE"); continue
                    end
                    local confirmed=tpToStage(target)
                    if confirmed then
                        getgenv().raidInP=false
                        if summonPaused and summonPauseReason=="raid" then summonPaused=false; summonPauseReason=nil end
                        forceSessionRefresh(); task.wait(0.04); setRaidSt("IDLE")
                    else
                        if raidYieldCheck() then continue end; task.wait(0.25)
                    end
                end
                RunService.Heartbeat:Wait()
            end
            stopSessionWatch(); stopMobWatch(); abortRaid()
        end)
    end
})

