local function checkUnitTraitsDone(unit)
    if #targetTraits == 0 then return true end
    local currentPri = safeGetNestedVal(unit, "Traits", "Primary"); if currentPri == "N/A" then currentPri = safeGetVal(unit, "Primary_Trait") end
    local currentSub = safeGetNestedVal(unit, "Traits", "Sub"); if currentSub == "N/A" then currentSub = safeGetVal(unit, "Sub_Trait") end
    
    local uiPri = getUiNameFromInternal(currentPri)
    local uiSub = getUiNameFromInternal(currentSub)
    
    if #targetTraits == 1 then 
        return (uiPri == targetTraits[1] and uiSub == targetTraits[1])
    else 
        local matchPri = table.find(targetTraits, uiPri) ~= nil
        local matchSub = table.find(targetTraits, uiSub) ~= nil
        return (matchPri and matchSub and uiPri ~= uiSub)
    end
end

local function checkUnitTalentsDone(unit)
    if #targetTalents == 0 then return true end
    local targetLayout = talent_check[targetTalentTier] and talent_check[targetTalentTier].layout or 0
    for _, uiTalent in ipairs(targetTalents) do
        local remStatName = talentUIToRemote[uiTalent]
        local tVal = safeGetNestedVal(unit, "Potentials_Adjustment", remStatName)
        if tVal == "N/A" then tVal = safeGetVal(unit, remStatName == "Abilities_DMG" and "Ability_Talent" or (remStatName == "Critical_Damage" and "Critical_Talent" or remStatName .. "_Talent")) end
        local l, _ = getStatLayoutAndTier(remStatName, tVal)
        if l < targetLayout then return false end
    end
    return true
end

local function getUnitInfoText()
    local info = "--- Queue Status ---\n"
    if #selectedInventoryUnits == 0 then return info .. "No unit selected." end
    
    for i, uName in ipairs(selectedInventoryUnits) do
        local unit = inventoryUnitsMap[uName]
        if not unit then 
            info = info .. i .. ". " .. uName .. " [Not Found]\n"
            continue 
        end
        
        local tDone = checkUnitTraitsDone(unit)
        local talDone = checkUnitTalentsDone(unit)
        
        local tEmoji = tDone and "✅" or (autoTraitsEnabled and "🔄" or "⏸️")
        local talEmoji = talDone and "✅" or (autoTalentsEnabled and "🔄" or "⏸️")
        
        if not autoTraitsEnabled and not autoTalentsEnabled then
            info = info .. i .. ". " .. uName .. " [⏸️ Waiting]\n"
        else
            info = info .. i .. ". " .. uName .. " [Traits: " .. tEmoji .. " | Talents: " .. talEmoji .. "]\n"
        end
    end
    return info
end

