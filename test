local function isCharReady(expectedStage)
    if getStg()~=expectedStage then return false end
    local char=lp.Character; if not char then return false end
    local h=char:FindFirstChild("HumanoidRootPart")
    local hum=char:FindFirstChildOfClass("Humanoid")
    return h and hum and h.Position.Y>=-100 and hum.Health>0
end

local function waitUntilAlive(cancelFn, timeout)
    local char = lp.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if hrp and hum and hum.Health > 0 and hrp.Position.Y > -50 then return true end
    local dl = os.clock() + (timeout or 20)
    while os.clock() < dl do
        if cancelFn and cancelFn() then return false end
        task.wait(0.15)
        char = lp.Character
        hrp  = char and char:FindFirstChild("HumanoidRootPart")
        hum  = char and char:FindFirstChildOfClass("Humanoid")
        if hrp and hum and hum.Health > 0 and hrp.Position.Y > -50 then
            task.wait(0.3)
            lastHRPUp=0; lastStgUp=0; cachedHRP=nil
            return true
        end
    end
    return false
end

local function waitReady(expectedStage, timeout, bufferStr, retryInt, cancelFn)
    local deadline = os.clock() + timeout
    local lastSend = -999
    local interval = retryInt or 2.0
    while os.clock() < deadline do
        if cancelFn and cancelFn() then return false end
        local now = os.clock()
        if now - lastSend >= interval then
            if bufferStr then R.Byte:FireServer(bufferStr) end
            lastSend = now; lastStgUp = 0
            interval = math.min(interval * 1.2, 5.0)
        end
        task.wait(0.08)
        if isCharReady(expectedStage) then
            task.wait(0.20); lastStgUp = 0
            if isCharReady(expectedStage) then return true end
        end
    end
    return false
end

