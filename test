-- 🧠 [SmartWait for Boxes - เก็บกล่องและออกด่านรวดเร็ว]
local function collectBoxes(others, checkFunc)
    if not others then return end
    local rewardsFolder = others:FindFirstChild("Rewards")
    if not rewardsFolder then rewardsFolder = others:FindFirstChild("Rewards", true) end
    if not rewardsFolder then return end

    SmartWait(function()
        if checkFunc and not checkFunc() then return true end
        return #rewardsFolder:GetChildren() > 0
    end, 5.0)

    if #rewardsFolder:GetChildren() == 0 then return end

    local function findActivePrompt(model)
        if not model or not model.Parent then return nil end
        for _, v in next, model:GetDescendants() do
            if v:IsA("ProximityPrompt") and v.Enabled then return v end
        end
        return nil
    end

    local collectDl = os.clock() + 20.0
    while os.clock() < collectDl do
        if checkFunc and not checkFunc() then return end
        local boxes     = rewardsFolder:GetChildren()
        local anyActive = false

        for _, box in ipairs(boxes) do
            if not box or not box.Parent then continue end
            if collectPurpleChest == "No" and string.lower(box.Name):find("purple") then continue end
            local prm = findActivePrompt(box)
            if not prm or not prm.Enabled then continue end
            anyActive = true
            local part = box.PrimaryPart or box:FindFirstChildWhichIsA("BasePart")
            if not part and prm.Parent and prm.Parent:IsA("BasePart") then part = prm.Parent end
            if not part then continue end
            local targetPos = part.Position + Vector3.new(0, 1.5, 0)
            local pHRP = LP.Character and (LP.Character:FindFirstChild("HumanoidRootPart") or LP.Character:FindFirstChild("Torso"))
            if pHRP then
                pHRP.AssemblyLinearVelocity = Vector3.zero
                pHRP.AssemblyAngularVelocity = Vector3.zero
                pHRP.CFrame = CFrame.new(targetPos)
            end
            
            SmartWait(function()
                if checkFunc and not checkFunc() then return true end
                if not prm or not prm.Parent or not prm.Enabled then return true end
                if not box.Parent then return true end
                
                local pHRP_in = LP.Character and (LP.Character:FindFirstChild("HumanoidRootPart") or LP.Character:FindFirstChild("Torso"))
                if pHRP_in then
                    local dv = pHRP_in.Position - part.Position
                    if dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z > 9 then
                        pHRP_in.AssemblyLinearVelocity = Vector3.zero
                        pHRP_in.AssemblyAngularVelocity = Vector3.zero
                        pHRP_in.CFrame = CFrame.new(targetPos)
                    end
                end
                pcall(function() fireproximityprompt(prm, 1, true) end)
                return false
            end, 3.0)
        end
        if not anyActive then break end
        task.wait(0.05)
    end
end

local function getPriorityCheck()
    local riftSpawned = false
    local spawnedRiftsFolder = workspace:FindFirstChild("SpawnedRifts")
    if spawnedRiftsFolder and #spawnedRiftsFolder:GetChildren() > 0 then riftSpawned = true end
    for _, mon in ipairs(Server:GetChildren()) do
        if string.find(mon.Name, "Rift") then riftSpawned = true; break end
    end
    
    local bossValues = RS:FindFirstChild("Values")
        and RS.Values:FindFirstChild("Gamemodes")
        and RS.Values.Gamemodes:FindFirstChild("BossFights")
        and RS.Values.Gamemodes.BossFights:FindFirstChild("Bosses")
    local bossSpawned = bossValues and bossValues.Value ~= ""
    
    local currentlyInRaid = false
    local raidsVisual = workspace:FindFirstChild("Raids_Visual")
    if raidsVisual then
        for _, f in ipairs(raidsVisual:GetChildren()) do
            if not string.find(f.Name, "Rift") and (string.find(f.Name, "Server_" .. LP.Name) or string.match(f.Name, "Clients_" .. LP.Name)) then
                currentlyInRaid = true; break
            end
        end
    end
    
    return riftSpawned, bossSpawned, currentlyInRaid
end

local function getNearestMobByPattern(pattern)
    local char = LP.Character
    local pHRP = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
    local bestMob, minDist = nil, math.huge
    for _, mon in ipairs(Server:GetChildren()) do
        if string.find(mon.Name, pattern) then
            local hum = mon:FindFirstChildOfClass("Humanoid")
            local hrp = mon:FindFirstChild("HumanoidRootPart")
            if hum and hum.Health > 0 and hrp then
                if pHRP then
                    local d = (pHRP.Position - hrp.Position).Magnitude
                    if d < minDist then
                        minDist = d
                        bestMob = {Model=mon, HRP=hrp, Humanoid=hum}
                    end
                elseif not bestMob then
                    bestMob = {Model=mon, HRP=hrp, Humanoid=hum}
                end
            end
        end
    end
    return bestMob
end

local function getNearestMonsterInList()
    local char = LP.Character
    local pHRP = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
    local targetMon, nearestDist = nil, math.huge
    for _, mon in ipairs(Server:GetChildren()) do
        local mName = modelNameToDisplay[mon.Name]
        if mName and table.find(selectedMonsters, mName) then
            local hum = mon:FindFirstChildOfClass("Humanoid") or mon:FindFirstChild("Humanoid")
            local hrp = mon:FindFirstChild("HumanoidRootPart") or mon:FindFirstChild("Torso") or mon:FindFirstChild("UpperTorso")
            if hum and hum.Health > 0 and hrp then
                if pHRP then
                    local dist = (pHRP.Position - hrp.Position).Magnitude
                    if dist < nearestDist then nearestDist = dist; targetMon = {Model=mon, HRP=hrp, Humanoid=hum} end
                elseif not targetMon then
                    targetMon = {Model=mon, HRP=hrp, Humanoid=hum}
                end
            end
        end
    end
    return targetMon
end

-- 🛡️ [ฟังก์ชันเช็ค Saviors - ถ้าชื่อเราเข้าไปแล้วแปลว่ายิงติด ไม่ต้องส่งคำสั่งซ้ำให้แลค!]
local function isPlayerInSaviors(targetMonModel)
    if not targetMonModel then return false end
    local saviorsFolder = targetMonModel:FindFirstChild("Saviors")
    if not saviorsFolder then return false end

    local playerName = LP.Name
    for _, val in ipairs(saviorsFolder:GetChildren()) do
        if val:IsA("StringValue") and val.Value == playerName then
            return true
        end
    end
    return false
end

-- ⚔️ [สุดยอดการโจมตี: วาร์ปก่อน -> เช็คระยะ -> ส่งโจมตี 1 นัด (Smart Retry via Saviors)]
local function attackMonster(targetMon, enabledCheckFunc)
    local activeTween = nil
    local lastReqTime = 0
    
    while targetMon and targetMon.Model and targetMon.Model:IsDescendantOf(workspace) and targetMon.Humanoid and targetMon.Humanoid.Health > 0 do
        if enabledCheckFunc and not enabledCheckFunc() then break end

        local char = LP.Character
        local pHRP = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
        if not pHRP then break end
        
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum and not char:FindFirstChildOfClass("Tool") then
            local bpTool = LP.Backpack:FindFirstChildOfClass("Tool")
            if bpTool then hum:EquipTool(bpTool) end
        end
        
        -- 1. วาร์ปเข้าหากลางเป้าหมายตรงๆ (Zero Offset)
        local targetPos = targetMon.HRP.Position
        local destPos = targetPos
        local attackDist = (pHRP.Position - targetPos).Magnitude
        
        if attackDist > 5 then
            if farmMode == "Tp" then
                if activeTween then activeTween:Cancel(); activeTween = nil end
                teleportToPosition(destPos, true)
            elseif farmMode == "Tween" then
                if not activeTween or activeTween.PlaybackState ~= Enum.PlaybackState.Playing then
                    if activeTween then activeTween:Cancel() end
                    activeTween = tweenToPosition(destPos)
                end
            end
        else
            if activeTween then activeTween:Cancel(); activeTween = nil end
        end
        
        -- 2. ระบบโจมตีแม่นยำ (ทำงานเฉพาะตอนไม่ได้เปิด Dmg Boost)
        if attackDist <= 35 and not dmgBoostEnabled then
            -- ถ้าชื่อเรายังไม่ไปโผล่ใน Saviors ของมอนสเตอร์แปลว่าคำสั่งโจมตียังไม่ถึงเซิร์ฟ!
            if not isPlayerInSaviors(targetMon.Model) then
                if os.clock() - lastReqTime >= 0.1 then 
                    lastReqTime = os.clock()
                    task.spawn(function()
                        pcall(function() RequestReq:FireServer(targetMon.Model.Name, "Mouse") end)
                    end)
                end
            end
        end
        task.wait() -- ทำงานลื่นไหลตามเฟรมเรตคอม ไม่มียิงรัวแบบมั่วซั่ว
    end
    if activeTween then activeTween:Cancel() end
end

-- ==========================================
-- [ Event Loops (Raid, Rift, Village, Farm) ]
-- ==========================================
task.spawn(function()
    while task.wait(0.1) do
        local char = LP.Character
        local pHRP = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
        if not pHRP then continue end

        local myData = RS:FindFirstChild("Players_Data") and RS.Players_Data:FindFirstChild(LP.Name)
        local onStageVal = myData and myData:FindFirstChild("Data") and myData.Data:FindFirstChild("OnStage")
        local currentStage = onStageVal and onStageVal.Value or ""

        local riftSpawned, bossSpawned, currentlyInRaid = getPriorityCheck()
        local raidsVisual = workspace:FindFirstChild("Raids_Visual")
        local spawnedRiftsFolder = workspace:FindFirstChild("SpawnedRifts")

        local insideRift, activeRiftFolder = false, nil
        if raidsVisual then
            for _, folder in ipairs(raidsVisual:GetChildren()) do
                if string.find(folder.Name, "Rift") then
                    insideRift, activeRiftFolder = true, folder; break
                end
            end
        end

        local activeRaidFolder = nil
        if raidsVisual then
            for _, f in ipairs(raidsVisual:GetChildren()) do
                if not string.find(f.Name, "Rift") and (string.find(f.Name, "Server_" .. LP.Name) or string.match(f.Name, "Clients_" .. LP.Name)) then
                    activeRaidFolder = f; break
                end
            end
        end

        if activeRiftFolder ~= currentRiftFolder then currentRiftFolder = activeRiftFolder; riftStarted = false end
        if activeRaidFolder ~= currentRaidFolder then currentRaidFolder = activeRaidFolder; raidStarted = false end

        -- [ ระบบ Auto Rift ทะลวงกำแพง ]
        if autoRiftEnabled and riftSpawned then
            if currentlyInRaid then
                pcall(function() RS.Remotes.Systems.RaidsEvent:FireServer("Leave") end)
                smartTeleport("Lobby")
                continue
            end
            
            if insideRift and activeRiftFolder then
                local targetMon = getNearestMobByPattern("Rift")
                if targetMon then
                    attackMonster(targetMon, function() return autoRiftEnabled end)
                else
                    local configs = activeRiftFolder:FindFirstChild("Configs")
                    local others = configs and configs:FindFirstChild("Others")
                    local isRiftClear = false
                    if others then
                        local enemiesVal = others:FindFirstChild("Enemies")
                        if enemiesVal and enemiesVal.Value == 0 then isRiftClear = true end
                    end
                    
                    if isRiftClear and riftStarted then
                        local travelPart = others and others:FindFirstChild("Portal") and others.Portal:FindFirstChild("Travel")
                        if not travelPart then travelPart = activeRiftFolder:FindFirstChild("Travel", true) end
                        if travelPart then
                            local exitPrompt = travelPart:FindFirstChildOfClass("ProximityPrompt")
                            SmartWait(function()
                                exitPrompt = travelPart:FindFirstChildOfClass("ProximityPrompt")
                                return exitPrompt ~= nil
                            end, 3.0)
                            
                            if exitPrompt then
                                local attemptExit = 0
                                while autoRiftEnabled and onStageVal.Value ~= "Lobby" and exitPrompt.Parent and attemptExit < 20 do
                                    local dest = travelPart:IsA("Model") and travelPart:GetPivot().Position or travelPart.Position
                                    teleportToPosition(dest + Vector3.new(0, 3, 0), true)
                                    pcall(function() fireproximityprompt(exitPrompt, 1, true) end)
                                    task.wait(0.5); attemptExit += 1
                                end
                            end
                        end
                        smartTeleport("Lobby")
                        riftStarted = false
                    end
                end
            else
                if spawnedRiftsFolder and #spawnedRiftsFolder:GetChildren() > 0 then
                    local isReaperMap = (currentStage == "Reaper Society")
                    if not isReaperMap and workspace:FindFirstChild("Block_Maps") and workspace.Block_Maps:FindFirstChild("Reaper Society") then
                        isReaperMap = true
                    end

                    if not isReaperMap then
                        if smartTeleport("Lobby") then
                            smartTeleport("Reaper Society")
                        end
                    else
                        for _, riftModel in ipairs(spawnedRiftsFolder:GetChildren()) do
                            while autoRiftEnabled and riftModel.Parent ~= nil do
                                local _isInside = false
                                if workspace:FindFirstChild("Raids_Visual") then
                                    for _, f in ipairs(workspace.Raids_Visual:GetChildren()) do
                                        if string.find(f.Name, "Rift") then _isInside = true; break end
                                    end
                                end
                                if _isInside then break end
                                
                                local rPos = riftModel.PrimaryPart and riftModel.PrimaryPart.Position or riftModel:GetPivot().Position
                                if rPos then teleportToPosition(rPos + Vector3.new(0, 3, 0), true) end
                                
                                local prompt = riftModel:FindFirstChildOfClass("ProximityPrompt", true)
                                if prompt then pcall(function() fireproximityprompt(prompt, 1, true) end) end
                                task.wait(0.2)
                            end
                            break
                        end
                    end
                end
            end

        -- [ ระบบ Auto Raid ]
        elseif autoRaidEnabled and currentlyInRaid then
            local configs = activeRaidFolder:FindFirstChild("Configs")
            local others = configs and configs:FindFirstChild("Others")

            local function countRaidMobs()
                local count = 0
                for _, mon in ipairs(Server:GetChildren()) do
                    if string.find(mon.Name, "Raid") then
                        local hum = mon:FindFirstChildOfClass("Humanoid")
                        local hrp = mon:FindFirstChild("HumanoidRootPart")
                        if hum and hum.Health > 0 and hrp then count += 1 end
                    end
                end
                return count
            end

            local function rewardsReady()
                if not others then return false end
                local rf = others:FindFirstChild("Rewards")
                return rf ~= nil and #rf:GetChildren() > 0
            end

            if not raidStarted then
                SmartWait(function()
                    if not autoRaidEnabled or not currentlyInRaid then return true end
                    if countRaidMobs() > 0 then raidStarted = true; return true end
                    return false
                end, 20.0)

                if not raidStarted then
                    if rewardsReady() then collectBoxes(others, function() return autoRaidEnabled end) end
                    smartTeleport("Lobby")
                    raidStarted = false; currentRaidFolder = nil
                    continue
                end
            end

            local targetMon = getNearestMobByPattern("Raid")

            if targetMon then
                attackMonster(targetMon, function() return autoRaidEnabled end)
            else
                SmartWait(function()
                    if countRaidMobs() > 0 then return true end
                    if rewardsReady() then return true end
                    return false
                end, 15.0)

                if countRaidMobs() == 0 then
                    if rewardsReady() then collectBoxes(others, function() return autoRaidEnabled end) end
                    
                    task.spawn(function()
                        for i = 1, 10 do
                            pcall(function() RS.Remotes.Systems.RaidsEvent:FireServer("Leave") end)
                            pcall(function() ByteNetReq:FireServer(buffer.fromstring(mapBuffers["Lobby"])) end)
                            task.wait(1.0)
                            local curSt = RS:FindFirstChild("Players_Data") and RS.Players_Data:FindFirstChild(LP.Name) and RS.Players_Data[LP.Name]:FindFirstChild("Data") and RS.Players_Data[LP.Name].Data:FindFirstChild("OnStage")
                            if curSt and curSt.Value == "Lobby" then break end
                        end
                    end)
                    
                    raidStarted = false
                    currentRaidFolder = nil
                end
            end

        -- [ ระบบ Auto Abandon Village ]
        elseif autoAbandonVillageEnabled and bossSpawned then
            if currentStage ~= "Demon Forest" then
                smartTeleport("Demon Forest")
            else
                local bossUI = LP.PlayerGui:FindFirstChild("Gamemodes") and LP.PlayerGui.Gamemodes:FindFirstChild("BossFight")
                if not (bossUI and bossUI.Visible == true) then
                    local bossEnterModel = workspace:FindFirstChild("BossFight_Entering") and workspace.BossFight_Entering:FindFirstChild("Demon Forest")
                    if bossEnterModel then
                        local destPos = bossEnterModel:IsA("Model") and (bossEnterModel.PrimaryPart and bossEnterModel.PrimaryPart.Position or bossEnterModel:GetPivot().Position) or bossEnterModel.Position
                        teleportToPosition(destPos + Vector3.new(0, 3, 0), true)
                    end
                else
                    local targetMon = getNearestMobByPattern("BossFight")
                    if targetMon then
                        attackMonster(targetMon, function() return autoAbandonVillageEnabled end)
                    end
                end
            end

        -- [ ระบบย้ายแมพเพื่อลง Raid ]
        elseif autoRaidEnabled and not currentlyInRaid then
            if selectedRaidMap == "Double Dungeons" then
                if currentStage ~= "Dungeons Town" then
                    smartTeleport("Dungeons Town")
                else
                    local raidsEntering = workspace:FindFirstChild("Raids_Entering")
                    if raidsEntering then
                        local specifyPod = raidsEntering:FindFirstChild("Specify")
                        if specifyPod then
                            local curUI = LP.PlayerGui:FindFirstChild("Gamemodes") and LP.PlayerGui.Gamemodes:FindFirstChild("Raids")
                            if not (curUI and curUI.Visible) then
                                local dest = specifyPod:IsA("Model") and (specifyPod.PrimaryPart and specifyPod.PrimaryPart.Position or specifyPod:GetPivot().Position) or specifyPod.Position
                                teleportToPosition(dest + Vector3.new(0, 3, 0), false)
                                pcall(function() RS.Remotes.Systems.RaidsEvent:FireServer(unpack({selectedRaidMap, selectedRaidDifficulty})) end)
                            end
                        end
                    end
                end
            else
                if currentStage ~= "Lobby" then
                    smartTeleport("Lobby")
                else
                    local raidsEntering = workspace:FindFirstChild("Raids_Entering")
                    if raidsEntering then
                        for _, pod in ipairs(raidsEntering:GetChildren()) do
                            if string.find(pod.Name, "Pod") then
                                local curUI = LP.PlayerGui:FindFirstChild("Gamemodes") and LP.PlayerGui.Gamemodes:FindFirstChild("Raids")
                                if not (curUI and curUI.Visible) then
                                    local dest = pod:IsA("Model") and (pod.PrimaryPart and pod.PrimaryPart.Position or pod:GetPivot().Position) or pod.Position
                                    teleportToPosition(dest + Vector3.new(0, 3, 0), false)
                                    pcall(function() RS.Remotes.Systems.RaidsEvent:FireServer(unpack({selectedRaidMap, selectedRaidDifficulty})) end)
                                end
                                break
                            end
                        end
                    end
                end
            end

        -- [ ระบบตีมอนฟาร์มทั่วไป ]
        elseif autoFarmEnabled and selectedMonsters[1] then
            local targetMon = getNearestMonsterInList()
            if targetMon then
                attackMonster(targetMon, function()
                    if not autoFarmEnabled then return false end
                    if (autoRiftEnabled and workspace:FindFirstChild("SpawnedRifts") and #workspace.SpawnedRifts:GetChildren() > 0) then return false end
                    if (autoAbandonVillageEnabled and RS.Values.Gamemodes.BossFights.Bosses.Value ~= "") then return false end
                    if autoRaidEnabled then return false end
                    return true
                end)
            end
        end
    end
end)
