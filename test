--[[
    [FIX RIFT v6] การเปลี่ยนแปลงหลัก:
    1. ใช้ RiftTimeLeft:GetPropertyChangedSignal("Value") แทน polling 0.5s
       → ตอบสนองทันทีเมื่อค่าเปลี่ยน ไม่มี lag
    2. Trigger window: tl > 0 AND tl <= 15
       → จับได้กว้างขึ้น ไม่พลาด window สั้น
    3. วาปไป Reaper Society ทันทีที่ detect ได้
       ไม่รอ confirm ซ้ำ → ถึงก่อนมอน spawn
    4. Anti-re-trigger: cooldown 8s หลังจบ Rift
       ป้องกัน loop ซ้ำจาก TimeLeft ที่เปลี่ยนหลายครั้ง
    5. Cleanup caches ทุกครั้งหลัง TP
]]

local function findNearestRiftMob()
    lastTgtUp = 0
    local hrp=getHRP(); if not hrp then return nil,nil end
    local hPos=hrp.Position; local bestMob,bestPart,bestDistSq=nil,nil,math.huge
    for _,m in next,getSTgts() do
        if m.Name:sub(1,5)=="Rifts" and isMobAlive(m) then
            local pt=m.PrimaryPart or m:FindFirstChild("HumanoidRootPart")
            if pt then
                local d=hPos-pt.Position; local dsq=d.X*d.X+d.Y*d.Y+d.Z*d.Z
                if dsq<bestDistSq then bestDistSq=dsq; bestMob=m; bestPart=pt end
            end
        end
    end
    return bestMob,bestPart
end

local function riftHasLiveMobs()
    lastTgtUp = 0
    for _, m in ipairs(getSTgts()) do
        if m.Name:sub(1,5)=="Rifts" and m.Parent then
            local h = mobHumCache[m]
            if h==nil then h=m:FindFirstChildOfClass("Humanoid"); mobHumCache[m]=h or false end
            if not h or not h.Parent or h.Health<=0 then continue end
            local pp = m.PrimaryPart or m:FindFirstChild("HumanoidRootPart")
            if not pp or not pp.Parent then continue end
            local p = pp.Position
            if p.Y < -200 or (p.X==0 and p.Z==0 and p.Y==0) then continue end
            return true
        end
    end
    return false
end

local function findRiftPortalEntry()
    if not RaidsVisual then return nil, nil end
    for _, f in next, RaidsVisual:GetChildren() do
        if f.Name:sub(1, 20) == "Reaper Society_Rift_" then
            local cfg = f:FindFirstChild("Configs")
            local oth = cfg and cfg:FindFirstChild("Others")
            local por = oth and oth:FindFirstChild("Portal")
            local trv = por and por:FindFirstChild("Travel")
            if trv then
                local prm = trv:FindFirstChildWhichIsA("ProximityPrompt")
                if not prm then
                    for _, v in next, trv:GetDescendants() do
                        if v:IsA("ProximityPrompt") then prm = v; break end
                    end
                end
                local part = nil
                if trv:IsA("BasePart") then part = trv
                elseif trv:IsA("Model") then part = trv.PrimaryPart or trv:FindFirstChildWhichIsA("BasePart")
                else part = trv:FindFirstChildWhichIsA("BasePart") end
                if not part and prm then
                    local pp = prm.Parent
                    if pp and pp:IsA("BasePart") then part = pp
                    elseif pp then part = pp:FindFirstChildWhichIsA("BasePart") end
                end
                if prm then return prm, part end
            end
        end
    end
    return nil, nil
end

-- [FIX RIFT] TP ไป Reaper Society พร้อม confirm ที่รวดเร็ว
local function tpToRiftStage(cancelFn)
    R.Byte:FireServer(teleportBuffers["Reaper Society"])
    lastStgUp = 0
    local deadline  = os.clock() + 20
    local lastSend  = os.clock()
    local confirms  = 0
    local interval  = 0.8
    while os.clock() < deadline do
        if cancelFn and cancelFn() then return false end
        task.wait(0.07); lastStgUp = 0
        if getStg() == "Reaper Society" then
            local char = lp.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hrp.Position.Y > -50 and hum.Health > 0 then
                confirms = confirms + 1
                if confirms >= 2 then return true end  -- [FIX] ลด 3→2 confirm
                task.wait(0.10); continue
            end
        end
        confirms = 0
        if os.clock() - lastSend >= interval then
            R.Byte:FireServer(teleportBuffers["Reaper Society"])
            lastSend = os.clock()
            interval = math.min(interval * 1.3, 3.0)
        end
    end
    return false
end

local function tpToLobbyConfirmed()
    lastStgUp = 0
    if getStg() == "Lobby" then task.wait(0.10); lastStgUp = 0; if getStg() == "Lobby" then return true end end
    local deadline = os.clock() + 15; local lastSend = -99
    while os.clock() < deadline do
        local now = os.clock()
        if now - lastSend >= 1.5 then R.Byte:FireServer(teleportBuffers["Lobby"]); lastSend = now end
        task.wait(0.10); lastStgUp = 0
        if getStg() == "Lobby" then task.wait(0.10); lastStgUp = 0; if getStg() == "Lobby" then return true end end
    end
    return false
end

Tabs.Gen:Toggle({
