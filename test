-- ==========================================
-- DEATH RECOVERY SYSTEM
-- ==========================================
local RECOVERABLE_FLAGS = {
    "AutoClick", "AutoNearest", "AutoSelected",
    "DPSBoost", "SafeBoost",
    "AutoTraits", "AutoSTTraits", "AutoTalent",
    "AutoRift", "AutoAbandon", "AutoRaid", "AutoSummon",
}

local _deathSnapshot = {}
local _isDying       = false

local function snapshotFlags()
    _deathSnapshot = {}
    if not Window or not Window.Flags then return end
    for _, k in ipairs(RECOVERABLE_FLAGS) do
        local fl = Window.Flags[k]
        if fl then
            local ok, val = pcall(function() return fl.Value end)
            _deathSnapshot[k] = (ok and val == true)
        end
    end
end

local function restoreFlags()
    if not Window or not Window.Flags then return end
    local rdl = os.clock() + 15
    while os.clock() < rdl do
        local char = lp.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if hrp and hum and hum.Health > 0 and hrp.Position.Y > -50 then break end
        task.wait(0.15)
    end
    task.wait(0.6)
    lastHRPUp=0; lastPartUp=0; lastStgUp=0; lastTgtUp=0
    unitServerFolder=nil; lastUnitFolderCheck=0
    cachedHRP=nil
    for k in next, mobHumCache     do mobHumCache[k]    = nil end
    for k in next, mobNameCache    do mobNameCache[k]   = nil end
    for k in next, mobDisplayCache do mobDisplayCache[k]= nil end

    for _, k in ipairs(RECOVERABLE_FLAGS) do
        if _deathSnapshot[k] then
            task.wait(0.08)
            pcall(function()
                local fl = Window.Flags[k]
                if fl then fl:Set(true) end
            end)
        end
    end
    _deathSnapshot = {}
    _isDying = false
end

lp.CharacterRemoving:Connect(function()
    if _isDying then return end
    _isDying = true
    snapshotFlags()
    for _, k in ipairs({"clk","atk","sel","raid","near","boss","rift","uInfo"}) do
        if Conns[k] then pcall(function() Conns[k]:Disconnect() end); Conns[k]=nil end
    end
    pcall(stopDPSPrecision)
    if dpsActive then pcall(dpsCleanup) end
    getgenv().safeBoostActive = false
    pcall(function() R.Hatch:FireServer(false) end)

    getgenv().doRift=false;   getgenv().doBoss=false
    getgenv().raidInP=false;  getgenv().raidSt="IDLE"
    getgenv().bossWaiting=false
    getgenv().autoRift=false; getgenv().autoTRun=false
    getgenv().autoTalRun=false; getgenv().autoSTRun=false
    getgenv().autoClick=false; getgenv().autoNearest=false
    getgenv().autoSel=false;  getgenv().autoBoss=false
    getgenv().autoRaid=false; getgenv().autoSummon=false
    getgenv().unitQueue={}; getgenv().traitsDoneSet={}
    getgenv().talentsDoneSet={}; getgenv().stDoneSet={}
    getgenv().rollingFn=nil; getgenv().rollingPhase=""
    dpsCleanup()
    anyEggRef=nil; anyEggInitialized=false
    autoRiftRun=false; summonPaused=false; summonPauseReason=nil
    lastHRPUp=0; lastStgUp=0; unitServerFolder=nil; lastUnitFolderCheck=0
    _lastAtk=0; _lastClk=0

    task.spawn(function()
        lp.CharacterAdded:Wait()
        restoreFlags()
    end)
end)

