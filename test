local function anyTraitsRunning() return getgenv().autoTRun or getgenv().autoSTRun end

local function waitTraitChange(fn, slotKey, oldVal, runFlagFn, timeout)
    local dl = os.clock() + (timeout or 1.5)
    local changed = false
    local conn

    local ff = getUF_fn(fn)
    local to = ff and ff:FindFirstChild(slotKey.."_Trait")
    if to and to:IsA("StringValue") then
        pcall(function()
            conn = to:GetPropertyChangedSignal("Value"):Connect(function()
                if to.Value ~= oldVal then changed = true end
            end)
        end)
    end

    while not changed and os.clock() < dl do
        if not runFlagFn() then break end
        local f2 = getUF_fn(fn)
        local t2 = f2 and f2:FindFirstChild(slotKey.."_Trait")
        if t2 and t2:IsA("StringValue") and t2.Value ~= oldVal then changed = true; break end
        task.wait(0.004)
    end

    if conn then pcall(function() conn:Disconnect() end) end
    return changed
end

local function waitTalentChange(fn, stat, oldVal, runFlagFn, timeout)
    local dl = os.clock() + (timeout or 1.5)
    local changed = false
    local conn

    local ff = getUF_fn(fn)
    local pa = ff and ff:FindFirstChild("Potentials_Adjustment")
    local sv = pa and pa:FindFirstChild(stat)
    if sv then
        pcall(function()
            conn = sv:GetPropertyChangedSignal("Value"):Connect(function()
                if sv.Value ~= oldVal then changed = true end
            end)
        end)
    end

    while not changed and os.clock() < dl do
        if not runFlagFn() then break end
        local f2  = getUF_fn(fn)
        local pa2 = f2 and f2:FindFirstChild("Potentials_Adjustment")
        local sv2 = pa2 and pa2:FindFirstChild(stat)
        if sv2 and sv2.Value ~= oldVal then changed = true; break end
        task.wait(0.004)
    end

    if conn then pcall(function() conn:Disconnect() end) end
    return changed
end

local function rollSlotUntilDone(fn, slotKey, targetList, runFlagFn)
    local ra = {}
    for _,d in ipairs(targetList) do ra[#ra+1] = trD2G[d] or d end

    while runFlagFn() do
        local f = getUF_fn(fn)
        if not f or f.Name ~= fn then return end
        local to = f:FindFirstChild(slotKey.."_Trait")
        if not to or not to:IsA("StringValue") then return end

        if cTrS_fn(fn, slotKey, targetList) then return end

        local old = to.Value
        R.Traits:FireServer(fn, slotKey, ra, false)
        waitTraitChange(fn, slotKey, old, runFlagFn, 1.5)
    end
end

TrSec:Toggle({
    Title="Auto Traits", Flag="AutoTraits", Value=false,
    Callback=function(state)
        getgenv().autoTRun=state
        if not state then return end
        task.spawn(function()
            local queue={}
            for _,e in ipairs(getgenv().unitQueue) do queue[#queue+1]=e end
            if #queue==0 then getgenv().autoTRun=false; return end
            for _,e in ipairs(queue) do getgenv().traitsDoneSet[e.fn]=nil end
            local function subT()  return normalizeMultiVal(getgenv().selSubT  or {}) end
            local function primT() return normalizeMultiVal(getgenv().selPrimT or {}) end
            local function run()   return getgenv().autoTRun end
            if #subT()==0 and #primT()==0 then getgenv().autoTRun=false; return end

            for _,entry in ipairs(queue) do
                if not run() then break end
                local fn=entry.fn; getgenv().rollingFn=fn
                local f=getUF_fn(fn)
                if not f or f.Name~=fn then getgenv().traitsDoneSet[fn]=true; continue end

                local st=subT()
                if #st>0 then
                    getgenv().rollingPhase="SUB"
                    rollSlotUntilDone(fn, "Sub", st, run)
                end
                if not run() then break end

                if #st>0 and not cTrS_fn(fn, "Sub", st) then
                    getgenv().rollingPhase=""
                    continue
                end

                local pt=primT()
                if #pt>0 then
                    getgenv().rollingPhase="PRIMARY"
                    rollSlotUntilDone(fn, "Primary", pt, run)
                end

                getgenv().rollingPhase=""; getgenv().traitsDoneSet[fn]=true
                if getgenv().autoTalRun then
                    local wdl=os.clock()+600
                    while run() and getgenv().autoTalRun and not getgenv().talentsDoneSet[fn] and os.clock()<wdl do
                        task.wait(0.05)
                    end
                end
            end
            getgenv().autoTRun=false; getgenv().rollingPhase=""
            if not anyTraitsRunning() and not getgenv().autoTalRun then getgenv().rollingFn=nil end
        end)
    end
})

