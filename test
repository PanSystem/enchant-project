                        resetRiftDetection(); riftEngaged = false
                        if summonPaused and summonPauseReason == "rift" then
                            summonPaused = false; summonPauseReason = nil
                        end
                        task.wait(1.5); continue
                    end
                    task.wait(0.4)
                    lastHRPUp = 0; lastPartUp = 0
