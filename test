        for _, f in ipairs(raidsVisual:GetChildren()) do
            if not string.find(f.Name, "Rift") and (string.find(f.Name, "Server_" .. LP.Name) or string.find(f.Name, "Clients_" .. LP.Name)) then
                currentlyInRaid = true; break
            end
        end
    end
    
    return riftSpawned, bossSpawned, currentlyInRaid
end

local function findNearestMonsterInList()
    local char = LP.Character
    local pHRP = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
    if not pHRP then return nil end
    
    local targetMon, nearestDist = nil, math.huge
    for _, mon in ipairs(Server:GetChildren()) do
        local mName = modelNameToDisplay[mon.Name]
        if mName and table.find(selectedMonsters, mName) then
            local hum = mon:FindFirstChildOfClass("Humanoid") or mon:FindFirstChild("Humanoid")
            local hrp = mon:FindFirstChild("HumanoidRootPart") or mon:FindFirstChild("Torso") or mon:FindFirstChild("UpperTorso")
            if hum and hum.Health > 0 and hrp then
                local dist = (pHRP.Position - hrp.Position).Magnitude
                if dist < nearestDist then nearestDist = dist; targetMon = {Model=mon, HRP=hrp, Humanoid=hum} end
            end
        end
    end
    return targetMon, nearestDist
end

