local inventoryUnitsList, inventoryUnitsMap = {}, {}
local function RefreshInventoryUnits()
    table.clear(inventoryUnitsList); table.clear(inventoryUnitsMap)
    local nameOccurrences, tempUnits = {}, {}
    local myUnitsFolder = RS:FindFirstChild("Players_Data") and RS.Players_Data:FindFirstChild(LP.Name) and RS.Players_Data[LP.Name]:FindFirstChild("Inventory") and RS.Players_Data[LP.Name].Inventory:FindFirstChild("Units")
    if myUnitsFolder then
        for _, unitFolder in ipairs(myUnitsFolder:GetChildren()) do
            local nicknameVal = unitFolder:FindFirstChild("Nickname")
            local baseName = (nicknameVal and nicknameVal:IsA("StringValue") and nicknameVal.Value ~= "") and nicknameVal.Value or unitFolder.Name
            nameOccurrences[baseName] = (nameOccurrences[baseName] or 0) + 1
            table.insert(tempUnits, {folder = unitFolder, bName = baseName})
        end
        local currentCounts = {}
        for _, uData in ipairs(tempUnits) do
            local bn = uData.bName
            currentCounts[bn] = (currentCounts[bn] or 0) + 1
            local finalName = nameOccurrences[bn] > 1 and (bn .. " " .. currentCounts[bn]) or (bn .. " 1")
            table.insert(inventoryUnitsList, finalName)
            inventoryUnitsMap[finalName] = uData.folder
        end
    end
    table.sort(inventoryUnitsList)
end

local function safeGetVal(parent, name) if parent and parent:FindFirstChild(name) then return tostring(parent[name].Value) end return "N/A" end
local function safeGetNestedVal(parent, folderName, name) local folder = parent and parent:FindFirstChild(folderName) if folder and folder:FindFirstChild(name) then return tostring(folder[name].Value) end return "N/A" end
local function getStatLayoutAndTier(statName, valNumStr)
    local valNum = tonumber(valNumStr); if not valNum then return 0, "N/A" end
    local t = tVL[statName]; local gData = t and t[math.floor(valNum * 10000 + 0.5)] or nil
    if gData then return gData.layout, gData.name end
    local bestLayout, bestTier, minDiff = 0, "N/A", math.huge
    for tier, data in pairs(talent_check) do
        local targetVal = data.Status[statName]
        if targetVal then
            local diff = math.abs(valNum - targetVal)
            if diff < 0.015 and diff < minDiff then minDiff = diff; bestLayout = data.layout; bestTier = tier end
        end
    end
    return bestLayout, bestTier
end

