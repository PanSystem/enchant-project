Tabs.Sum:Toggle({
    Title="Auto Summon Egg", Flag="AutoSummon", Value=false,
    Callback=function(state)
        getgenv().autoSummon = state
        anyEggRef = nil; anyEggInitialized = false
        if not state then
            pcall(sendHatchStop)
            return
        end
        task.spawn(function()
            local function cancelCheck() return not getgenv().autoSummon end
            local targetMap = getgenv().selSumm or "Namex Planet"
            local waitDl = os.clock() + 180
            while os.clock() < waitDl do
                if cancelCheck() then return end
                if not isBusy() then break end
                task.wait(0.3)
            end
            if cancelCheck() then return end
            if getStg() ~= targetMap then
                waitReady(targetMap, 20, teleportBuffers[targetMap], 2.5,
                    function() return not getgenv().autoSummon or isBusy() end)
                task.wait(0.5)
            end
            if cancelCheck() then return end
            sendHatchStart()
            while getgenv().autoSummon do
                if isBusy() or summonPaused then
                    pcall(sendHatchStop)
                    while getgenv().autoSummon and (isBusy() or summonPaused) do
                        task.wait(0.3)
                    end
                    if not getgenv().autoSummon then break end
                    sendHatchStart()
                end
                task.wait(0.1)
            end
            pcall(sendHatchStop)
        end)
    end
})

