    local raidsVisual = workspace:FindFirstChild("Raids_Visual")
    local currentlyInRaid = false
    if raidsVisual then
        for _, f in ipairs(raidsVisual:GetChildren()) do
            if string.match(f.Name, "Rift") then 
                riftSpawned = true 
            elseif string.match(f.Name, "Server_" .. LP.Name) or string.match(f.Name, "Clients_" .. LP.Name) then
