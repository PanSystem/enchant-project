-- ==========================================
local function SmartWait(conditionFunc, timeout)
    local timeoutLimit = timeout or 5.0
    local timeElapsed = 0
    while timeElapsed < timeoutLimit do
        if conditionFunc() then return true end
        timeElapsed = timeElapsed + task.wait()
    end
    return false
end

