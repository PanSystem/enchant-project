                for k in next, mobNameCache    do mobNameCache[k]=nil end
                for k in next, mobDisplayCache do mobDisplayCache[k]=nil end
            end

            -- ── exit rift phase ──────────────────────────────────────
            local function doExitRift()
                stopRiftCombat()
                inRift = false
                getgenv().doRift = false

                local exitDl = os.clock() + 25
                while autoRiftRun and os.clock() < exitDl do
                    lastStgUp = 0
                    if getStg() == "Lobby" then break end
                    local prm, part = findRiftPortalEntry()
                    if prm and prm.Parent and prm.Enabled then
