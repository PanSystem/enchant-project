local function collectBoxes(others, checkFunc)
    if not others then return end
    local rewardsFolder = others:FindFirstChild("Rewards")
    if not rewardsFolder then
        rewardsFolder = others:FindFirstChild("Rewards", true)
    end
    if not rewardsFolder then return end

    local waitDl = os.clock() + 5.0
    while os.clock() < waitDl do
        if checkFunc and not checkFunc() then return end
        if #rewardsFolder:GetChildren() > 0 then break end
        task.wait(0.1)
    end
    if #rewardsFolder:GetChildren() == 0 then return end

    local function findActivePrompt(model)
        if not model or not model.Parent then return nil end
        for _, v in next, model:GetDescendants() do
            if v:IsA("ProximityPrompt") and v.Enabled then return v end
        end
        return nil
    end

    local collectDl = os.clock() + 20.0
    while os.clock() < collectDl do
        if checkFunc and not checkFunc() then return end
        local boxes     = rewardsFolder:GetChildren()
        local anyActive = false

        for _, box in ipairs(boxes) do
            if not box or not box.Parent then continue end
            if collectPurpleChest == "No" and string.lower(box.Name):find("purple") then continue end
            local prm = findActivePrompt(box)
            if not prm or not prm.Enabled then continue end
            anyActive = true
            local part = box.PrimaryPart or box:FindFirstChildWhichIsA("BasePart")
            if not part and prm.Parent and prm.Parent:IsA("BasePart") then part = prm.Parent end
            if not part then continue end
            local targetPos = part.Position + Vector3.new(0, 1.5, 0)
            local pHRP = LP.Character and (LP.Character:FindFirstChild("HumanoidRootPart") or LP.Character:FindFirstChild("Torso"))
            if pHRP then
                pHRP.AssemblyLinearVelocity = Vector3.zero
                pHRP.AssemblyAngularVelocity = Vector3.zero
                pHRP.CFrame = CFrame.new(targetPos)
            end
            local fireDl = os.clock() + 3.0
            while os.clock() < fireDl do
                if checkFunc and not checkFunc() then return end
                if not prm or not prm.Parent or not prm.Enabled then break end
                if not box.Parent then break end
                pHRP = LP.Character and (LP.Character:FindFirstChild("HumanoidRootPart") or LP.Character:FindFirstChild("Torso"))
                if pHRP then
                    local dv = pHRP.Position - part.Position
                    if dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z > 9 then
                        pHRP.AssemblyLinearVelocity = Vector3.zero
                        pHRP.AssemblyAngularVelocity = Vector3.zero
                        pHRP.CFrame = CFrame.new(targetPos)
                    end
                end
                pcall(function() fireproximityprompt(prm, 1, true) end)
                task.wait(0.05)
            end
        end
        if not anyActive then break end
        task.wait(0.05)
    end
end

local function getPriorityCheck()
    local riftSpawned = false
    local spawnedRiftsFolder = workspace:FindFirstChild("SpawnedRifts")
    if spawnedRiftsFolder and #spawnedRiftsFolder:GetChildren() > 0 then riftSpawned = true end
    for _, mon in ipairs(Server:GetChildren()) do
        if string.find(mon.Name, "Rift") then riftSpawned = true; break end
    end
    
    local bossValues = RS:FindFirstChild("Values")
        and RS.Values:FindFirstChild("Gamemodes")
        and RS.Values.Gamemodes:FindFirstChild("BossFights")
        and RS.Values.Gamemodes.BossFights:FindFirstChild("Bosses")
    local bossSpawned = bossValues and bossValues.Value ~= ""
    
    local currentlyInRaid = false
    local raidsVisual = workspace:FindFirstChild("Raids_Visual")
