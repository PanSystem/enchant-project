Tabs.Gen:Section({Title="Auto Rift"})

--[[
    [RIFT v10] ใช้ workspace.SpawnedRifts.RiftModel โดยตรง
    Flow:
    1. ตรวจ RiftTimeLeft window (0 < tl <= 15)
    2. รอ workspace.SpawnedRifts.RiftModel ปรากฏ (max 60s)
       - ถ้าไม่เจอใน 60s → abort รอบนี้
    3. TP ไปที่ RiftModel
    4. Fire ProximityPrompt ใน RiftModel แบบ aggressive (Heartbeat)
       จนกว่า RiftModel จะหายไป
    5. หลัง RiftModel หาย → รอมอน Rifts spawn (max 15s)
    6. ตีมอน Rifts จนหมด → cleanup
    7. Cooldown 5s แล้ว loop ใหม่
]]

-- ── SpawnedRifts helpers ─────────────────────────────────────────────────
local function getSpawnedRifts()
    if SpawnedRiftsFolder and SpawnedRiftsFolder.Parent then return SpawnedRiftsFolder end
    SpawnedRiftsFolder = Workspace:FindFirstChild("SpawnedRifts")
    return SpawnedRiftsFolder
end

-- รอ RiftModel ปรากฏใน SpawnedRifts (signal-based + poll fallback)
local function waitForRiftModel(timeout, cancelFn)
    -- ตรวจทันที
    local sr = getSpawnedRifts()
    if sr then
        local ex = sr:FindFirstChild("RiftModel")
        if ex and ex.Parent then return ex end
    end

    local found   = nil
    local conns   = {}
    local connSR  = nil  -- watch Workspace.ChildAdded เผื่อ SpawnedRifts ยังไม่มี

    local function hookSR(srFolder)
        if not srFolder then return end
        table.insert(conns, srFolder.ChildAdded:Connect(function(child)
            if not found and child.Name == "RiftModel" then
                found = child
            end
        end))
        -- ตรวจซ้ำกรณี spawn ก่อน hook
        local ex2 = srFolder:FindFirstChild("RiftModel")
        if ex2 and ex2.Parent then found = ex2 end
    end

    pcall(function()
        if sr then
            hookSR(sr)
        else
            -- รอ SpawnedRifts เองก่อน
            connSR = Workspace.ChildAdded:Connect(function(child)
                if child.Name == "SpawnedRifts" then
                    SpawnedRiftsFolder = child
                    hookSR(child)
                end
            end)
            table.insert(conns, connSR)
        end
    end)

    local dl = os.clock() + (timeout or 60)
    while not found and os.clock() < dl do
        if cancelFn and cancelFn() then break end
        -- Poll fallback ทุก 0.05s
        local srNow = getSpawnedRifts()
        if srNow then
            local poll = srNow:FindFirstChild("RiftModel")
            if poll and poll.Parent then found = poll; break end
        end
        task.wait(0.05)
    end

    for _, c in ipairs(conns) do pcall(function() c:Disconnect() end) end
    return found
end

-- หา BasePart ของ RiftModel เพื่อ TP ไปหา
local function getRiftModelPart(model)
    if not model or not model.Parent then return nil end
    if model:IsA("BasePart") then return model end
    if model:IsA("Model") then
        local pp = model.PrimaryPart
        if pp and pp.Parent then return pp end
        local hrp = model:FindFirstChild("HumanoidRootPart")
        if hrp and hrp.Parent then return hrp end
        local bp = model:FindFirstChildWhichIsA("BasePart", true)
        if bp then return bp end
        -- fallback: GetPivot position
        return nil  -- จะใช้ GetPivot แทน
    end
    return model:FindFirstChildWhichIsA("BasePart", true)
end

-- หา ProximityPrompt ใน RiftModel (ตรงกับ explorer: ProximityPrompt เป็น child โดยตรง)
local function findRiftProxPrompt(model)
    if not model or not model.Parent then return nil end
    -- 1. Direct child (ตามที่เห็นใน explorer)
    local pp = model:FindFirstChildOfClass("ProximityPrompt")
    if pp then return pp end
    -- 2. Model subfolder
    local sub = model:FindFirstChild("Model")
    if sub then
        pp = sub:FindFirstChildOfClass("ProximityPrompt")
        if pp then return pp end
        for _, v in next, sub:GetDescendants() do
            if v:IsA("ProximityPrompt") then return v end
        end
    end
    -- 3. Full descendants
    for _, v in next, model:GetDescendants() do
        if v:IsA("ProximityPrompt") then return v end
    end
    return nil
end

-- รอ RiftModel หายไป (AncestryChanged signal + poll)
local function waitRiftModelGone(model, timeout, cancelFn)
    if not model or not model.Parent then return true end
    local gone = false
    local conn = nil
    pcall(function()
        conn = model.AncestryChanged:Connect(function(_, newParent)
            if not newParent then gone = true end
        end)
    end)
    local dl = os.clock() + (timeout or 120)
    while not gone and os.clock() < dl do
        if cancelFn and cancelFn() then break end
        if not model.Parent then gone = true; break end
        task.wait(0.04)
    end
    if conn then pcall(function() conn:Disconnect() end) end
    return gone
end

-- ── Rift mob helpers (Rifts prefix, bypass cache ทั้งหมด) ───────────────
-- [v10] isRiftMobValid: Rifts prefix + BossFight prefix (Rift boss)
-- BossFight ใน Rift จะอยู่ใน ServerTargets และมีชื่อขึ้นต้น "BossFight"
local function isRiftMobValid(m)
    if not m or not m.Parent then return false end
    local nm = m.Name
    local isRiftMon  = nm:sub(1, 5) == "Rifts"
    local isRiftBoss = nm:sub(1, 9) == "BossFight"
    if not isRiftMon and not isRiftBoss then return false end
    local h = m:FindFirstChildOfClass("Humanoid")
    if not h or h.Health <= 0 then return false end
    local pt = m.PrimaryPart or m:FindFirstChild("HumanoidRootPart")
    if not pt then
        for _, v in next, m:GetDescendants() do
            if v:IsA("BasePart") then pt = v; break end
        end
    end
    if not pt then return false end
    local p = pt.Position
    if p.Y < -200 then return false end
    if math.abs(p.X) < 0.001 and math.abs(p.Z) < 0.001 and math.abs(p.Y) < 0.001 then return false end
    mobHumCache[m] = h
    return true
end

local function getRiftMobPart(m)
    if not m or not m.Parent then return nil end
    local pp = m.PrimaryPart
    if pp and pp.Parent then return pp end
    local hrp = m:FindFirstChild("HumanoidRootPart")
    if hrp and hrp.Parent then return hrp end
    for _, v in next, m:GetDescendants() do
        if v:IsA("BasePart") and v.Parent then return v end
    end
    return nil
end

local function findNearestRiftMob()
    -- Force fresh scan ทุกครั้ง
    lastTgtUp = 0
    local all = ServerTargets:GetChildren()
    cachedTargets = all
    local hrp = getHRP(); if not hrp then return nil, nil end
    local hPos = hrp.Position
    local best, bestPt, bestSq = nil, nil, math.huge
    for _, m in next, all do
        if isRiftMobValid(m) then
            local pt = getRiftMobPart(m)
            if pt then
                local d = hPos - pt.Position
                local dsq = d.X*d.X + d.Y*d.Y + d.Z*d.Z
                if dsq < bestSq then bestSq = dsq; best = m; bestPt = pt end
            end
        end
    end
    return best, bestPt
end

local function riftHasLiveMobs()
    lastTgtUp = 0
    local all = ServerTargets:GetChildren()
    cachedTargets = all
    for _, m in next, all do
        if isRiftMobValid(m) then return true end
    end
    return false
end

local function flushAllCaches()
    lastTgtUp = 0; lastHRPUp = 0; lastPartUp = 0
    for k in next, mobHumCache     do mobHumCache[k]    = nil end
    for k in next, mobNameCache    do mobNameCache[k]   = nil end
    for k in next, mobDisplayCache do mobDisplayCache[k]= nil end
end

-- ── Main Toggle ──────────────────────────────────────────────────────────
Tabs.Gen:Toggle({
    Title="Auto Rift", Flag="AutoRift", Value=false,
    Callback=function(state)
        getgenv().autoRift = state; autoRiftRun = state
        if not state then
            getgenv().doRift = false
            if Conns.rift then Conns.rift:Disconnect(); Conns.rift = nil end
            if summonPaused and summonPauseReason == "rift" then
                summonPaused = false; summonPauseReason = nil
            end
            return
        end

        task.spawn(function()
            local inRift      = false
            local lastRiftEnd = 0

            -- ── Signal watcher ────────────────────────────────────────
            local riftSig     = false
            local riftSigConn = nil
            pcall(function()
                riftSigConn = RiftTimeLeft:GetPropertyChangedSignal("Value"):Connect(function()
                    if not autoRiftRun or inRift then return end
                    local tl = getRiftTimeLeft()
                    if tl > 0 and tl <= 15 then riftSig = true end
                end)
            end)

            local function cancelFn()
                return not autoRiftRun or not getgenv().autoRift
            end

            -- ── Cleanup state ─────────────────────────────────────────
            local function doCleanup()
                if Conns.rift then Conns.rift:Disconnect(); Conns.rift = nil end
                inRift           = false
                getgenv().doRift = false
                lastRiftEnd      = os.clock()
                if summonPaused and summonPauseReason == "rift" then
                    summonPaused = false; summonPauseReason = nil
                end
            end

            -- ────────────────────────────────────────────────────────
            -- MAIN LOOP
            -- ────────────────────────────────────────────────────────
            while autoRiftRun do
                if not getgenv().autoRift then break end

                -- Cooldown หลัง rift จบ
                local cd = (lastRiftEnd + 5.0) - os.clock()
                if cd > 0 then task.wait(math.min(cd, 0.3)); continue end

                -- ตรวจ window ปัจจุบัน
                local tlNow    = getRiftTimeLeft()
                local inWindow = tlNow > 0 and tlNow <= 15

                if not inWindow then
                    -- รอ signal
                    riftSig = false
                    while autoRiftRun and not riftSig do
                        task.wait(0.08)
                        if not getgenv().autoRift then break end
                        local tl2 = getRiftTimeLeft()
                        if tl2 > 0 and tl2 <= 15 then riftSig = true; break end
                    end
                    if cancelFn() then break end
                    tlNow    = getRiftTimeLeft()
                    inWindow = tlNow > 0 and tlNow <= 15
                    if not inWindow then continue end
                end
                riftSig = false

                -- หยุด Raid ถ้ากำลังทำอยู่
                if getgenv().raidInP then
                    local rDl = os.clock() + 5
                    while getgenv().raidInP and os.clock() < rDl do task.wait(0.06) end
                    if getRaidSession() then
                        pcall(function() R.RaidsL:FireServer("Leave") end)
                        task.wait(0.3); getgenv().raidInP = false
                    end
                end

                inRift            = true
                getgenv().doRift  = true
                summonPaused      = true
                summonPauseReason = "rift"

                -- ══════════════════════════════════════════════════════
                -- PHASE 1: รอ RiftModel ปรากฏ (max 60s)
                -- ══════════════════════════════════════════════════════
                local riftModel = waitForRiftModel(60, cancelFn)

                if not riftModel or cancelFn() then
                    doCleanup(); task.wait(2.0); continue
                end

                -- TP ไปที่ RiftModel
                do
                    local rPart = getRiftModelPart(riftModel)
                    local hrpNow = getHRP()
                    if hrpNow then
                        if rPart then
                            for _ = 1, 3 do
                                killVelocity(hrpNow)
                                hrpNow.CFrame = CFrame.new(rPart.Position)
                                task.wait(0.04)
                            end
                        else
                            -- Fallback: GetPivot
                            pcall(function()
                                local pivot = riftModel:GetPivot()
                                for _ = 1, 3 do
                                    killVelocity(hrpNow)
                                    hrpNow.CFrame = pivot
                                    task.wait(0.04)
                                end
                            end)
                        end
                    end
                end

                if cancelFn() then doCleanup(); continue end

                -- ══════════════════════════════════════════════════════
                -- PHASE 2: Fire ProximityPrompt จนกว่า RiftModel หายไป
                -- ══════════════════════════════════════════════════════
                local prompt        = findRiftProxPrompt(riftModel)
                local rPartRef      = getRiftModelPart(riftModel)
                local promptActive  = true
                local promptFireConn = nil

                promptFireConn = RunService.Heartbeat:Connect(function()
                    if not promptActive then return end
                    if not riftModel or not riftModel.Parent then
                        promptActive = false; return
                    end

                    -- Refresh prompt หาก หาย
                    if not prompt or not prompt.Parent then
                        prompt = findRiftProxPrompt(riftModel)
                    end

                    -- Refresh rPart หาก หาย
                    if not rPartRef or not rPartRef.Parent then
                        rPartRef = getRiftModelPart(riftModel)
                    end

                    -- Snap ติดกับ RiftModel ตลอดเวลา
                    local hrp = getHRP()
                    if hrp and rPartRef and rPartRef.Parent then
                        local dv = hrp.Position - rPartRef.Position
                        if dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z > 4 then
                            killVelocity(hrp)
                            hrp.CFrame = CFrame.new(rPartRef.Position)
                        end
                    end

                    -- Fire ProximityPrompt
                    if prompt and prompt.Parent then
                        pcall(function() fireproximityprompt(prompt) end)
                    end
                end)

                -- รอ RiftModel หายไป (max 120s)
                waitRiftModelGone(riftModel, 120, cancelFn)

                -- หยุด fire
                promptActive = false
                if promptFireConn then
                    pcall(function() promptFireConn:Disconnect() end)
                    promptFireConn = nil
                end

                if cancelFn() then doCleanup(); continue end

                -- flush caches หลัง model หาย
                flushAllCaches()
                task.wait(0.3)

                -- ══════════════════════════════════════════════════════
                -- PHASE 3: รอ Rifts mobs spawn (max 15s)
                -- ══════════════════════════════════════════════════════
                local mobFound  = false
                local mobWaitDl = os.clock() + 15
                while os.clock() < mobWaitDl and autoRiftRun do
                    if riftHasLiveMobs() then mobFound = true; break end
                    task.wait(0.06)
                end

                if not mobFound or cancelFn() then
                    doCleanup(); task.wait(2.0); continue
                end

                -- Snap ไปมอนแรก + fire init attack
                local initMob, initPart = findNearestRiftMob()
                if initPart then
                    local hrpNow = getHRP()
                    if hrpNow then
                        for _ = 1, 3 do
                            killVelocity(hrpNow)
                            hrpNow.CFrame = CFrame.new(initPart.Position)
                            task.wait(0.02)
                        end
                    end
                end
                sendAtk(); sendClk()
                if initMob then
                    pcall(function() R.Req:FireServer(initMob.Name, "Mouse") end)
                end

                -- Re-equip DPS units ก่อน combat
                if dpsActive then
                    for _ = 1, 3 do
                        pcall(function() R.Byte:FireServer(buffer.fromstring("\026\000")) end)
                        task.wait(0.02)
                    end
                end

                -- ══════════════════════════════════════════════════════
                -- PHASE 4: Combat (Heartbeat)
                -- ══════════════════════════════════════════════════════
                if Conns.rift then Conns.rift:Disconnect() end

                local cRiftMob, cRiftPart = initMob, initPart
                local _reqLast   = 0
                local _scanTick  = 0
                local _reEqLast  = 0
                local _stuckCnt  = 0

                Conns.rift = RunService.Heartbeat:Connect(function()
                    if not autoRiftRun or not getgenv().autoRift then return end
                    local now = os.clock()

                    sendAtk(); sendClk()

                    -- Validate mob
                    if cRiftMob then
                        if not cRiftMob.Parent or not isRiftMobValid(cRiftMob) then
                            cRiftMob = nil; cRiftPart = nil
                        else
                            local newPt = getRiftMobPart(cRiftMob)
                            if newPt and newPt.Parent then cRiftPart = newPt end
                        end
                    end

                    -- Rescan ทุก 2 frame
                    _scanTick = _scanTick + 1
                    if not cRiftMob and _scanTick % 2 == 0 then
                        cRiftMob, cRiftPart = findNearestRiftMob()
                    end

                    -- Stuck detection: ถ้าหามอบไม่เจอนาน → flush cache
                    if not cRiftMob then
                        _stuckCnt = _stuckCnt + 1
                        if _stuckCnt >= 120 then
                            _stuckCnt = 0
                            flushAllCaches()
                            cRiftMob, cRiftPart = findNearestRiftMob()
                        end
                        return
                    else
                        _stuckCnt = 0
                    end

                    if not cRiftPart then
                        cRiftPart = getRiftMobPart(cRiftMob)
                        if not cRiftPart then cRiftMob = nil; return end
                    end

                    local hrp = getHRP(); if not hrp then return end
                    -- Snap ตรงไปมอน ทุก frame (aggressive)
                    killVelocity(hrp)
                    hrp.CFrame = CFrame.new(cRiftPart.Position)

                    -- Fire R.Req โดยตรง (rate 0.03s)
                    if now - _reqLast >= 0.03 then
                        _reqLast = now
                        R.Req:FireServer(cRiftMob.Name, "Mouse")
                        pendingRequests[cRiftMob] = now
                    end

                    -- Re-equip DPS watchdog ทุก 2.5s
                    if dpsActive and now - _reEqLast >= 2.5 then
                        _reEqLast = now
                        pcall(function() R.Byte:FireServer(buffer.fromstring("\026\000")) end)
                    end
                end)

                -- ── รอมอนหมด (confirm 4 ครั้ง) ───────────────────────
                local combatDl   = os.clock() + 300
                local noMobTick  = 0
                while autoRiftRun and os.clock() < combatDl do
                    task.wait(0.08)
                    if not riftHasLiveMobs() then
                        noMobTick = noMobTick + 1
                        if noMobTick >= 4 then break end
                    else
                        noMobTick = 0
                    end
                end

                -- Cleanup combat
                if Conns.rift then Conns.rift:Disconnect(); Conns.rift = nil end
                cRiftMob = nil; cRiftPart = nil
                doCleanup()
                task.wait(0.5)
            end

            -- Final cleanup
            if riftSigConn then pcall(function() riftSigConn:Disconnect() end) end
            if Conns.rift   then Conns.rift:Disconnect(); Conns.rift = nil end
            getgenv().doRift = false
            if summonPaused and summonPauseReason == "rift" then
                summonPaused = false; summonPauseReason = nil
            end
        end)
    end
})

