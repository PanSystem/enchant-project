local function GetCleanArray(val)
    local res = {}
    if type(val) == "table" then
        for k, v in pairs(val) do
            if type(k) == "number" and type(v) == "string" then table.insert(res, v)
            elseif type(k) == "string" and v == true then table.insert(res, k)
            elseif type(k) == "string" and type(v) == "string" then table.insert(res, v)
            end
        end
    elseif type(val) == "string" and val ~= "" then
        table.insert(res, val)
    end
    return res
end

