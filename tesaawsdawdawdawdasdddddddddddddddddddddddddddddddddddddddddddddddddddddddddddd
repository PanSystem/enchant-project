-- Helper Functions for Traits/Talents
local function safeGetVal(parent, name)
    return (parent and parent:FindFirstChild(name)) and tostring(parent[name].Value) or "N/A"
end

local function safeGetNestedVal(parent, folderName, name)
    local folder = parent and parent:FindFirstChild(folderName)
    return (folder and folder:FindFirstChild(name)) and tostring(folder[name].Value) or "N/A"
end

local function getStatLayoutAndTier(statName, valNumStr)
    local valNum = tonumber(valNumStr)
    if not valNum then return 0, "N/A" end
    local t = tVL[statName]
    local gData = t and t[math.floor(valNum * 10000 + 0.5)]
    if gData then return gData.layout, gData.name end
    
    local bestLayout, bestTier, minDiff = 0, "N/A", math.huge
    for tier, data in pairs(talent_check) do
        local targetVal = data.Status[statName]
        if targetVal then
            local diff = math.abs(valNum - targetVal)
            if diff < 0.015 and diff < minDiff then minDiff = diff; bestLayout = data.layout; bestTier = tier end
        end
    end
    return bestLayout, bestTier
end

local function waitTalentChange(unitFolder, statName, oldVal)
    local t = os.clock()
    while os.clock() - t < 1.5 do
        local newVal = safeGetNestedVal(unitFolder, "Potentials_Adjustment", statName)
        if newVal == "N/A" then
            if statName == "Abilities_DMG" then newVal = safeGetVal(unitFolder, "Ability_Talent")
            elseif statName == "Critical_Damage" then newVal = safeGetVal(unitFolder, "Critical_Talent")
            else newVal = safeGetVal(unitFolder, statName .. "_Talent") end
        end
        if newVal ~= "N/A" and newVal ~= oldVal then return true end
        task.wait(0.05)
    end
    return false
end

local function waitTraitChange(unitFolder, slotToRoll, oldVal)
    local traitNode = slotToRoll == "Primary" and "Primary" or "Sub"
    local legacyNode = slotToRoll == "Primary" and "Primary_Trait" or "Sub_Trait"
    local t = os.clock()
    while os.clock() - t < 1.5 do
        local newVal = safeGetNestedVal(unitFolder, "Traits", traitNode)
        if newVal == "N/A" then newVal = safeGetVal(unitFolder, legacyNode) end
        if newVal ~= "N/A" and newVal ~= oldVal then return true end
        task.wait(0.05)
    end
    return false
end

local function getUnitInfoText(unitFolder)
    if not unitFolder then return "No unit selected." end
    local nickName = safeGetVal(unitFolder, "Nickname")
    if nickName == "N/A" then nickName = unitFolder.Name end
    local level = safeGetVal(unitFolder, "Level")
    
    local traitPrimary = safeGetNestedVal(unitFolder, "Traits", "Primary")
    if traitPrimary == "N/A" then traitPrimary = safeGetVal(unitFolder, "Primary_Trait") end
    local traitSub = safeGetNestedVal(unitFolder, "Traits", "Sub")
    if traitSub == "N/A" then traitSub = safeGetVal(unitFolder, "Sub_Trait") end
    
    local talDmgRaw = safeGetNestedVal(unitFolder, "Potentials_Adjustment", "Damage")
    if talDmgRaw == "N/A" then talDmgRaw = safeGetVal(unitFolder, "Damage_Talent") end
    local _, talDmg = getStatLayoutAndTier("Damage", talDmgRaw)
    
    local talAbilRaw = safeGetNestedVal(unitFolder, "Potentials_Adjustment", "Abilities_DMG")
    if talAbilRaw == "N/A" then talAbilRaw = safeGetVal(unitFolder, "Ability_Talent") end
    local _, talAbil = getStatLayoutAndTier("Abilities_DMG", talAbilRaw)
    
    local talCritRaw = safeGetNestedVal(unitFolder, "Potentials_Adjustment", "Critical_Damage")
    if talCritRaw == "N/A" then talCritRaw = safeGetVal(unitFolder, "Critical_Talent") end
    local _, talCrit = getStatLayoutAndTier("Critical_Damage", talCritRaw)
    
    local talSpdRaw = safeGetNestedVal(unitFolder, "Potentials_Adjustment", "Speed")
    if talSpdRaw == "N/A" then talSpdRaw = safeGetVal(unitFolder, "Speed_Talent") end
    local _, talSpd = getStatLayoutAndTier("Speed", talSpdRaw)

    local info = string.format(
        "Name units : %s\nLevel Units : %s\n--- Traits ---\nPrimary > %s\nSub > %s\n--- Talents ---\nDamage > %s\nAbility Damage > %s\nCritical > %s\nSpeed > %s",
        nickName, level, traitPrimary, traitSub, talDmg, talAbil, talCrit, talSpd
    )
    
    info = info .. "\n\n--- Queue Status ---"
    if #selectedInventoryUnits > 0 then
        for i, uName in ipairs(selectedInventoryUnits) do
            local state = unitStates[uName] or "waiting"
            local emoji = (state == "done") and "✅" or (state == "rolling" and "🔄" or "⏸️")
            info = info .. string.format("\n%d. %s [%s]", i, uName, emoji)
        end
    else
        info = info .. "\nNone"
    end
    return info
end

local function setAutoAttackState(state)
    pcall(function()
        local pData = RS:FindFirstChild("Players_Data")
        if pData then
            local myDataNode = pData:FindFirstChild(LP.Name)
            if myDataNode and myDataNode:FindFirstChild("Data") then
                local autoAtk = myDataNode.Data:FindFirstChild("Auto_Attacks")
                if autoAtk and autoAtk:IsA("BoolValue") then autoAtk.Value = state end
            end
        end
    end)
end

local function checkAndAttackAllMonsters()
    if not dmgBoostEnabled then return end
    local t = tick()
    if t - lastAttackTime < 0.05 then return end
    
    local myFolder = UnitsServer:FindFirstChild(LP.Name)
    if not myFolder then return end
    
    local hasDebounceTrue = false
    for _, unit in ipairs(myFolder:GetChildren()) do
        local debounce = unit:FindFirstChild("Debounce")
        if debounce and debounce.Value == true then
            hasDebounceTrue = true; break
        end
    end
    
    if hasDebounceTrue then
        lastAttackTime = t
        pcall(function() ByteNetReq:FireServer(attackBuffer) end)
    end
end

local function setupDamageBoostForUnit(unit)
    if dmgBoostConnections[unit] then return end
    local debounce = unit:WaitForChild("Debounce", 1)
    if debounce then
        local conn = debounce:GetPropertyChangedSignal("Value"):Connect(function()
            if debounce.Value == true then checkAndAttackAllMonsters() end
        end)
        dmgBoostConnections[unit] = conn
    end
end

