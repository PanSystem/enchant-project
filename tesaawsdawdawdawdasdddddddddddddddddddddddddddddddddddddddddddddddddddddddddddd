-- Unified Remote Execute Loop: Auto Traits / Talents
task.spawn(function()
    while task.wait(0.1) do
        if not (autoTraitsEnabled or autoTalentsEnabled) or #selectedInventoryUnits == 0 then continue end

        local activeUnitDisp = nil
        for _, uName in ipairs(selectedInventoryUnits) do
            if unitStates[uName] ~= "done" then activeUnitDisp = uName; break end
        end
        if not activeUnitDisp then continue end

        local activeUnit = inventoryUnitsMap[activeUnitDisp]
        if not activeUnit or not activeUnit.Parent then unitStates[activeUnitDisp] = "done"; continue end
        
        unitStates[activeUnitDisp] = "rolling"

        local _tTraits = targetTraits or {}
        local _tTalents = targetTalents or {}

        local traitsDone = not autoTraitsEnabled or #_tTraits == 0
        local talentsDone = not autoTalentsEnabled or #_tTalents == 0

        -- Auto Traits
        if not traitsDone then
            local currentPri = safeGetNestedVal(activeUnit, "Traits", "Primary")
            if currentPri == "N/A" then currentPri = safeGetVal(activeUnit, "Primary_Trait") end
            local currentSub = safeGetNestedVal(activeUnit, "Traits", "Sub")
            if currentSub == "N/A" then currentSub = safeGetVal(activeUnit, "Sub_Trait") end
            
            local internalTargets = {}
            for _, t in ipairs(_tTraits) do
                if trait_check[t] then internalTargets[trait_check[t]] = t end
            end
            
            local priGood = internalTargets[currentPri] ~= nil
            local subGood = internalTargets[currentSub] ~= nil
            local slotToRoll = nil
            local validArgs  = {}

            if #_tTraits == 1 then
                if priGood or subGood then traitsDone = true else
                    slotToRoll = (math.random() > 0.5) and "Primary" or "Sub"
                    local iName = trait_check[_tTraits[1]]
                    if iName then validArgs = {iName, iName} end
                end
            elseif #_tTraits >= 2 then
                if priGood and subGood and currentPri ~= currentSub then traitsDone = true
                elseif priGood and not subGood then
                    slotToRoll = "Sub"
                    for iName, _ in pairs(internalTargets) do if iName ~= currentPri then table.insert(validArgs, iName) end end
                elseif subGood and not priGood then
                    slotToRoll = "Primary"
                    for iName, _ in pairs(internalTargets) do if iName ~= currentSub then table.insert(validArgs, iName) end end
                elseif priGood and subGood and currentPri == currentSub then
                    slotToRoll = "Sub"
                    for iName, _ in pairs(internalTargets) do if iName ~= currentPri then table.insert(validArgs, iName) end end
                else
                    slotToRoll = "Primary"
                    for iName, _ in pairs(internalTargets) do table.insert(validArgs, iName) end
                end
                
                if #validArgs == 0 then traitsDone = true end
                if #validArgs == 1 then table.insert(validArgs, validArgs[1]) end
            end
            
            if not traitsDone and slotToRoll and #validArgs >= 2 then
                local oldVal = (slotToRoll == "Primary") and currentPri or currentSub
                pcall(function() Gamblings.Traits:FireServer(activeUnit.Name, slotToRoll, validArgs, false) end)
                waitTraitChange(activeUnit, slotToRoll, oldVal)
                continue
            end
        end

        -- Auto Talents
        if traitsDone and not talentsDone then
            local targetLayout = (talent_check[targetTalentTier] and talent_check[targetTalentTier].layout) or 0
            local slotToRollTalent, oldValForRoll = nil, nil
            
            for _, uiTalent in ipairs(_tTalents) do
                local remStatName = talentUIToRemote[uiTalent]
                if not remStatName then continue end
                local valStr = safeGetNestedVal(activeUnit, "Potentials_Adjustment", remStatName)
                if valStr == "N/A" then
                    if remStatName == "Abilities_DMG" then valStr = safeGetVal(activeUnit, "Ability_Talent")
                    elseif remStatName == "Critical_Damage" then valStr = safeGetVal(activeUnit, "Critical_Talent")
                    else valStr = safeGetVal(activeUnit, remStatName .. "_Talent") end
                end
                
                local l, _ = getStatLayoutAndTier(remStatName, valStr)
                if l < targetLayout then
                    slotToRollTalent = remStatName
                    oldValForRoll = valStr
                    break
                end
            end
            
            if not slotToRollTalent then talentsDone = true else
                pcall(function() Systems.Potentials_Rolling:FireServer(activeUnit.Name, "Reroll", slotToRollTalent) end)
                waitTalentChange(activeUnit, slotToRollTalent, oldValForRoll)
                continue
            end
        end

        if traitsDone and talentsDone then
            unitStates[activeUnitDisp] = "done"
            task.wait(0.5)
        end
    end
end)

