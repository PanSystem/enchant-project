local function collectRaidChests(others)
    if raidCollecting then return end
    raidCollecting = true
    local rewardsFolder = others and others:FindFirstChild("Rewards")
    if not rewardsFolder then raidCollecting = false; raidChestDone = true; return end

    local resultList = {}
    local function scanChests(folder)
        if not folder or not folder.Parent then return end
        for _,obj in ipairs(folder:GetChildren()) do
            if collectPurpleChest == "No" and string.find(string.lower(obj.Name), "purple", 1, true) then continue end
            local prm = obj:FindFirstChildWhichIsA("ProximityPrompt",true)
            if prm and prm.Enabled then
                local part = getPromptBasePart(prm)
                if part and part.Parent then table.insert(resultList,{prm=prm,part=part}) end
            end
            if obj:IsA("Folder") or obj:IsA("Model") then scanChests(obj) end
        end
    end
    scanChests(rewardsFolder)

    local ch0 = LP.Character; local ref = (ch0 and ch0:FindFirstChild("HumanoidRootPart")) and ch0.HumanoidRootPart.Position or Vector3.zero
    table.sort(resultList,function(a,b)
        local pa = (a.part and a.part.Parent) and a.part.Position or Vector3.zero
        local pb = (b.part and b.part.Parent) and b.part.Position or Vector3.zero
        return (ref-pa).Magnitude < (ref-pb).Magnitude
    end)

    for _,chest in ipairs(resultList) do
        if not autoRaidEnabled then break end 
        local prm, part = chest.prm, chest.part
        if not prm or not prm.Parent or not part or not part.Parent then continue end
        local tries = 0
        while autoRaidEnabled and prm and prm.Parent and prm.Enabled and tries < 30 do
            tries = tries+1
            local ch = LP.Character; local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
            if hrp and part.Parent then
                local dv = hrp.Position-part.Position
                if dv.Magnitude > 20 then 
                    teleportToPosition(part.Position, true)
                end
            end
            pcall(function() fireproximityprompt(prm, 1, true) end)
            task.wait(0.1)
        end
        task.wait(0.04)
    end
    
    raidCollecting = false
    if not autoRaidEnabled then return end 
    raidChestDone = true
end

local function handleRaidEnd(tPP, tPart)
    if raidExiting then return end
    raidExiting = true
    
    local victoryTime = nil
    local actionTaken = false
    local deadline = os_clock() + 45 
    
    while autoRaidEnabled and os_clock() < deadline do
        local victoryUI = LP.PlayerGui:FindFirstChild("Victory")
        
        if victoryUI and victoryUI:IsA("ScreenGui") and victoryUI.Enabled then
            if not victoryTime then victoryTime = os_clock() end
            
            if os_clock() - victoryTime >= 30 then
                pcall(function() RS.Remotes.Gameplays.RaidAction:FireServer("Leave") end)
                actionTaken = true
                task.wait(3)
                break
            end
            
            if autoReplayEnabled then
                pcall(function() RS.Remotes.Gameplays.RaidAction:FireServer("Replay") end)
                actionTaken = true
                task.wait(3) 
                break
            elseif autoLeaveEnabled then
                pcall(function() RS.Remotes.Gameplays.RaidAction:FireServer("Leave") end)
                actionTaken = true
                task.wait(3) 
                break
            end
        else
            if tPP and tPP.Parent and tPP.Enabled then
                local ch = LP.Character
                local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
                if hrp and tPart and tPart.Parent then
                    local dv = hrp.Position - tPart.Position
                    if dv.Magnitude > 5 then
                        teleportToPosition(tPart.Position + Vector3.new(0, 1.5, 0), true)
                    end
                end
                pcall(function() fireproximityprompt(tPP, 1, true) end)
            end
        end
        
        task.wait(0.2)
    end
    
    currentRaidFolder = nil
    raidChestDone = false
    raidCollecting = false
    raidExiting = false
    raidTransitionTime = 0 
end

local function findNearestMonsterInList()
    local char = LP.Character
    local pHRP = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
    if not pHRP then return nil end
    local targetMon, nearestDist = nil, math.huge
    for _,mon in ipairs(Server:GetChildren()) do
        local mName = modelNameToDisplay[mon.Name]
        if mName and table_find(selectedMonsters,mName) then
            local hum = mon:FindFirstChildOfClass("Humanoid") or mon:FindFirstChild("Humanoid")
            local hrp = mon:FindFirstChild("HumanoidRootPart") or mon:FindFirstChild("Torso") or mon:FindFirstChild("UpperTorso")
            if hum and hum.Health > 0 and hrp then
                local dist = (pHRP.Position-hrp.Position).Magnitude
                if dist < nearestDist then nearestDist = dist; targetMon = {Model=mon,HRP=hrp,Humanoid=hum} end
            end
        end
    end
    return targetMon, nearestDist
end

