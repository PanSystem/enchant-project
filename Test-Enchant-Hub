local function getPromptBasePart(prm)
    if not prm then return nil end
    local p = prm.Parent; if not p then return nil end
    if p:IsA("BasePart") then return p end
    if p:IsA("Model") then
        if p.PrimaryPart then return p.PrimaryPart end
        return p:FindFirstChildWhichIsA("BasePart",true)
    end
    local gp = p.Parent
    if gp then
        if gp:IsA("BasePart") then return gp end
        if gp:IsA("Model") then
            if gp.PrimaryPart then return gp.PrimaryPart end
            return gp:FindFirstChildWhichIsA("BasePart",true)
        end
    end
    return nil
end

