local function safeGetVal(parent,name)
    if not parent then return "N/A" end
    local obj = parent:FindFirstChild(name)
    if obj then
        local success, val = pcall(function() return obj.Value end)
        if success and val ~= nil then return tostring(val) end
    end
    return "N/A"
end

local function safeGetNestedVal(parent,folderName,name)
    if not parent then return "N/A" end
    local folder = parent:FindFirstChild(folderName)
    if folder then
        local obj = folder:FindFirstChild(name)
        if obj then
            local success, val = pcall(function() return obj.Value end)
            if success and val ~= nil then return tostring(val) end
        end
    end
    return "N/A"
end

local function getStatLayoutAndTier(statName,valNumStr)
    local valNum = tonumber(valNumStr)
    if not valNum then return 0,"N/A" end
    local bestLayout, bestTier, minDiff = 0, "N/A", math.huge
    for tier,data in pairs(talent_check) do
        if data and data.Status then
            local targetVal = data.Status[statName]
            if targetVal then
                local diff = math.abs(valNum-targetVal)
                if diff < 0.015 and diff < minDiff then
                    minDiff = diff; bestLayout = data.layout; bestTier = tier
                end
            end
        end
    end
    return bestLayout,bestTier
end

