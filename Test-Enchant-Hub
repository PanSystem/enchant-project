local isRunning = true

local function tween(obj, info, props)
    local t = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

local function smoothText(text, delayParam)
    StatusText.Text = ""
    local tLen = string.len(text)
    local d = delayParam or (0.5 / tLen)
    for i = 1, tLen do
        if not isRunning then break end
        StatusText.Text = string.sub(text, 1, i) .. "_"
        task.wait(d)
    end
    if isRunning then 
        StatusText.Text = text 
    end
end

local rotConn = RunService.RenderStepped:Connect(function(dt)
    if Ring1.Parent then
        Ring1.Rotation = Ring1.Rotation + (12 * dt)
        Ring2.Rotation = Ring2.Rotation - (18 * dt)
        Ring3.Rotation = Ring3.Rotation + (6 * dt)
    end
end)

local smoothIntro = TweenInfo.new(1.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

task.spawn(function()
    tween(Background, smoothIntro, {BackgroundTransparency = 0})
    tween(Blur, smoothIntro, {Size = 25})
    tween(CenterGroup, smoothIntro, {Position = UDim2.new(0.5, 0, 0.48, 0)})
    
    tween(Stroke1, smoothIntro, {Transparency = 0.3})
    tween(Ring2.UIStroke, smoothIntro, {Transparency = 0.5})
    tween(Ring3.UIStroke, smoothIntro, {Transparency = 0.8})
    
    tween(Logo, smoothIntro, {ImageTransparency = 0})
    tween(LogoGlow, smoothIntro, {ImageTransparency = 0.4})
    tween(Title, smoothIntro, {TextTransparency = 0})
    tween(Subtitle, smoothIntro, {TextTransparency = 0})
    
    tween(BarBack, smoothIntro, {BackgroundTransparency = 0.5})
    tween(BarFill, smoothIntro, {BackgroundTransparency = 0})
    tween(StatusText, smoothIntro, {TextTransparency = 0})
    
    task.spawn(function()
        while isRunning and Logo.Parent do
            tween(Logo, TweenInfo.new(3, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Position = UDim2.new(0.5, 0, 0.38, 0)})
            tween(LogoGlow, TweenInfo.new(3, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Position = UDim2.new(0.5, 0, 0.38, 0)}).Completed:Wait()
            
            if not isRunning then break end
            
            tween(Logo, TweenInfo.new(3, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Position = UDim2.new(0.5, 0, 0.42, 0)})
            tween(LogoGlow, TweenInfo.new(3, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Position = UDim2.new(0.5, 0, 0.42, 0)}).Completed:Wait()
        end
    end)
    
    task.wait(1)

    smoothText("Fetching Client HWID...")
    tween(BarFill, TweenInfo.new(1, Enum.EasingStyle.Quint), {Size = UDim2.new(0.4, 0, 1, 0)})
    
    local hwid = ""
    local success, result = pcall(function() 
        return game:GetService("RbxAnalyticsService"):GetClientId() 
    end)
    
    if success and result then 
        hwid = result 
    elseif gethwid then 
        hwid = gethwid() 
    end
    
    task.wait(0.5)

    smoothText("Verifying Access Tier...")
    tween(BarFill, TweenInfo.new(1.5, Enum.EasingStyle.Quint), {Size = UDim2.new(0.8, 0, 1, 0)})
    
    local isPremium = false
    local allowedGameIds = {"ALL"}

    local reqSuccess, reqErr = pcall(function()
        local authCheck = loadstring(game:HttpGet(AUTH_URL))()
        isPremium, allowedGameIds = authCheck(hwid)
    end)

    if reqSuccess and isPremium then
        StatusText.TextColor3 = Color3.fromRGB(180, 255, 180)
        smoothText("Premium Access Granted.")
    else
        isPremium = false
        StatusText.TextColor3 = Color3.fromRGB(200, 200, 200)
        smoothText("Free Version Initialized.")
        pcall(function() setclipboard(hwid) end)
    end

    tween(BarFill, TweenInfo.new(0.5, Enum.EasingStyle.Sine), {Size = UDim2.new(1, 0, 1, 0)})
    task.wait(0.8)
    
    isRunning = false
    rotConn:Disconnect()

    local fastOut = TweenInfo.new(0.6, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
    
    tween(CenterGroup, fastOut, {Size = UDim2.new(0, 650, 0, 650), Position = UDim2.new(0.5, 0, 0.45, 0)})
    tween(Stroke1, fastOut, {Transparency = 1})
    tween(Ring2.UIStroke, fastOut, {Transparency = 1})
    tween(Ring3.UIStroke, fastOut, {Transparency = 1})
    tween(Logo, fastOut, {ImageTransparency = 1, Size = UDim2.new(0, 200, 0, 200)})
    tween(LogoGlow, fastOut, {ImageTransparency = 1})
    tween(Title, fastOut, {TextTransparency = 1})
    tween(Subtitle, fastOut, {TextTransparency = 1})
    tween(BarBack, fastOut, {BackgroundTransparency = 1})
    tween(BarFill, fastOut, {BackgroundTransparency = 1})
    tween(StatusText, fastOut, {TextTransparency = 1})
    
    task.wait(0.4)
    tween(Background, TweenInfo.new(0.8, Enum.EasingStyle.Sine), {BackgroundTransparency = 1})
    tween(Blur, TweenInfo.new(0.8, Enum.EasingStyle.Sine), {Size = 0})
    
    task.wait(1)
    ScreenGui:Destroy()
    Blur:Destroy()

    pcall(function()
        loadstring(game:HttpGet(MAIN_SCRIPT_URL))(isPremium, allowedGameIds, hwid)
    end)
end)
