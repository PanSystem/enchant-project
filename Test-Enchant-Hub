        or safeGetNestedVal(unitFolder,"Potentials_Adjustment","Speed"))
        
    local info = string.format(
        "Name units : %s\nLevel Units : %s\n--- Traits ---\nPrimary > %s\nSub > %s\n--- Talents ---\nDamage > %s\nAbility Damage > %s\nCritical > %s\nSpeed > %s",
        nickName,level,traitPrimary,traitSub,talDmg,talAbil,talCrit,talSpd)
        
    info = info.."\n\n--- Queue Status ---"
    if #selectedInventoryUnits > 0 then
        for i,uName in ipairs(selectedInventoryUnits) do
            local state = unitStates[uName] or "waiting"
            local emoji = (state=="done") and "✅" or (state=="rolling" and "🔄" or "⏸️")
            info = info..string.format("\n%d. %s [%s]",i,uName,emoji)
        end
    else 
        info = info.."\nNone" 
    end
    return info
end

