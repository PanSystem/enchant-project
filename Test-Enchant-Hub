local function attackMonster(targetMon, isEnabledFunc)
    local activeTween = nil
    local firstMoveDone = false
    local ATTACK_RANGE = 10 

    while targetMon and targetMon.Model and targetMon.Model.Parent == Server do
        if isEnabledFunc and not isEnabledFunc() then 
            if activeTween then activeTween:Cancel(); activeTween = nil end
            break 
        end
        
        if not targetMon.Humanoid or targetMon.Humanoid.Health <= 0 then break end
        local char = LP.Character
        local pHRP = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
        if not pHRP then break end
        
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum and not char:FindFirstChildOfClass("Tool") then
            local bpTool = LP.Backpack:FindFirstChildOfClass("Tool")
            if bpTool then hum:EquipTool(bpTool) end
        end
        
        if not targetMon.HRP then break end
        local destPos = targetMon.HRP.Position
        
        local dist = (pHRP.Position - destPos).Magnitude
        
        if not firstMoveDone or dist > ATTACK_RANGE then
            if farmMode == "Tween" then
                if not activeTween or activeTween.PlaybackState ~= Enum.PlaybackState.Playing then
                    activeTween = tweenToPosition(destPos)
                end
            else
                teleportToPosition(destPos, true)
                task.wait(0.05)
            end
            firstMoveDone = true
        end
        
        local checkDist = (pHRP.Position - targetMon.HRP.Position).Magnitude
        
        if checkDist <= ATTACK_RANGE then
            if activeTween then activeTween:Cancel(); activeTween = nil end
            
            if not hasSuccessfullyAttacked(targetMon.Model) then
                pcall(function() RequestReq:FireServer(targetMon.Model.Name, "Mouse") end)
            end
            
        elseif farmMode == "Tp" and checkDist > ATTACK_RANGE and firstMoveDone then
            teleportToPosition(targetMon.HRP.Position, true)
        end
        
        task.wait(0.05)
    end
    if activeTween then activeTween:Cancel() end
end

