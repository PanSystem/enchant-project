local function smartWait(seconds, conditionFunc)
    local elapsed = 0
    while elapsed < seconds do
        if conditionFunc and not conditionFunc() then return false end
        task.wait(0.1)
        elapsed = elapsed + 0.1
    end
    return true
end

local function FireOrInvokeRemote(parentFolder, remoteName, ...)
    if not parentFolder then return end
    local remote = parentFolder:FindFirstChild(remoteName)
    if not remote then return end
    
    local args = {...}
    if remote:IsA("RemoteEvent") then pcall(function() remote:FireServer(unpack(args)) end)
    elseif remote:IsA("RemoteFunction") then task.spawn(function() pcall(function() remote:InvokeServer(unpack(args)) end) end) end
end

